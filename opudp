# ============================================================
# USER CARD
# Password string explained clearly — no confusion
# ============================================================
print_user_card() {
    local pass="$1" exp="$2" days="$3" quota="$4" devid="$5" label="${6:-USER DETAILS}"
    local APP_PASS BIND_STATUS

    # -------------------------------------------------------
    # ZIVPN auth works by plain string match.
    # If device binding ON:  config stores  "pass|HWID"
    #                        user types in app: "pass|HWID"
    # If device binding OFF: config stores  "pass"
    #                        user types in app: "pass"
    # -------------------------------------------------------
    if [ -n "$devid" ] && [ "$devid" != "None" ] && [ "$devid" != "none" ]; then
        APP_PASS="${pass}|${devid}"
        BIND_STATUS="${G}ENABLED (Device Locked)${NC}"
    else
        APP_PASS="${pass}"
        BIND_STATUS="${Y}DISABLED (No Device ID)${NC}"
    fi

    local CREATED
    CREATED=$(get_time)

    echo ""
    echo -e "${C}${BOLD}╔══════════════════════════════════════════════════════════╗${NC}"
    printf "${C}${BOLD}║${NC}  ${G}${BOLD}🎉  %-52s${NC}${C}${BOLD}║${NC}\n" "OPZIVPN PANEL — ${label}"
    echo -e "${C}${BOLD}╠══════════════════════════════════════════════════════════╣${NC}"
    echo -e "${C}${BOLD}║  📡  SERVER INFO                                         ║${NC}"
    echo -e "${C}${BOLD}╠══════════════════════════════════════════════════════════╣${NC}"
    printf "${C}${BOLD}║${NC}  🌍 %-20s : ${W}${BOLD}%-25s${NC}${C}${BOLD}║${NC}\n" "Server IP"         "$IP"
    printf "${C}${BOLD}║${NC}  🔌 %-20s : ${W}${BOLD}%-25s${NC}${C}${BOLD}║${NC}\n" "Port"              "$PORT"
    printf "${C}${BOLD}║${NC}  📍 %-20s : ${W}%-25s${NC}${C}${BOLD}║${NC}\n"         "Location"          "${CITY}, ${COUNTRY}"
    printf "${C}${BOLD}║${NC}  🏢 %-20s : ${W}%-25s${NC}${C}${BOLD}║${NC}\n"         "ISP"               "${ISP:0:25}"
    echo -e "${C}${BOLD}╠══════════════════════════════════════════════════════════╣${NC}"
