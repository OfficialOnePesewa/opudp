    printf "${C}${BOLD}║${NC}  📱 %-20s : ${W}%-25s${NC}${C}${BOLD}║${NC}\n"         "DevInfo Device ID" "${devid:-None}"
    printf "${C}${BOLD}║${NC}  🛡️  %-19s : "                                          "Anti-Sharing"
