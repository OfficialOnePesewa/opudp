    echo -e " ${Y}Total Users: ${W}${BOLD}${TOTAL}${NC}"
}

# ============================================================
# CLEANUP EXPIRED
# ============================================================
cleanup_expired() {
    local TODAY COUNT=0
    TODAY=$(date +%Y-%m-%d)
    [ ! -f "$DB" ] && echo -e "${R}No database found.${NC}" && return

    while IFS='|' read -r pass exp _ devid _; do
        if [[ "$exp" < "$TODAY" ]]; then
            if [ -f "$CONFIG" ]; then
                jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
                    > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
                [ "$devid" != "None" ] && \
                jq --arg p "${pass}|${devid}" '.auth.config -= [$p]' "$CONFIG" \
                    > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            fi
            sed -i "/^${pass}|/d" "$DB"
            COUNT=$((COUNT + 1))
        fi
    done < <(cat "$DB")
    systemctl restart zivpn 2>/dev/null
    echo -e "${G}Cleanup done. Removed ${Y}${COUNT}${G} expired user(s).${NC}"
}

# ============================================================
# CONNECTION STATS
# ============================================================
connection_stats() {
    local ACTIVE ZSTATUS
    ACTIVE=$(ss -tnp 2>/dev/null | grep -c "zivpn" || echo "0")
    ZSTATUS=$(systemctl is-active zivpn 2>/dev/null || echo "inactive")
    echo ""
    echo -e "${C}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${C}${BOLD}║          CONNECTION STATS                ║${NC}"
    echo -e "${C}${BOLD}╠══════════════════════════════════════════╣${NC}"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Active Connections"  "$ACTIVE"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "ZIVPN Status"        "$ZSTATUS"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Listen Port"         "$PORT"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Server IP"           "$IP"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Location"            "${CITY}, ${COUNTRY}"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Uptime"              "$(uptime -p | sed 's/up //')"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Load Average"        "$(cut -d' ' -f1-3 /proc/loadavg)"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Memory"              "$(free -h | awk '/Mem:/{print $3"/"$2}')"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Disk (/)"            "$(df -h / | awk 'NR==2{print $3"/"$2" ("$5")"}')"
    printf "${C}${BOLD}║${NC}  %-22s : ${W}%-16s${NC}${C}${BOLD}║${NC}\n" "Total Users"         "$(wc -l < "$DB" 2>/dev/null || echo 0)"
    echo -e "${C}${BOLD}╚══════════════════════════════════════════╝${NC}"
}

# ============================================================
# BANDWIDTH + EXPIRY
# ============================================================
bandwidth_expiry() {
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && echo -e "${R}No users.${NC}" && return
    echo ""
    echo -e "${C}${BOLD}╔═══════════════════════════════════════════════════════╗${NC}"
    echo -e "${C}${BOLD}║            BANDWIDTH & EXPIRY REPORT                  ║${NC}"
    echo -e "${C}${BOLD}╠══════════════╦════════════╦══════════╦════════════════╣${NC}"
    printf "${C}${BOLD}║${NC} ${Y}%-12s${NC} ${C}${BOLD}║${NC} ${Y}%-10s${NC} ${C}${BOLD}║${NC} ${Y}%-8s${NC} ${C}${BOLD}║${NC} ${Y}%-14s${NC} ${C}${BOLD}║${NC}\n" \
        "Password" "Expiry" "Quota" "Used"
    echo -e "${C}${BOLD}╠══════════════╬════════════╬══════════╬════════════════╣${NC}"
    while IFS='|' read -r p exp q dev used; do
        printf "${C}${BOLD}║${NC} %-12s ${C}${BOLD}║${NC} %-10s ${C}${BOLD}║${NC} %-8s ${C}${BOLD}║${NC} %-14s ${C}${BOLD}║${NC}\n" \
            "${p:0:12}" "$exp" "${q:0:8}" "${used:-0}"
    done < "$DB"
    echo -e "${C}${BOLD}╚══════════════╩════════════╩══════════╩════════════════╝${NC}"
}

# ============================================================
# RESET BANDWIDTH
# ============================================================
reset_bandwidth() {
    read -p " Reset for (password or 'all'): " target
    if [ "$target" = "all" ]; then
        [ -f "$DB" ] && awk -F'|' 'BEGIN{OFS="|"}{$5="0";print}' "$DB" \
            > /tmp/db_tmp && mv /tmp/db_tmp "$DB"
        echo -e "${G}All user bandwidth reset.${NC}"
    else
        grep -q "^${target}|" "$DB" 2>/dev/null \
            && sed -i "/^${target}|/s/|[^|]*$/|0/" "$DB" \
            && echo -e "${G}Bandwidth reset for '${target}'.${NC}" \
            || echo -e "${R}User not found.${NC}"
    fi
}

# ============================================================
# SPEED TEST
# ============================================================
speed_test() {
    echo -e "${Y}Running speed test...${NC}"
    if command -v speedtest-cli &>/dev/null; then
        speedtest-cli --simple
    else
        install_pkg python3-pip
        pip3 install speedtest-cli -q 2>/dev/null
        command -v speedtest-cli &>/dev/null \
            && speedtest-cli --simple \
            || echo -e "${R}Could not install speedtest-cli.${NC}"
    fi
}

# ============================================================
# BACKUP / RESTORE
# ============================================================
backup_data() {
    local BDIR="/root/ovps_backup"
    mkdir -p "$BDIR"
    local BFILE="${BDIR}/backup_$(date +%Y%m%d_%H%M%S).tar.gz"
    tar -czf "$BFILE" /etc/zivpn/ 2>/dev/null
    echo -e "${G}Backup saved: ${Y}${BFILE}${NC}"
}

restore_backup() {
    local BDIR="/root/ovps_backup"
    echo -e "\n${Y}Available backups:${NC}"
    ls -1 "${BDIR}"/*.tar.gz 2>/dev/null || { echo -e "${R}No backups found.${NC}"; return; }
    read -p " Filename: " fname
    if [ -f "${BDIR}/${fname}" ]; then
        tar -xzf "${BDIR}/${fname}" -C / 2>/dev/null
        systemctl restart zivpn 2>/dev/null
        echo -e "${G}Restore complete.${NC}"
    else
        echo -e "${R}File not found.${NC}"
    fi
}

# ============================================================
# CHANGE PORT RANGE - also updates firewall
# ============================================================
change_port_range() {
    read -p " New start port: " pstart
    read -p " New end port  : " pend
    if [ -f "$CONFIG" ]; then
        jq --argjson s "$pstart" --argjson e "$pend" \
            '.nat_port_range.start = $s | .nat_port_range.end = $e' \
            "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
        # Update firewall for new range
        if command -v ufw &>/dev/null; then
            ufw allow "${pstart}:${pend}/udp" &>/dev/null
        fi
        if command -v iptables &>/dev/null; then
            iptables -I INPUT -p udp --dport "${pstart}:${pend}" -j ACCEPT &>/dev/null
        fi
        echo -e "${G}Port range updated: ${W}${pstart}-${pend}${NC}"
        echo -e "${G}Firewall updated for new range.${NC}"
    else
        echo -e "${R}Config not found.${NC}"
    fi
}

# ============================================================
# SET CONNECTION LIMIT
# ============================================================
set_conn_limit() {
    read -p " Max connections per user: " limit
    if [ -f "$CONFIG" ]; then
        jq --argjson l "$limit" '.max_connections = $l' "$CONFIG" \
            > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
        echo -e "${G}Limit set to ${W}${limit}${NC}"
    else
        echo -e "${R}Config not found.${NC}"
    fi
}

# ============================================================
# FIX FIREWALL - manual trigger from menu
# ============================================================
fix_firewall_menu() {
    echo -e "\n${Y}Opening all required ZIVPN ports...${NC}"
    local SPORT EPORT EPORT_END
    SPORT=$(jq -r '.listen_port // 5667' "$CONFIG" 2>/dev/null || echo 5667)
    EPORT=$(jq -r '.nat_port_range.start // 6000' "$CONFIG" 2>/dev/null || echo 6000)
    EPORT_END=$(jq -r '.nat_port_range.end // 19999' "$CONFIG" 2>/dev/null || echo 19999)

    if command -v ufw &>/dev/null; then
        ufw allow "${SPORT}/udp"              && echo -e "${G}UFW: ${SPORT}/udp opened${NC}"
        ufw allow "${SPORT}/tcp"              && echo -e "${G}UFW: ${SPORT}/tcp opened${NC}"
        ufw allow "${EPORT}:${EPORT_END}/udp" && echo -e "${G}UFW: ${EPORT}-${EPORT_END}/udp opened${NC}"
        ufw reload &>/dev/null
    else
        echo -e "${Y}UFW not found, applying iptables rules...${NC}"
    fi

    if command -v iptables &>/dev/null; then
        iptables -I INPUT -p udp --dport "${SPORT}" -j ACCEPT
        iptables -I INPUT -p tcp --dport "${SPORT}" -j ACCEPT
        iptables -I INPUT -p udp --dport "${EPORT}:${EPORT_END}" -j ACCEPT
        iptables -I FORWARD -j ACCEPT
        echo -e "${G}iptables rules applied.${NC}"
    fi

    echo ""
    echo -e "${G}${BOLD}Firewall fix complete! Ports open:${NC}"
    echo -e "${W}  Listen Port : ${Y}${SPORT}/udp + tcp${NC}"
    echo -e "${W}  NAT Range   : ${Y}${EPORT}-${EPORT_END}/udp${NC}"
    echo ""
    echo -e "${Y}Now restart ZIVPN and try connecting again.${NC}"
    systemctl restart zivpn 2>/dev/null
}

# ============================================================
# AUTO UPDATE
# ============================================================
auto_update() {
    echo -e "\n${Y}Fetching latest OPZIVPN PANEL from GitHub...${NC}"
    wget -qO /usr/local/bin/ovps \
        https://raw.githubusercontent.com/OfficialOnePesewa/ovps/main/ovps
    chmod +x /usr/local/bin/ovps
    echo -e "${G}Update complete! Restarting...${NC}"
    sleep 2
    exec ovps
}

# ============================================================
# UNINSTALL
# ============================================================
uninstall_panel() {
    echo -e "${R}${BOLD}WARNING: Removes ZIVPN service and all panel files.${NC}"
    read -p " Type 'yes' to confirm: " confirm
    [ "$confirm" != "yes" ] && echo -e "${Y}Cancelled.${NC}" && return
    systemctl stop zivpn 2>/dev/null
    systemctl disable zivpn 2>/dev/null
    rm -f /etc/systemd/system/zivpn.service
    systemctl daemon-reload 2>/dev/null
    rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/ovps
    echo -e "${R}Uninstalled.${NC}"
    exit 0
}

