# ============================================================
# COMPATIBILITY - Debian & Ubuntu (any version)
# ============================================================
PKG_MANAGER="apt-get"
command -v apt &>/dev/null && PKG_MANAGER="apt"

install_pkg() {
    $PKG_MANAGER install -y "$1" -qq &>/dev/null 2>&1
}

for tool in jq curl wget openssl; do
    if ! command -v "$tool" &>/dev/null; then
        echo -e "${Y}Installing $tool...${NC}"
        $PKG_MANAGER update -qq &>/dev/null
        install_pkg "$tool"
    fi
done

# ============================================================
# FIREWALL - Auto-open ZIVPN required ports on every launch
# ============================================================
fix_firewall() {
    local SPORT EPORT
    SPORT=5667
    EPORT=""
    if [ -f "$CONFIG" ]; then
        SPORT=$(jq -r '.listen_port // 5667' "$CONFIG" 2>/dev/null)
        EPORT=$(jq -r '.nat_port_range.start // 6000' "$CONFIG" 2>/dev/null)
        EPORT_END=$(jq -r '.nat_port_range.end // 19999' "$CONFIG" 2>/dev/null)
    fi
    [ -z "$SPORT" ]     && SPORT=5667
    [ -z "$EPORT" ]     && EPORT=6000
    [ -z "$EPORT_END" ] && EPORT_END=19999

    # UFW
    if command -v ufw &>/dev/null; then
        ufw allow "${SPORT}/udp"              &>/dev/null
        ufw allow "${SPORT}/tcp"              &>/dev/null
        ufw allow "${EPORT}:${EPORT_END}/udp" &>/dev/null
    fi

    # iptables fallback
    if command -v iptables &>/dev/null; then
        iptables -I INPUT -p udp --dport "${SPORT}" -j ACCEPT              &>/dev/null
        iptables -I INPUT -p tcp --dport "${SPORT}" -j ACCEPT              &>/dev/null
        iptables -I INPUT -p udp --dport "${EPORT}:${EPORT_END}" -j ACCEPT &>/dev/null
        iptables -I FORWARD -j ACCEPT                                       &>/dev/null
    fi
}

# Run silently on every panel launch
fix_firewall

# ============================================================
# TIME - AM/PM with timezone label
# ============================================================
get_time() {
    date +"%A, %d %B %Y  %I:%M:%S %p (%Z)"
}

# ============================================================
# GEO INFO - ipapi.io primary, ip-api.com fallback
# ============================================================
fetch_geo() {
    GEO=$(curl -4 -s --max-time 10 "https://ipapi.io/json" 2>/dev/null)
    IP=$(echo "$GEO"      | grep -oP '"ip":\s*"\K[^"]+')
    CITY=$(echo "$GEO"    | grep -oP '"city":\s*"\K[^"]+')
    COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
    ISP=$(echo "$GEO"     | grep -oP '"org":\s*"\K[^"]+')
    [ -z "$ISP" ] && ISP=$(echo "$GEO" | grep -oP '"asn_organisation":\s*"\K[^"]+')

    if [ -z "$IP" ] || [ "$IP" = "null" ]; then
        GEO2=$(curl -4 -s --max-time 10 "http://ip-api.com/json/" 2>/dev/null)
        IP=$(echo "$GEO2"      | grep -oP '"query":\s*"\K[^"]+')
        CITY=$(echo "$GEO2"    | grep -oP '"city":\s*"\K[^"]+')
        COUNTRY=$(echo "$GEO2" | grep -oP '"country":\s*"\K[^"]+')
        ISP=$(echo "$GEO2"     | grep -oP '"isp":\s*"\K[^"]+')
    fi

    OS_INFO=$(grep "PRETTY_NAME" /etc/os-release 2>/dev/null | cut -d '"' -f 2)
    [ -z "$IP" ]      && IP="N/A"
    [ -z "$CITY" ]    && CITY="Unknown"
    [ -z "$COUNTRY" ] && COUNTRY="Unknown"
    [ -z "$ISP" ]     && ISP="Unknown"
    [ -z "$OS_INFO" ] && OS_INFO="Linux"
}

get_port() {
    PORT="5667"
    [ -f "$CONFIG" ] && PORT=$(jq -r '.listen_port // 5667' "$CONFIG" 2>/dev/null)
    [ -z "$PORT" ] && PORT="5667"
}

fetch_geo
get_port

