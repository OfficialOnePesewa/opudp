    printf "${C}${BOLD}║${NC}  ⏳ %-20s : ${M}${BOLD}%-25s${NC}${C}${BOLD}║${NC}\n" "Expiry"            "$exp"
    printf "${C}${BOLD}║${NC}  📅 %-20s : ${M}${BOLD}%-25s${NC}${C}${BOLD}║${NC}\n" "Duration"          "${days} Day(s)"
