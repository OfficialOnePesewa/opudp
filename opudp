# ============================================================
# ADD USER
# ============================================================
add_user() {
    echo -e "\n${Y}${BOLD}--- ADD NEW USER ---${NC}"
    read -p "  Password                     : " pass
    [ -z "$pass" ] && echo -e "${R}Password required.${NC}" && return

    read -p "  Validity (Days)              : " days
    [[ ! "$days" =~ ^[0-9]+$ ]] && echo -e "${R}Invalid days.${NC}" && return

    read -p "  Quota (e.g. 10GB)            : " quota

    echo -e ""
    echo -e "  ${C}${BOLD}--- DEVICE BINDING (Anti-Sharing) ---${NC}"
    echo -e "  ${W}Client installs: ${G}${BOLD}DevInfo${NC}${W} from Play Store${NC}"
    echo -e "  ${W}Steps: Open DevInfo → Device tab → copy ${G}Android Device ID${NC}"
    echo -e ""
    read -p "  Android Device ID (DevInfo)  : " devid
    [ -z "$devid" ] && devid="None"

    local exp
    exp=$(date -d "+${days} days" +%Y-%m-%d 2>/dev/null \
       || python3 -c "from datetime import date,timedelta; \
          print((date.today()+timedelta(days=${days})).isoformat())" 2>/dev/null)

    # Auth string written to ZIVPN config:
    # - With device binding:    "password|DeviceID"
    # - Without device binding: "password"
    # User must type this exact string into the ZIVPN app password field
    local AUTH_STR="$pass"
    [ "$devid" != "None" ] && AUTH_STR="${pass}|${devid}"

    if [ -f "$CONFIG" ]; then
        jq --arg p "$AUTH_STR" '.auth.config += [$p]' "$CONFIG" \
            > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    else
        echo -e "${R}Warning: ZIVPN config not found. Saved to DB only.${NC}"
    fi

    # DB: password|expiry|quota|device_id|used_bytes
    echo "${pass}|${exp}|${quota}|${devid}|0" >> "$DB"
    systemctl restart zivpn 2>/dev/null

    print_user_card "$pass" "$exp" "$days" "$quota" "$devid" "NEW USER ADDED"
}

# ============================================================
# TRIAL USER
# ============================================================
trial_user() {
    echo -e "\n${Y}${BOLD}--- TRIAL USER ---${NC}"
    read -p "  Duration (1-60 min): " mins
    [[ ! "$mins" =~ ^[0-9]+$ ]] || [ "$mins" -lt 1 ] || [ "$mins" -gt 60 ] \
        && echo -e "${R}Enter 1-60.${NC}" && return

    echo -e ""
    echo -e "  ${C}${BOLD}--- DEVICE BINDING (Anti-Sharing) ---${NC}"
    echo -e "  ${W}Client installs ${G}${BOLD}DevInfo${NC}${W} → Device tab → Android Device ID${NC}"
    echo -e ""
    read -p "  Android Device ID (DevInfo) [blank=skip]: " devid
    [ -z "$devid" ] && devid="None"

    local pass="trial_$(openssl rand -hex 3)"
    local exp
    exp=$(date -d "+${mins} minutes" +"%Y-%m-%d %H:%M" 2>/dev/null \
       || date +"%Y-%m-%d %H:%M")

    local AUTH_STR="$pass"
    [ "$devid" != "None" ] && AUTH_STR="${pass}|${devid}"

    if [ -f "$CONFIG" ]; then
        jq --arg p "$AUTH_STR" '.auth.config += [$p]' "$CONFIG" \
            > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi

    print_user_card "$pass" "Expires in ${mins} min(s) [${exp}]" \
        "${mins} min(s)" "Trial / Free" "$devid" "TRIAL USER"

    (
        sleep $((mins * 60))
        [ -f "$CONFIG" ] && \
        jq --arg p "$AUTH_STR" '.auth.config -= [$p]' "$CONFIG" \
            > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    ) &
}

# ============================================================
# RENEW USER
# ============================================================
renew_user() {
    echo -e "\n${Y}${BOLD}--- RENEW USER ---${NC}"
    read -p "  Password to renew: " pass
    if ! grep -q "^${pass}|" "$DB" 2>/dev/null; then
        echo -e "${R}User not found.${NC}"; return
    fi
    read -p "  New Validity (Days): " days
    [[ ! "$days" =~ ^[0-9]+$ ]] && echo -e "${R}Invalid days.${NC}" && return

    local exp quota devid used
    IFS='|' read -r _ _ quota devid used <<< "$(grep "^${pass}|" "$DB" | head -1)"
    exp=$(date -d "+${days} days" +%Y-%m-%d 2>/dev/null)

    sed -i "s|^${pass}|[^|]*||${pass}|${exp}|" "$DB"

    print_user_card "$pass" "$exp" "$days" "${quota:-N/A}" "${devid:-None}" "USER RENEWED"
}

# ============================================================
# REMOVE USER
# ============================================================
remove_user() {
    echo -e "\n${Y}${BOLD}--- REMOVE USER ---${NC}"
    read -p "  Password to remove: " pass
    local devid
    IFS='|' read -r _ _ _ devid _ <<< "$(grep "^${pass}|" "$DB" 2>/dev/null | head -1)"

    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
            > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        if [ -n "$devid" ] && [ "$devid" != "None" ]; then
            jq --arg p "${pass}|${devid}" '.auth.config -= [$p]' "$CONFIG" \
                > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        fi
    fi
    [ -f "$DB" ] && sed -i "/^${pass}|/d" "$DB"
    systemctl restart zivpn 2>/dev/null
    echo -e "${G}User '${pass}' removed.${NC}"
}

