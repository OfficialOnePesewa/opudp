show_user_status() {
    echo -ne "${GRN}Enter full password: ${RST}"; read pass
    user_data=$(grep "^$pass|" "$DB")
    if [ -z "$user_data" ]; then
        echo -e "${RED}Password not found.${RST}"; read -p "Press Enter..."; return
    fi
    IFS='|' read -r p expiry quota port hwid start <<< "$user_data"
    used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}
    quota_bytes=$(quota_to_bytes "$quota")
    remain=$((quota_bytes - used))
    [ $remain -lt 0 ] && remain=0
    days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
    sessions=$(ss -un state established 2>/dev/null | grep -c ":$port " || echo 0)
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│           📊 ACCOUNT STATUS 📊                         │${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST} ${YLW}🔑 Password  :${RST} $p"
    echo -e "${CYN}│${RST} ${YLW}📅 Expiry    :${RST} $expiry (${days_left} days left)"
    echo -e "${CYN}│${RST} ${YLW}📊 Quota     :${RST} $quota"
    echo -e "${CYN}│${RST} ${YLW}📈 Used      :${RST} $(format_bytes $used)"
    echo -e "${CYN}│${RST} ${YLW}📉 Remaining :${RST} $(format_bytes $remain)"
    echo -e "${CYN}│${RST} ${YLW}🔒 HWID      :${RST} $hwid"
    echo -e "${CYN}│${RST} ${YLW}👥 Sessions  :${RST} $sessions"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}"
    read -p "Press Enter..."
}

renew_user_interactive() {
    echo -ne "${GRN}Full password: ${RST}"; read pass
    echo -ne "${GRN}Days to add: ${RST}"; read days
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    [ -z "$oldexp" ] && { echo -e "${RED}User not found.${RST}"; read -p "Press Enter..."; return; }
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
    awk -F'|' -v OFS='|' -v p="$pass" -v newexp="$newexp" '$1==p{$2=newexp}1' "$DB" > /tmp/db.tmp && mv /tmp/db.tmp "$DB"
    echo -e "${GRN}Expiry extended to $newexp${RST}"
    read -p "Press Enter..."
}

cleanup_expired() {
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port hwid start; do
        [[ "$expiry" < "$today" ]] && {
            [ -n "$port" ] && remove_tracking "$port"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
        }
    done < "$DB"
    systemctl restart zivpn 2>/dev/null || true
    echo -e "${GRN}Expired users cleaned.${RST}"
    read -p "Press Enter..."
}

connection_stats() {
    echo -e "\n${CYN}Current UDP sessions per user:${RST}"
    while IFS='|' read -r pass expiry quota port hwid start; do
        sessions=$(ss -un state established 2>/dev/null | grep -c ":$port " || echo 0)
        echo -e "${WHT}$pass${RST} : ${YLW}$sessions sessions${RST}"
    done < "$DB"
    read -p "Press Enter..."
}

bw_expiry_summary() {
    echo -e "\n${CYN}Password | Used/Quota | Expiry${RST}"
    while IFS='|' read -r pass expiry quota port hwid start; do
        used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ]; then
            echo "$pass | $(format_bytes $used) / $quota | $expiry"
        else
            echo "$pass | $(format_bytes $used) / unlimited | $expiry"
        fi
    done < "$DB"
    read -p "Press Enter..."
}

reset_bandwidth_interactive() {
    echo -ne "${GRN}Full password: ${RST}"; read pass
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    [ -n "$port" ] && { iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null; }
    sed -i "/^$pass|/c\\$pass|0" "$USAGE_DB"
    reset_user_quota_pause "$pass"
    echo -e "${GRN}Bandwidth reset.${RST}"
    read -p "Press Enter..."
}

speed_test() {
    command -v speedtest-cli &>/dev/null && speedtest-cli || echo -e "${YLW}speedtest-cli missing.${RST}"
