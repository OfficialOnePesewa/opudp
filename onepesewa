# ════════════════════════════════════════════════════════════════
#  BOT CLI MODE  (called by opudp_bot.py via --bot-*)
# ════════════════════════════════════════════════════════════════
if [[ "$1" == "--bot-"* ]]; then
    cmd="${1#--bot-}"
    shift

    # Geo needed for status
    [ "$cmd" = "status" ] && fetch_geo

    case "$cmd" in
        status)
            get_sysinfo
            SVC=$(systemctl is-active zivpn 2>/dev/null || echo "unknown")
            echo "🖥 Server Status
🌐 IP: ${IP}
📍 Location: ${CITY}, ${COUNTRY}
🏢 ISP: ${ISP}
💻 OS: ${OS_INFO}
⚡ Service: ${SVC}
⏱ Uptime: ${UPTIME}
👥 Users: ${USER_COUNT}"
            ;;

        adduser)
            # args: password days quota hwid
            result=$(add_user_core "$1" "$2" "$3" "$4")
            if [[ "$result" == SUCCESS* ]]; then
                IFS='|' read -r _s finalpass exp port quota <<< "$result"
                echo "✅ User Created
🔑 Password : ${finalpass}
📅 Expiry   : ${exp}
📊 Quota    : ${quota}
🔌 Port     : ${port}"
            else
                echo "❌ ${result}"
            fi
            ;;

        removeuser)
            pass="$1"
            if ! grep -q "^$(esc "$pass")|" "$DB" 2>/dev/null; then
                echo "❌ User not found."
            else
                remove_user_core "$pass"
                echo "✅ User removed: ${pass}"
            fi
            ;;

        renew)
            result=$(renew_user_core "$1" "$2")
            if [[ "$result" == SUCCESS* ]]; then
                newexp=$(echo "$result" | cut -d'|' -f2)
                echo "✅ Expiry extended to ${newexp}"
            else
                echo "❌ ${result}"
            fi
            ;;

        resetbw)
            result=$(resetbw_core "$1")
            if [[ "$result" == SUCCESS* ]]; then
                echo "✅ Bandwidth reset for: $1"
            else
                echo "❌ ${result}"
            fi
            ;;

        userinfo)
            result=$(get_user_info "$1")
            if [[ "$result" == FOUND* ]]; then
                IFS='|' read -r _f p expiry days_left quota used_hr remain_hr hwid port <<< "$result"
                echo "🔍 User Info
🔑 Password  : ${p}
📅 Expiry    : ${expiry} (${days_left} days left)
📊 Quota     : ${quota}
📈 Used      : ${used_hr}
📉 Remaining : ${remain_hr}
🔒 HWID      : ${hwid}
🔌 Port      : ${port}"
            else
                echo "❌ ${result}"
            fi
            ;;

        list)
            if [ ! -s "$DB" ]; then
                echo "No users found."
            else
                printf "%-30s %-12s %-8s %s\n" "Password" "Expiry" "Quota" "HWID"
                echo "──────────────────────────────────────────────────────────"
                while IFS='|' read -r pass expiry quota port hwid; do
                    printf "%-30s %-12s %-8s %s\n" \
                        "${pass:0:28}" "$expiry" "$quota" "${hwid:0:20}"
                done < "$DB"
            fi
            ;;

        cleanup)
            today=$(date +%Y-%m-%d)
            count=0
            while IFS='|' read -r pass expiry quota port hwid; do
                [ -z "$pass" ] && continue
                if [[ "$expiry" < "$today" ]]; then
                    remove_user_core "$pass"
                    count=$((count+1))
                fi
            done < <(cat "$DB")
            systemctl restart zivpn 2>/dev/null
            echo "✅ Cleanup done. ${count} expired user(s) removed."
            ;;

        trial)
            mins="$1"
            if ! [[ "$mins" =~ ^[0-9]+$ ]] || [ "$mins" -lt 1 ] || [ "$mins" -gt 60 ]; then
                echo "❌ Minutes must be 1–60."; exit 1
            fi
            hwid="trial_$(openssl rand -hex 4)"
            finalpass="trial_${hwid}"
            port=$(find_free_port)
            [ -z "$port" ] && { echo "❌ No free port."; exit 1; }
            exp=$(date -d "+1 day" +%Y-%m-%d)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" \
                > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            echo "${finalpass}|${exp}|100MB|${port}|${hwid}" >> "$DB"
            echo "${finalpass}|0" >> "$USAGE_DB"
            setup_tracking "$port"
            systemctl restart zivpn 2>/dev/null
            echo "✅ Trial Created
🔑 Password : ${finalpass}
⏳ Duration : ${mins} minute(s)
📊 Quota    : 100MB"
            ( sleep $((mins*60))
              remove_tracking "$port"
              jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" \
                  > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
              grep -v "^$(esc "$finalpass")|" "$DB"       > /tmp/db_tmp && mv /tmp/db_tmp "$DB"
              grep -v "^$(esc "$finalpass")|" "$USAGE_DB" > /tmp/ub_tmp && mv /tmp/ub_tmp "$USAGE_DB"
              systemctl restart zivpn 2>/dev/null
            ) &
            ;;

        bbr)
            apt-get install -y curl -qq 2>/dev/null
            bash <(curl -s https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/optimizer.sh --ipv4)
            echo "✅ BBR optimization installed."
            ;;

        badvpn)
            wget -qN https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/Install/udpgw.sh \
                && bash udpgw.sh
            echo "✅ BadVPN installed."
            ;;

        *) echo "❌ Unknown bot command: $cmd"; exit 1 ;;
    esac
    exit 0
fi

