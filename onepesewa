#!/bin/bash
# OFFICIAL ONEPESEWA UDP Dashboard – Modern Compact Edition

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"

# --- Colors ---
C="\e[1;36m"
G="\e[1;32m"
R="\e[1;31m"
Y="\e[1;33m"
M="\e[1;35m"
B="\e[1;34m"
W="\e[1;37m"
NC="\e[0m"
BOLD="\e[1m"

# --- Auto-install jq if missing ---
if ! command -v jq &>/dev/null; then
    echo -e "${Y}Installing jq...${NC}"
    apt-get install -y jq -qq &>/dev/null
fi

# --- Fetch Geo Data (ipapi.co) ---
GEO=$(curl -4 -s --max-time 8 "https://ipapi.co/json/" 2>/dev/null)
if [ -z "$GEO" ] || ! echo "$GEO" | grep -q '"ip"'; then
    IP="N/A"
    CITY="Unknown"
    COUNTRY="Unknown"
    COUNTRY_CODE=""
    ZIP=""
    ISP="Unknown"
else
    IP=$(echo "$GEO"      | grep -oP '"ip":\s*"\K[^"]+')
    CITY=$(echo "$GEO"    | grep -oP '"city":\s*"\K[^"]+')
    COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
    COUNTRY_CODE=$(echo "$GEO" | grep -oP '"country_code":\s*"\K[^"]+' | tr '[:upper:]' '[:lower:]')
    ZIP=$(echo "$GEO"     | grep -oP '"postal":\s*"\K[^"]+')
    ISP=$(echo "$GEO"     | grep -oP '"org":\s*"\K[^"]+')
    [ -z "$IP" ] && IP="N/A"
    [ -z "$CITY" ] && CITY="Unknown"
    [ -z "$COUNTRY" ] && COUNTRY="Unknown"
    [ -z "$ISP" ] && ISP="Unknown"
fi

# Flag emoji from country code (simple mapping)
flag_emoji() {
    case $1 in
        us) echo "🇺🇸" ;; gb) echo "🇬🇧" ;; ca) echo "🇨🇦" ;; au) echo "🇦🇺" ;;
        de) echo "🇩🇪" ;; fr) echo "🇫🇷" ;; nl) echo "🇳🇱" ;; in) echo "🇮🇳" ;;
        jp) echo "🇯🇵" ;; br) echo "🇧🇷" ;; za) echo "🇿🇦" ;; sg) echo "🇸🇬" ;;
        gh) echo "🇬🇭" ;; ng) echo "🇳🇬" ;; ke) echo "🇰🇪" ;; *) echo "" ;;
    esac
}
FLAG=$(flag_emoji "$COUNTRY_CODE")

# --- Service & Uptime ---
service_status() {
    if systemctl is-active --quiet zivpn; then
        echo -e "${G}🟢 active${NC}"
        return 0
    else
        echo -e "${R}🔴 inactive${NC}"
        return 1
    fi
}
STATUS=$(service_status)

uptime_pretty() {
    uptime -p | sed 's/up //' | sed 's/ days/d/' | sed 's/ day/d/' | sed 's/ hours/h/' | sed 's/ hour/h/' | sed 's/ minutes/m/' | sed 's/ minute/m/'
}
UPTIME=$(uptime_pretty 2>/dev/null || echo "N/A")

count_users() {
    if [ -f "$CONFIG" ]; then
        jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0"
    else
        echo "0"
    fi
}
USER_COUNT=$(count_users)

OS_INFO=$(grep "PRETTY_NAME" /etc/os-release | cut -d '"' -f 2)

# --- Modern Banner ---
banner() {
    clear
    DATE_TIME=$(date +"%a %d %b %Y  %H:%M:%S")
    echo -e "${W}${BOLD}🕐  ${DATE_TIME}${NC}"
    echo ""
    echo -e "${W}━━━━━ 🖥  Server Info ━━━━━${NC}"
    echo -e "${W}🌐  IP       :  ${G}$IP${NC}"
    [ -n "$FLAG" ] && LOC_STR="${FLAG}  ${CITY}, ${COUNTRY}" || LOC_STR="${CITY}, ${COUNTRY}"
    echo -e "${W}📍  Location :  ${Y}$LOC_STR${NC}"
    [ -n "$ZIP" ] && echo -e "${W}📮  ZIP      :  ${M}$ZIP${NC}"
    echo -e "${W}🏢  ISP      :  ${C}$ISP${NC}"
    echo -e "${W}🎯  UDP Ports:  ${G}6000:19999${NC}"
    echo ""
    echo -e "${W}━━━━━ ⚡ Service ━━━━━${NC}"
    echo -e "${W}🟢  ZIVPN    :  ${STATUS}"
    echo -e "${W}⏱  Uptime  :  ${Y}$UPTIME${NC}"
    echo -e "${W}👥  Users   :  ${G}$USER_COUNT active${NC}"
    echo -e "${W}━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# --- Goodbye Screen ---
goodbye() {
    clear
    echo -e "${C}${BOLD}=========================================${NC}"
    echo -e "${G}${BOLD}     Thanks For Using${NC}"
    echo -e "${Y}${BOLD}   OFFICIAL ONEPESEWA UDP!${NC}"
    echo -e "${G}${BOLD}        See You Soon! 👋${NC}"
    echo -e "${C}${BOLD}=========================================${NC}"
    echo ""
    echo -e "${M}   Admin   : @OfficialOnePesewa${NC}"
    echo -e "${M}   Channel : https://t.me/OfficialOnePesewa${NC}"
    echo ""
}

# --- Add User with Card Output ---
add_user() {
    echo -e "\n${Y}--- CREATE NEW USER ---${NC}"
    read -p "User Password: " pass
    read -p "Validity (Days): " days
    read -p "Quota (GB/MB): " quota
    read -p "Device ID (Optional): " devid

    exp=$(date -d "+$days days" +%Y-%m-%d)

    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    else
        echo -e "${R}Warning: ZIVPN config not found. User saved to DB only.${NC}"
    fi

    echo "$pass|$exp|$quota|${devid:-None}" >> "$DB"
    systemctl restart zivpn 2>/dev/null || echo -e "${Y}Note: zivpn.service not running.${NC}"

    # Success Card with Server Info
    echo -e "\n${C}╔════════════════════════════════════════╗${NC}"
    echo -e "${C}║  ${G}${BOLD}🎉 NEW USER CREATED SUCCESSFULLY 🎉${C}   ║${NC}"
    echo -e "${C}╠════════════════════════════════════════╣${NC}"
    echo -e "${C}║${NC} ${Y}👤 Password   :${NC} $pass"
    echo -e "${C}║${NC} ${Y}⏳ Expiry     :${NC} $exp ($days Days)"
    echo -e "${C}║${NC} ${Y}📊 Quota      :${NC} $quota"
    echo -e "${C}║${NC} ${Y}📱 Device ID  :${NC} ${devid:-None}"
    echo -e "${C}╠════════════════════════════════════════╣${NC}"
    echo -e "${C}║${NC} ${M}🌍 Server IP  :${NC} $IP"
    echo -e "${C}║${NC} ${M}📍 Location   :${NC} $CITY, $COUNTRY"
    echo -e "${C}║${NC} ${M}🏢 ISP        :${NC} $ISP"
    echo -e "${C}╚════════════════════════════════════════╝${NC}"
}

# --- Trial User ---
trial_user() {
    read -p "Minutes (1-60): " mins
    pass="trial_$(openssl rand -hex 2)"
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi
    echo -e "${G}Trial Created: ${Y}$pass${G} (Expires in $mins mins)${NC}"
    (
        sleep $((mins * 60))
        if [ -f "$CONFIG" ]; then
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
        fi
    ) &
}

# --- Main Menu ---
while true; do
    banner
    echo -e " ${G}1)${NC} Start ZIVPN          ${G}11)${NC} Bandwidth + Expiry"
    echo -e " ${G}2)${NC} Stop ZIVPN           ${G}12)${NC} Reset Bandwidth"
    echo -e " ${G}3)${NC} Restart ZIVPN        ${G}13)${NC} Speed Test"
    echo -e " ${G}4)${NC} Status               ${G}14)${NC} Live Logs"
    echo -e " ${G}5)${NC} List Users + Expiry  ${G}15)${NC} Backup All Data"
    echo -e " ${G}6)${NC} Add User             ${G}16)${NC} Restore Backup"
    echo -e " ${G}7)${NC} Remove User          ${G}17)${NC} Change Port Range"
    echo -e " ${G}8)${NC} Renew / Extend User  ${Y}18)${NC} Auto-Update Panel"
    echo -e " ${G}9)${NC} Cleanup Expired      ${G}19)${NC} Set Connection Limit"
    echo -e " ${G}10)${NC} Connection Stats    ${G}20)${NC} Trial User (1-60m)"
    echo -e "${W}─────────────────────────────────────────${NC}"
    echo -e " ${R}99) UNINSTALL${NC}           ${G}0) Exit${NC}"
    echo -e "${W}─────────────────────────────────────────${NC}"
    read -p " Choose [0-99]: " opt

    case $opt in
        1) systemctl start zivpn 2>/dev/null && echo -e "${G}ZIVPN Started.${NC}" || echo -e "${R}zivpn.service not found.${NC}" ;;
        2) systemctl stop zivpn 2>/dev/null && echo -e "${R}ZIVPN Stopped.${NC}" || echo -e "${R}zivpn.service not found.${NC}" ;;
        3) systemctl restart zivpn 2>/dev/null && echo -e "${G}ZIVPN Restarted.${NC}" || echo -e "${R}zivpn.service not found.${NC}" ;;
        4) systemctl status zivpn 2>/dev/null || echo -e "${R}zivpn.service not found.${NC}" ;;
        5)
           if [ -f "$DB" ]; then
               echo -e "\n${C}Pass | Expiry | Quota | DeviceID${NC}"
               echo "---------------------------------"
               column -t -s "|" "$DB"
           else
               echo -e "${R}No user database found at $DB${NC}"
           fi
           ;;
        6) add_user ;;
        7)
           read -p "Password to remove: " pass
           if [ -f "$CONFIG" ]; then
               jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
           fi
           [ -f "$DB" ] && sed -i "/^$pass|/d" "$DB"
           systemctl restart zivpn 2>/dev/null
           echo -e "${G}User removed.${NC}"
           ;;
        14) journalctl -u zivpn -f 2>/dev/null || echo -e "${R}zivpn.service not found.${NC}" ;;
        18)
           echo -e "\n${Y}Fetching latest panel from GitHub...${NC}"
           wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa
           chmod +x /usr/local/bin/onepesewa
           echo -e "${G}Update complete! Restarting panel...${NC}"
           sleep 2
           exec onepesewa
           ;;
        20) trial_user ;;
        99)
           systemctl stop zivpn 2>/dev/null
           rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa
           echo -e "${R}Uninstalled.${NC}"
           exit
           ;;
        0) goodbye; exit ;;
        *) echo -e "${R}Invalid option.${NC}" ;;
    esac
    echo ""
    read -p "Press Enter to return to menu..."
done
