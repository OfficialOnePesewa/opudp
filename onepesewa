    else
        UDPC_STATUS="${RED}рҹ”ҙ inactive${RST}"
        UDPC_USERS=0
    fi
    
    if systemctl is-active --quiet badvpn-gateway; then
        BADVPN_STATUS="${GRN}рҹҹў active${RST}"
    else
        BADVPN_STATUS="${RED}рҹ”ҙ inactive${RST}"
    fi
    
    DATE_TIME=$(TZ="Africa/Accra" date +"%A, %d %B %Y  %I:%M:%S %p %Z")
    FLAG=$(flag "$COUNTRY_CODE")
    [ -n "$FLAG" ] && LOC_STR="${FLAG}  $CITY, $COUNTRY" || LOC_STR="$CITY, $COUNTRY"
}

