    else
        ZIVPN_STATUS="${RED}рҹ”ҙ inactive${RST}"
        ZIVPN_USERS=0
    fi
    
    if systemctl is-active --quiet udp-custom; then
        UDPC_STATUS="${GRN}рҹҹў active${RST}"
