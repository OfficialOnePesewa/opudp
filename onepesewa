# [7] REMOVE USER
do_remove_user() {
    echo -e "\n  ${RED}${BOLD}в—Ҳ  Remove User${RST}\n"
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && {
        echo -e "  ${YLW}No users.${RST}"; press_enter; return
    }
    echo -ne "  ${GRN}Enter full password: ${RST}"; read -r pass
    [ -z "$pass" ] && { echo -e "  ${RED}вңҳ  Aborted.${RST}"; press_enter; return; }
    grep -q "^${pass}|" "$DB" 2>/dev/null || {
        echo -e "  ${RED}вңҳ  User not found.${RST}"; press_enter; return
    }
    local port; port=$(grep "^${pass}|" "$DB" | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    [ -f "$CONFIG" ] && \
        jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json \
        && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^${pass}|/d" "$DB"       2>/dev/null
    sed -i "/^${pass}|/d" "$USAGE_DB" 2>/dev/null
    sed -i "/^${pass}|/d" "$CONN_LIMIT_FILE" 2>/dev/null
    systemctl restart zivpn 2>/dev/null
    echo -e "\n  ${GRN}вң”  User ${YLW}${pass}${GRN} removed.${RST}"
    press_enter
}

# [8] RENEW USER
do_renew_user() {
    echo -e "\n  ${CYN}${BOLD}в—Ҳ  Renew / Extend User${RST}\n"
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && {
        echo -e "  ${YLW}No users.${RST}"; press_enter; return
    }
    echo -ne "  ${GRN}Enter full password: ${RST}"; read -r pass
    [ -z "$pass" ] && { echo -e "  ${RED}вңҳ  Aborted.${RST}"; press_enter; return; }
    local line; line=$(grep "^${pass}|" "$DB")
    [ -z "$line" ] && { echo -e "  ${RED}вңҳ  Not found.${RST}"; press_enter; return; }
    local oldexp; oldexp=$(echo "$line" | cut -d'|' -f2)
    echo -e "  ${DIM}Current expiry: ${WHT}${oldexp}${RST}"
    echo -ne "  ${GRN}Add how many days: ${RST}"; read -r days
    [[ ! "$days" =~ ^[0-9]+$ ]] && {
        echo -e "  ${RED}вңҳ  Invalid.${RST}"; press_enter; return
    }
    local newexp; newexp=$(date -d "${oldexp} +${days} days" +%Y-%m-%d 2>/dev/null)
    [ -z "$newexp" ] && { echo -e "  ${RED}вңҳ  Date error.${RST}"; press_enter; return; }
    awk -F'|' -v p="$pass" -v ne="$newexp" \
        'BEGIN{OFS="|"} $1==p{$2=ne} {print}' "$DB" > /tmp/db_tmp \
        && mv /tmp/db_tmp "$DB"
    echo -e "\n  ${GRN}вң”  Expiry: ${WHT}${oldexp}${GRN} вҶ’ ${WHT}${newexp}${RST}"
    press_enter
}

# [9] CLEANUP EXPIRED
do_cleanup() {
    echo -e "\n  ${YLW}${BOLD}в—Ҳ  Cleanup Expired Users${RST}\n"
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && {
        echo -e "  ${YLW}Nothing to clean.${RST}"; press_enter; return
    }
    local today removed=0; today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port hwid used; do
        if [[ "$expiry" < "$today" ]]; then
            echo -e "  ${DIM}  вҶ’ Removing: ${pass}  (expired: ${expiry})${RST}"
            [ -n "$port" ] && remove_tracking "$port"
            [ -f "$CONFIG" ] && \
                jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json \
                && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^${pass}|/d" "$DB"       2>/dev/null
            sed -i "/^${pass}|/d" "$USAGE_DB" 2>/dev/null
            sed -i "/^${pass}|/d" "$CONN_LIMIT_FILE" 2>/dev/null
            removed=$((removed + 1))
        fi
    done < <(cat "$DB")
    [ "$removed" -gt 0 ] && systemctl restart zivpn 2>/dev/null
    echo -e "\n  ${GRN}вң”  Done. Removed ${YLW}${removed}${GRN} expired user(s).${RST}"
    press_enter
}

# [10] CONNECTION STATS
do_conn_stats() {
    echo -e "\n  ${CYN}${BOLD}в—Ҳ  Connection Statistics${RST}\n"
    echo -e "  ${WHT}в”Җв”Җ Active UDP Connections в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RST}"
    ss -u -n state established 2>/dev/null | head -20 \
        || netstat -uan 2>/dev/null | head -20 \
        || echo "  (not available)"
    echo -e "\n  ${WHT}в”Җв”Җ ZIVPN Listeners в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RST}"
    ss -tulnp 2>/dev/null | grep -E 'zivpn|5667|7300' || echo "  None found."
    echo -e "\n  ${WHT}в”Җв”Җ Per-User Connection Count в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RST}"
    if [ -f "$DB" ] && [ -s "$DB" ]; then
        while IFS='|' read -r pass exp quota port hwid used; do
            local cnt; cnt=$(ss -u -n state established 2>/dev/null \
                             | grep -c ":${port} " || echo 0)
            printf "  Port ${GRN}%-6s${RST} в”Ӯ User ${WHT}%-28s${RST} в”Ӯ Conns: ${YLW}%s${RST}\n" \
                   "$port" "${pass:0:28}" "$cnt"
        done < "$DB"
    else
        echo "  No users."
    fi
    press_enter
}

