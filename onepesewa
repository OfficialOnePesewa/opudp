           /etc/systemd/system/opudp-bwmon.service \
           /etc/systemd/system/opudp-pausemon.service 2>/dev/null
    systemctl daemon-reload 2>/dev/null
    echo -e "\n  ${GRN}✔  Uninstalled. Goodbye! — ${ADMIN_HANDLE}${RST}\n"
    exit 0
}

