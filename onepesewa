    sed -i "s|^PORT_START=.*|PORT_START=${PORT_START}|" "$self" 2>/dev/null
    sed -i "s|^PORT_END=.*|PORT_END=${PORT_END}|"       "$self" 2>/dev/null
    echo -e "\n  ${GRN}вң”  Range set: ${WHT}${PORT_START}${GRN} вҖ“ ${WHT}${PORT_END}${RST}"
    press_enter
}

