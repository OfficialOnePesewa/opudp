# ══════════════════════════════════════════════════════════════════════════════
#  HELPER FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|$port|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port+1))
    done
    echo ""
}

quota_to_bytes() {
    local q=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    if [[ "$q" =~ ^([0-9.]+)gb$ ]]; then echo "${BASH_REMATCH[1]} * 1073741824" | bc | cut -d. -f1
    elif [[ "$q" =~ ^([0-9.]+)mb$ ]]; then echo "${BASH_REMATCH[1]} * 1048576" | bc | cut -d. -f1
    elif [[ "$q" == "0" ]] || [[ "$q" == "unlimited" ]] || [[ -z "$q" ]]; then echo "0"
    else echo "0"; fi
}

format_bytes() {
    local b=$1
    if   [ $b -ge 1073741824 ]; then echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [ $b -ge 1048576    ]; then echo "$(echo "scale=2; $b/1048576"    | bc) MB"
    elif [ $b -ge 1024       ]; then echo "$(echo "scale=2; $b/1024"       | bc) KB"
    else echo "$b B"; fi
}

setup_tracking() {
    local port=$1
    iptables -C INPUT -p udp --dport $port -j ACCEPT 2>/dev/null || iptables -I INPUT -p udp --dport $port -j ACCEPT
    iptables -t nat -C PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null || iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667
    iptables -N UDP_IN_$port  2>/dev/null || true
    iptables -N UDP_OUT_$port 2>/dev/null || true
    iptables -C INPUT  -p udp --dport $port -j UDP_IN_$port  2>/dev/null || iptables -I INPUT  -p udp --dport $port -j UDP_IN_$port
    iptables -C OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null || iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port
}

remove_tracking() {
    local port=$1
    iptables -D INPUT  -p udp --dport $port -j UDP_IN_$port  2>/dev/null || true
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null || true
    iptables -F UDP_IN_$port  2>/dev/null || true
    iptables -X UDP_IN_$port  2>/dev/null || true
    iptables -F UDP_OUT_$port 2>/dev/null || true
    iptables -X UDP_OUT_$port 2>/dev/null || true
    iptables -D INPUT  -p udp --dport $port -j ACCEPT 2>/dev/null || true
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null || true
}

validate_input() {
    local days="$1" quota="$2"
    if ! [[ "$days" =~ ^[0-9]+$ ]] || [ "$days" -lt 1 ]; then
        echo "ERROR: Validity must be a positive integer."
        return 1
    fi
    if ! [[ "$quota" =~ ^([0-9.]+[GgMm][Bb])$ ]] && [ "$quota" != "0" ] && [ "$quota" != "unlimited" ]; then
        echo "ERROR: Quota must be like 10GB, 500MB, 0, or unlimited."
        return 1
    fi
    return 0
}

add_user_core() {
    local basepass="$1" days="$2" quota="$3" hwid="$4"
    if ! validate_input "$days" "$quota"; then
        echo "$(validate_input "$days" "$quota")"
        return 1
    fi
    finalpass="${basepass}_${hwid}"
    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")
    startdate=$(date +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }
    tmp_json=$(mktemp)
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$hwid|$startdate" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null || true
    echo "SUCCESS|$finalpass|$exp|$port|$quota"
}

reset_user_quota_pause() {
    local pass="$1"
    if grep -q "^$pass|.*PAUSED" "$DB"; then
        sed -i "s|^$pass \[PAUSED\]|$pass|" "$DB"
        tmp_json=$(mktemp)
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
        systemctl restart zivpn 2>/dev/null || true
    fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  USAGE TRACKING (Background)
# ══════════════════════════════════════════════════════════════════════════════
update_usage_db() {
    local tmp_usage=$(mktemp)
    while IFS='|' read -r pass expiry quota port hwid start; do
        [ -z "$port" ] || [ "$port" = "None" ] && continue
        in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | awk '/^[ ]*[0-9]+/ {print $2}' || echo 0)
        out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | awk '/^[ ]*[0-9]+/ {print $2}' || echo 0)
        total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
        echo "$pass|$total" >> "$tmp_usage"
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ] && ! grep -q "^$pass|.*PAUSED" "$DB"; then
            sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
            tmp_json=$(mktemp)
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
            systemctl restart zivpn 2>/dev/null || true
        fi
    done < "$DB"
    mv "$tmp_usage" "$USAGE_DB"
}

start_usage_daemon() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null || true
    ( while true; do /usr/local/bin/onepesewa --update-usage; sleep 10; done ) &
    echo $! > "$DAEMON_PID_FILE"
}

