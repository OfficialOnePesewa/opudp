remove_user_interactive() {
    echo -ne "${GRN}Full password to remove: ${RST}"; read pass
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}User removed.${RST}"
    read -p "Press Enter..."
}

trial_user_interactive() {
    echo -ne "${GRN}Minutes (1-60): ${RST}"; read mins
    hwid="trial_$(openssl rand -hex 4)"
    basepass="trial"
    finalpass="${basepass}_${hwid}"
    port=$(find_free_port)
    if [ -z "$port" ]; then
        echo -e "${RED}No free port.${RST}"; read -p "Press Enter..."; return
    fi
    exp=$(date -d "+1 day" +%Y-%m-%d)
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "$finalpass|$exp|100MB|$port|$hwid" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}Trial Created: ${YLW}$finalpass${GRN} (expires in $mins mins)${RST}"
    echo -e "${DIM}Server: $IP | Password: $finalpass${RST}"
    ( sleep $((mins*60))
      remove_tracking "$port"
      jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
      sed -i "/^$finalpass|/d" "$DB" "$USAGE_DB"
      systemctl restart zivpn 2>/dev/null
    ) &
    read -p "Press Enter..."
}

