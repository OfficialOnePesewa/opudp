do_limits_status() {
    echo -e "\n  ${CYN}${BOLD}◈  Limits Status (Connection & IP)${RST}\n"
    echo "  ─── Connection (concurrent) limits ───"
    if [ -f "$CONN_LIMIT_FILE" ] && [ -s "$CONN_LIMIT_FILE" ]; then
        while IFS='|' read -r pass lim; do
            echo -e "    ${YLW}${pass:0:24}${RST} → ${lim} concurrent sessions"
        done < "$CONN_LIMIT_FILE"
    else
        echo -e "    ${DIM}No per-user connection limits set.${RST}"
    fi
    echo ""
    echo "  ─── IP (unique source) limits ───"
    if [ -f "$IP_LIMIT_FILE" ] && [ -s "$IP_LIMIT_FILE" ]; then
        while IFS='|' read -r pass lim; do
            local count=0
            [ -f "/etc/zivpn/iplist_${pass}.db" ] && count=$(wc -l < "/etc/zivpn/iplist_${pass}.db")
            echo -e "    ${YLW}${pass:0:24}${RST} → ${lim} unique IPs (currently ${count} tracked)"
        done < "$IP_LIMIT_FILE"
    else
        echo -e "    ${DIM}No per-user IP limits set.${RST}"
    fi
    echo ""
    echo "  ─── Bandwidth monitoring ───"
    bw_monitor_status
    echo ""
    press_enter
}

do_ip_limit() {
    echo -e "\n  ${CYN}${BOLD}◈  Set Unique IP Limit per User${RST}\n"
    echo -ne "  ${GRN}Enter full password: ${RST}"; read -r pass
    [ -z "$pass" ] && { echo -e "  ${RED}✘  Aborted.${RST}"; press_enter; return; }
    grep -q "^${pass}|" "$DB" 2>/dev/null || {
        echo -e "  ${RED}✘  Not found.${RST}"; press_enter; return
    }
    local current; current=$(grep "^${pass}|" "$IP_LIMIT_FILE" 2>/dev/null | cut -d'|' -f2)
    echo -e "  ${DIM}Current IP limit: ${WHT}${current:-unlimited}${RST}"
    echo -ne "  ${GRN}New limit (0=unlimited): ${RST}"; read -r lim
    [[ ! "$lim" =~ ^[0-9]+$ ]] && {
        echo -e "  ${RED}✘  Invalid.${RST}"; press_enter; return
    }
    sed -i "/^${pass}|/d" "$IP_LIMIT_FILE" 2>/dev/null
    if [ "$lim" -gt 0 ]; then
        echo "${pass}|${lim}" >> "$IP_LIMIT_FILE"
        echo -e "\n  ${GRN}✔  IP limit set to ${WHT}${lim}${GRN} for ${YLW}${pass}${RST}"
    else
        echo -e "\n  ${GRN}✔  IP limit removed (unlimited) for ${YLW}${pass}${RST}"
    fi
    echo -e "\n  ${DIM}Do you want to reset the tracked IPs for this user?${RST}"
    echo -ne "  ${GRN}Reset? (y/N): ${RST}"; read -r reset
    if [[ "$reset" =~ ^[Yy]$ ]]; then
        reset_user_ips "$pass"
        echo -e "  ${GRN}✔  IP list reset.${RST}"
    fi
    if [ ! -f "$IPMON_SERVICE_FILE" ] && [ "$lim" -gt 0 ]; then
        echo ""
        echo -e "  ${YLW}Global IP limit monitoring is currently OFF.${RST}"
        echo -ne "  ${GRN}Enable it now? (y/N): ${RST}"; read -r en
        if [[ "$en" =~ ^[Yy]$ ]]; then
            enable_ip_monitor
        fi
    fi
    press_enter
}

