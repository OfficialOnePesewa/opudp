    echo -e "  ${CYN}в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј${RST}"
    printf  "  ${CYN}в•‘${RST}  ${YLW}рҹ”‘  Password   :${RST}  ${WHT}%-42s${RST}${CYN}в•‘${RST}\n" "$p"
    printf  "  ${CYN}в•‘${RST}  ${YLW}рҹ“…  Expiry     :${RST}  ${exp_color}%-42s${RST}${CYN}в•‘${RST}\n" \
            "$expiry  ($days_left days left)"
    printf  "  ${CYN}в•‘${RST}  ${YLW}рҹ“Ҡ  Quota      :${RST}  ${WHT}%-42s${RST}${CYN}в•‘${RST}\n" "$quota"
