# ════════════════════════════════════════════════════════════════
#  TELEGRAM BOT CONFIGURATION
# ════════════════════════════════════════════════════════════════
config_telegram() {
    while true; do
        clear
        echo -e "${CYN}╭──────────────────────────────────────────────────────╮${RST}"
        echo -e "${CYN}│           🤖 TELEGRAM BOT CONFIGURATION              │${RST}"
        echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
        if systemctl is-active --quiet opudp-bot 2>/dev/null; then
            BOT_STATUS_LINE="${GRN}🟢 Running${RST}"
        else
            BOT_STATUS_LINE="${RED}🔴 Stopped${RST}"
        fi
        echo -e "  Bot Status : $BOT_STATUS_LINE\n"
        echo -e "  ${GRN}1)${RST} Set Bot Token"
        echo -e "  ${GRN}2)${RST} Start Bot"
        echo -e "  ${GRN}3)${RST} Stop Bot"
        echo -e "  ${GRN}4)${RST} Bot Status / Logs"
        echo -e "  ${GRN}5)${RST} Add Bot Admin"
        echo -e "  ${GRN}6)${RST} Remove Bot Admin"
        echo -e "  ${GRN}7)${RST} List Bot Admins"
        echo -e "  ${RED}0)${RST} Back\n"
        echo -ne "${CYN}Choose: ${RST}"; read -r opt_bot
        case $opt_bot in
            1)
                echo -ne "${GRN}Enter Bot Token (from @BotFather): ${RST}"; read -r token
                [ -z "$token" ] && { echo -e "${RED}Cancelled.${RST}"; read -rp "Press Enter..."; continue; }
                echo "$token" > "$TELEGRAM_TOKEN_FILE"
                chmod 600 "$TELEGRAM_TOKEN_FILE"
                echo -e "${GRN}✅ Token saved.${RST}"
                read -rp "Press Enter..."
                ;;
            2)
                if [ ! -f "$TELEGRAM_TOKEN_FILE" ]; then
                    echo -e "${RED}❌ Token not set. Use option 1 first.${RST}"
                    read -rp "Press Enter..."; continue
                fi
                # Install python-telegram-bot if missing
                if ! python3 -c "import telegram" 2>/dev/null; then
                    echo -e "${YLW}Installing python-telegram-bot...${RST}"
                    pip3 install "python-telegram-bot>=20.0" --break-system-packages -q
                fi
                # Download bot script if not present / always refresh
                echo -e "${YLW}Downloading latest bot script...${RST}"
                wget -qO "$BOT_SCRIPT" \
                    "https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/opudp_bot.py" \
                    && chmod +x "$BOT_SCRIPT" \
                    || { echo -e "${RED}❌ Failed to download bot script.${RST}"; read -rp "Press Enter..."; continue; }
                # Write systemd service
                cat > "$BOT_SERVICE_FILE" <<EOF
[Unit]
Description=OP UDP Panel Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/bin/python3 $BOT_SCRIPT
Restart=always
RestartSec=5
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF
                systemctl daemon-reload
                systemctl enable opudp-bot
                systemctl restart opudp-bot
                sleep 2
                if systemctl is-active --quiet opudp-bot; then
                    echo -e "${GRN}✅ Bot started successfully.${RST}"
                else
                    echo -e "${RED}❌ Bot failed to start. Check: journalctl -u opudp-bot -n 20${RST}"
                fi
                read -rp "Press Enter..."
                ;;
            3)
                systemctl stop opudp-bot 2>/dev/null
                systemctl disable opudp-bot 2>/dev/null
                echo -e "${RED}🔴 Bot stopped.${RST}"
                read -rp "Press Enter..."
                ;;
            4)
                echo -e "\n${CYN}── Bot Status ─────────────────────────────${RST}"
                systemctl status opudp-bot --no-pager -l 2>/dev/null \
                    || echo -e "${YLW}Bot service not installed yet.${RST}"
                echo -e "\n${CYN}── Recent Logs ────────────────────────────${RST}"
                journalctl -u opudp-bot -n 30 --no-pager 2>/dev/null \
                    || echo -e "${YLW}No logs available.${RST}"
                read -rp "Press Enter..."
                ;;
            5)
                echo -ne "${GRN}Telegram Chat ID to add as admin: ${RST}"; read -r chatid
                if ! [[ "$chatid" =~ ^-?[0-9]+$ ]]; then
                    echo -e "${RED}❌ Invalid Chat ID (must be numeric).${RST}"
                else
                    # Avoid duplicates
                    if grep -qx "$chatid" "$BOT_ADMINS_FILE" 2>/dev/null; then
                        echo -e "${YLW}⚠️  Already an admin.${RST}"
                    else
                        echo "$chatid" >> "$BOT_ADMINS_FILE"
                        echo -e "${GRN}✅ Admin added: $chatid${RST}"
                    fi
                fi
                read -rp "Press Enter..."
                ;;
            6)
                echo -ne "${GRN}Chat ID to remove: ${RST}"; read -r chatid
                if [ -f "$BOT_ADMINS_FILE" ]; then
                    grep -v "^${chatid}$" "$BOT_ADMINS_FILE" > /tmp/adm_tmp \
                        && mv /tmp/adm_tmp "$BOT_ADMINS_FILE"
                    echo -e "${GRN}✅ Removed (if it existed).${RST}"
                else
                    echo -e "${YLW}No admins file found.${RST}"
                fi
                read -rp "Press Enter..."
                ;;
            7)
                echo -e "\n${CYN}── Bot Admins ──────────────────────────────${RST}"
                if [ -s "$BOT_ADMINS_FILE" ]; then
                    cat "$BOT_ADMINS_FILE"
                else
                    echo -e "${YLW}No admins configured.${RST}"
                fi
                read -rp "Press Enter..."
                ;;
            0) return ;;
            *) echo -e "${RED}Invalid option.${RST}"; sleep 1 ;;
        esac
    done
}

