# ------------------ Telegram Bot Config Function ------------------
config_telegram() {
    clear
    echo -e "${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│           🤖 TELEGRAM BOT CONFIGURATION              │${RST}"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
    echo -e "${GRN}1) Set Bot Token${RST}"
    echo -e "${GRN}2) Start Bot${RST}"
    echo -e "${GRN}3) Stop Bot${RST}"
    echo -e "${GRN}4) Bot Status${RST}"
    echo -e "${GRN}5) Add Bot Admin (Sub-admin)${RST}"
    echo -e "${GRN}6) Remove Bot Admin${RST}"
    echo -e "${GRN}7) List Bot Admins${RST}"
    echo -e "${RED}0) Back${RST}"
    echo -ne "${CYN}Choose: ${RST}"
    read opt_bot
    case $opt_bot in
        1)
            echo -ne "${GRN}Enter Bot Token (from @BotFather): ${RST}"
            read token
            echo "$token" > "$TELEGRAM_TOKEN_FILE"
            echo -e "${GRN}Token saved.${RST}"
            read -p "Press Enter..."
            ;;
        2)
            if [ ! -f "$TELEGRAM_TOKEN_FILE" ]; then
                echo -e "${RED}Token not set. First set token.${RST}"
                read -p "Press Enter..."
                return
            fi
            # Download bot script if not exists
            if [ ! -f "$BOT_SCRIPT" ]; then
                wget -qO "$BOT_SCRIPT" "https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/opudp_bot.py"
                chmod +x "$BOT_SCRIPT"
            fi
            # Create systemd service
            cat <<EOF > "$BOT_SERVICE_FILE"
[Unit]
Description=OP UDP Panel Telegram Bot
After=network.target

[Service]
ExecStart=/usr/bin/python3 $BOT_SCRIPT
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
EOF
            systemctl daemon-reload
            systemctl enable opudp-bot
            systemctl start opudp-bot
            echo -e "${GRN}Bot started.${RST}"
            read -p "Press Enter..."
            ;;
        3)
            systemctl stop opudp-bot
            systemctl disable opudp-bot
            echo -e "${RED}Bot stopped.${RST}"
            read -p "Press Enter..."
            ;;
        4)
            if systemctl is-active --quiet opudp-bot; then
                echo -e "${GRN}Bot is running.${RST}"
            else
                echo -e "${RED}Bot is not running.${RST}"
            fi
            read -p "Press Enter..."
            ;;
        5)
            echo -ne "${GRN}Enter Telegram Chat ID to add as admin: ${RST}"
            read chatid
            echo "$chatid" >> "$BOT_ADMINS_FILE"
            echo -e "${GRN}Admin added.${RST}"
            read -p "Press Enter..."
            ;;
        6)
            echo -ne "${GRN}Enter Chat ID to remove: ${RST}"
            read chatid
            sed -i "/^$chatid$/d" "$BOT_ADMINS_FILE" 2>/dev/null
            echo -e "${GRN}Removed.${RST}"
            read -p "Press Enter..."
            ;;
        7)
            if [ -f "$BOT_ADMINS_FILE" ]; then
                echo -e "${CYN}Bot Admins:${RST}"
                cat "$BOT_ADMINS_FILE"
            else
                echo -e "${YLW}No admins configured.${RST}"
            fi
            read -p "Press Enter..."
            ;;
        0) return ;;
        *) echo -e "${RED}Invalid.${RST}"; read -p "Press Enter..." ;;
    esac
    config_telegram
}

