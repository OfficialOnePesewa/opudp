                }
                cat > "$BOT_SERVICE_FILE" <<EOF
[Unit]
Description=OP UDP Panel Telegram Bot
After=network.target
[Service]
ExecStart=/usr/bin/python3 $BOT_SCRIPT
Restart=always
RestartSec=5
User=root
[Install]
WantedBy=multi-user.target
EOF
                systemctl daemon-reload
