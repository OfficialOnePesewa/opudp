#!/bin/bash
# OFFICIAL ONEPESEWA UDP Dashboard – Modern Edition

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"

# Colors
BLK='\e[1;30m' RED='\e[1;31m' GRN='\e[1;32m' YLW='\e[1;33m' BLU='\e[1;34m' MAG='\e[1;35m' CYN='\e[1;36m' WHT='\e[1;37m' RST='\e[0m'

# Dependencies
command -v jq &>/dev/null || apt-get install -y jq -qq &>/dev/null
command -v bc &>/dev/null || apt-get install -y bc -qq &>/dev/null

# Fetch Geo data
GEO=$(curl -4 -s --max-time 8 https://ipapi.co/json/ 2>/dev/null)
if [ -z "$GEO" ] || ! echo "$GEO" | grep -q '"ip"'; then
    IP="N/A"; CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"; ZIP=""
else
    IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+')
    CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+')
    COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
    COUNTRY_CODE=$(echo "$GEO" | grep -oP '"country_code":\s*"\K[^"]+' | tr '[:upper:]' '[:lower:]')
    ZIP=$(echo "$GEO" | grep -oP '"postal":\s*"\K[^"]+')
    ISP=$(echo "$GEO" | grep -oP '"org":\s*"\K[^"]+')
    [ -z "$IP" ] && IP="N/A"
    [ -z "$CITY" ] && CITY="Unknown"
    [ -z "$COUNTRY" ] && COUNTRY="Unknown"
    [ -z "$ISP" ] && ISP="Unknown"
fi

# Flag emoji
flag_emoji() {
    case $1 in
        us) echo "🇺🇸" ;; gb) echo "🇬🇧" ;; ca) echo "🇨🇦" ;; au) echo "🇦🇺" ;;
        de) echo "🇩🇪" ;; fr) echo "🇫🇷" ;; nl) echo "🇳🇱" ;; in) echo "🇮🇳" ;;
        jp) echo "🇯🇵" ;; br) echo "🇧🇷" ;; za) echo "🇿🇦" ;; sg) echo "🇸🇬" ;;
        gh) echo "🇬🇭" ;; ng) echo "🇳🇬" ;; ke) echo "🇰🇪" ;; *) echo "" ;;
    esac
}
FLAG=$(flag_emoji "$COUNTRY_CODE")

# OS & Uptime
OS_INFO=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
UPTIME=$(uptime -p | sed 's/up //' | sed 's/ days/d/' | sed 's/ day/d/' | sed 's/ hours/h/' | sed 's/ hour/h/' | sed 's/ minutes/m/' | sed 's/ minute/m/')
[ -z "$UPTIME" ] && UPTIME="N/A"

# Service status & user count
if systemctl is-active --quiet zivpn; then
    STATUS="${GRN}🟢  active${RST}"
else
    STATUS="${RED}🔴  inactive${RST}"
fi
USER_COUNT=$(jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0")

# Current time
DATE_TIME=$(date +"%a %d %b %Y   %H:%M:%S")

# --- Banner (exact format requested) ---
banner() {
    clear
    echo -e "${WHT}🕐  ${DATE_TIME}${RST}"
    echo ""
    echo -e "${WHT}━━━━━ 🖥  Server Info ━━━━━${RST}"
    echo -e "${WHT}🌐  IP       :  ${CYN}$IP${RST}"
    [ -n "$FLAG" ] && LOC_STR="${FLAG}  $CITY, $COUNTRY" || LOC_STR="$CITY, $COUNTRY"
    echo -e "${WHT}📍  Location :  ${YLW}$LOC_STR${RST}"
    [ -n "$ZIP" ] && echo -e "${WHT}📮  ZIP      :  ${MAG}$ZIP${RST}"
    echo -e "${WHT}🏢  ISP      :  ${BLU}$ISP${RST}"
    echo -e "${WHT}🎯  UDP Ports:  ${GRN}6000:19999${RST}"
    echo ""
    echo -e "${WHT}━━━━━ ⚡ Service ━━━━━${RST}"
    echo -e "${WHT}🟢  ZIVPN    :  $STATUS"
    echo -e "${WHT}⏱  Uptime  :  ${YLW}$UPTIME${RST}"
    echo -e "${WHT}👥  Users   :  ${GRN}$USER_COUNT active${RST}"
    echo -e "${WHT}━━━━━━━━━━━━━━━━━━━━━━━${RST}"
    echo ""
}

# --- Add User (with card containing server info) ---
add_user() {
    echo -e "\n${YLW}═══════════ CREATE NEW USER ═══════════${RST}"
    echo -ne "${GRN}User Password: ${RST}"; read pass
    echo -ne "${GRN}Validity (Days): ${RST}"; read days
    echo -ne "${GRN}Quota (GB/MB): ${RST}"; read quota
    echo -ne "${GRN}Device ID (Optional): ${RST}"; read devid

    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")

    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi
    echo "$pass|$exp|$quota|${devid:-None}" >> "$DB"
    systemctl restart zivpn 2>/dev/null

    echo -e "\n${CYN}╔══════════════════════════════════════════════╗${RST}"
    echo -e "${CYN}║  ${GRN}🎉 NEW USER CREATED SUCCESSFULLY 🎉${CYN}         ║${RST}"
    echo -e "${CYN}╠══════════════════════════════════════════════╣${RST}"
    echo -e "${CYN}║${RST} ${YLW}👤 Password   :${RST} ${WHT}$pass${RST}"
    echo -e "${CYN}║${RST} ${YLW}⏳ Expiry     :${RST} ${WHT}$exp ($days Days)${RST}"
    echo -e "${CYN}║${RST} ${YLW}📊 Quota      :${RST} ${WHT}$quota${RST}"
    echo -e "${CYN}║${RST} ${YLW}📱 Device ID  :${RST} ${WHT}${devid:-None}${RST}"
    echo -e "${CYN}╠══════════════════════════════════════════════╣${RST}"
    echo -e "${CYN}║${RST} ${MAG}🌍 Server IP  :${RST} ${WHT}$IP${RST}"
    echo -e "${CYN}║${RST} ${MAG}📍 Location   :${RST} ${WHT}$CITY, $COUNTRY${RST}"
    echo -e "${CYN}║${RST} ${MAG}🏢 ISP        :${RST} ${WHT}$ISP${RST}"
    echo -e "${CYN}╚══════════════════════════════════════════════╝${RST}"
    echo ""
    read -p "Press Enter to continue..."
}

# Trial user
trial_user() {
    echo -ne "${GRN}Minutes (1-60): ${RST}"; read mins
    pass="trial_$(openssl rand -hex 2)"
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi
    echo -e "${GRN}Trial Created: ${YLW}$pass${GRN} (Expires in $mins mins)${RST}"
    ( sleep $((mins*60))
      if [ -f "$CONFIG" ]; then
          jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
          systemctl restart zivpn 2>/dev/null
      fi
    ) &
    read -p "Press Enter to continue..."
}

# Goodbye
goodbye() {
    clear
    echo -e "\n${CYN}╔══════════════════════════════════════════════╗${RST}"
    echo -e "${CYN}║                                              ║${RST}"
    echo -e "${CYN}║      ${GRN}Thank you for using${RST}${CYN}                    ║${RST}"
    echo -e "${CYN}║      ${YLW}OFFICIAL ONEPESEWA UDP${RST}${CYN}                 ║${RST}"
    echo -e "${CYN}║      ${MAG}See you again soon! 👋${RST}${CYN}                 ║${RST}"
    echo -e "${CYN}║                                              ║${RST}"
    echo -e "${CYN}╚══════════════════════════════════════════════╝${RST}"
    echo -e "\n${WHT}Admin   : ${CYN}@OfficialOnePesewa${RST}"
    echo -e "${WHT}Channel : ${CYN}https://t.me/OfficialOnePesewa${RST}\n"
}

# Menu
show_menu() {
    echo -e "${WHT}┌─────────────────────────────────────────────────────────────┐${RST}"
    echo -e "${WHT}│  ${GRN}1)${RST} Start   ${GRN}6)${RST} Add User     ${GRN}11)${RST} BW+Expiry  ${GRN}16)${RST} Restore      ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN}2)${RST} Stop    ${GRN}7)${RST} Remove User  ${GRN}12)${RST} Reset BW   ${GRN}17)${RST} Port Range   ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN}3)${RST} Restart ${GRN}8)${RST} Renew/Extend ${GRN}13)${RST} Speed Test ${GRN}18)${RST} ${YLW}Update Panel${RST} ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN}4)${RST} Status  ${GRN}9)${RST} Cleanup      ${GRN}14)${RST} Live Logs  ${GRN}19)${RST} Conn Limit   ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN}5)${RST} List    ${GRN}10)${RST} Conn Stats   ${GRN}15)${RST} Backup     ${GRN}20)${RST} Trial User   ${WHT}│${RST}"
    echo -e "${WHT}├─────────────────────────────────────────────────────────────┤${RST}"
    echo -e "${WHT}│  ${RED}99) UNINSTALL${RST}                                      ${GRN}0) Exit${RST}  ${WHT}│${RST}"
    echo -e "${WHT}└─────────────────────────────────────────────────────────────┘${RST}"
}

# Main loop
while true; do
    banner
    show_menu
    echo -ne "${CYN}Choose [0-99]: ${RST}"; read opt
    case $opt in
        1) systemctl start zivpn && echo -e "${GRN}Started.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        2) systemctl stop zivpn && echo -e "${RED}Stopped.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        3) systemctl restart zivpn && echo -e "${GRN}Restarted.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        4) systemctl status zivpn ;;
        5) [ -f "$DB" ] && { echo -e "\n${CYN}Pass | Expiry | Quota | DeviceID${RST}"; column -t -s "|" "$DB"; } || echo -e "${RED}No users.${RST}"; read -p "Press Enter..." ;;
        6) add_user ;;
        7) echo -ne "${GRN}Password to remove: ${RST}"; read pass
           [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
           [ -f "$DB" ] && sed -i "/^$pass|/d" "$DB"
           systemctl restart zivpn 2>/dev/null
           echo -e "${GRN}User removed.${RST}"; read -p "Press Enter..." ;;
        8|9|10|11|12|13|15|16|17|19) echo "Coming soon."; read -p "Press Enter..." ;;
        14) journalctl -u zivpn -f ;;
        18) echo -e "\n${YLW}Updating panel...${RST}"
             wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa
             chmod +x /usr/local/bin/onepesewa
             echo -e "${GRN}Update complete! Restarting...${RST}"; sleep 2; exec onepesewa ;;
        20) trial_user ;;
        99) systemctl stop zivpn 2>/dev/null; rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa; echo -e "${RED}Uninstalled.${RST}"; exit ;;
        0) goodbye; exit ;;
        *) echo -e "${RED}Invalid.${RST}"; read -p "Press Enter..." ;;
    esac
done
