if [[ "${1-}" == "--bot-"* ]]; then
    cmd="${1#--bot-}"; shift
    case "$cmd" in
        status)            fetch_geo; get_sysinfo; echo "🖥 <b>Server Status</b>%0A🌐 IP: $IP%0A📍 Location: $LOC_STR%0A🏢 ISP: $ISP%0A💻 OS: $OS_INFO%0A⚡ Service: $(systemctl is-active zivpn)%0A⏱ Uptime: $UPTIME%0A🚀 BBR: $(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo unknown)%0A👥 Users: $USER_COUNT" ;;
        adduser)           result=$(add_user_core "$1" "$2" "$3" "$4"); echo "$result" ;;
        removeuser)        pass="$1"; port=$(grep "^$pass|" "$DB" | cut -d'|' -f4); [ -n "$port" ] && remove_tracking "$port"; jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; sed -i "/^$pass|/d" "$DB" "$USAGE_DB"; systemctl restart zivpn 2>/dev/null || true; echo "✅ User removed." ;;
        renew)             pass="$1"; days="$2"; oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2); newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d); awk -F'|' -v OFS='|' -v p="$pass" -v newexp="$newexp" '$1==p{$2=newexp}1' "$DB" > /tmp/db.tmp && mv /tmp/db.tmp "$DB"; echo "✅ Expiry extended to $newexp" ;;
        resetbw)           pass="$1"; port=$(grep "^$pass|" "$DB" | cut -d'|' -f4); [ -n "$port" ] && { iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null; }; sed -i "/^$pass|/c\\$pass|0" "$USAGE_DB"; reset_user_quota_pause "$pass"; echo "✅ Bandwidth reset." ;;
        userinfo)          pass="$1"; user_data=$(grep "^$pass|" "$DB"); IFS='|' read -r p expiry quota port hwid start <<< "$user_data"; used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}; quota_bytes=$(quota_to_bytes "$quota"); remain=$((quota_bytes - used)); days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 )); echo "🔍 <b>${p}</b>%0A📅 Expiry: $expiry ($days_left days)%0A📊 Quota: $quota%0A📈 Used: $(format_bytes $used)%0A📉 Remain: $(format_bytes $remain)%0A🔒 HWID: $hwid%0A🔌 Port: $port" ;;
        userstatus)        pass="$1"; user_data=$(grep "^$pass|" "$DB"); [ -z "$user_data" ] && { echo "❌ Password not found."; exit 1; }; IFS='|' read -r p expiry quota port hwid start <<< "$user_data"; used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}; quota_bytes=$(quota_to_bytes "$quota"); remain=$((quota_bytes - used)); [ $remain -lt 0 ] && remain=0; days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 )); sessions=$(ss -un state established 2>/dev/null | grep -c ":$port " || echo 0); echo "🔑 *Password:* $p"; echo "📅 *Expiry:* $expiry ($days_left days left)"; echo "📊 *Quota:* $quota"; echo "📈 *Used:* $(format_bytes $used)"; echo "📉 *Remaining:* $(format_bytes $remain)"; echo "🔒 *HWID:* $hwid"; echo "👥 *Active sessions:* $sessions" ;;
        list)              column -t -s "|" "$DB" | awk -F'|' '{print $1" | "$2" | "$3" | "$5}' ;;
        cleanup)           today=$(date +%Y-%m-%d); while IFS='|' read -r pass expiry quota port hwid start; do [[ "$expiry" < "$today" ]] && { [ -n "$port" ] && remove_tracking "$port"; jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; sed -i "/^$pass|/d" "$DB" "$USAGE_DB"; }; done < "$DB"; systemctl restart zivpn 2>/dev/null || true; echo "✅ Cleanup done." ;;
        trial)             mins="$1"; hwid="trial_$(openssl rand -hex 4)"; finalpass="trial_${hwid}"; port=$(find_free_port); exp=$(date -d "+1 day" +%Y-%m-%d); jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; echo "$finalpass|$exp|100MB|$port|$hwid|$(date +%Y-%m-%d)" >> "$DB"; echo "$finalpass|0" >> "$USAGE_DB"; setup_tracking "$port"; systemctl restart zivpn 2>/dev/null || true; echo "Trial created: $finalpass (expires in $mins minutes)"; ( sleep $((mins*60)); remove_tracking "$port"; jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; sed -i "/^$finalpass|/d" "$DB" "$USAGE_DB"; systemctl restart zivpn 2>/dev/null ) & ;;
        bbr)               bash <(curl -s https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/optimizer.sh --ipv4) ;;
        badvpn)            wget -N https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/Install/udpgw.sh && bash udpgw.sh ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi

