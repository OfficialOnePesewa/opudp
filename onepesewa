# We also need add_user_core that accepts hwid (as we already modified earlier)
add_user_core() {
    local basepass="$1" days="$2" quota="$3" hwid="$4"
    finalpass="${basepass}_${hwid}"
    exp=$(date -d "+$days days" +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$hwid" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|$finalpass|$exp|$port|$quota"
}

