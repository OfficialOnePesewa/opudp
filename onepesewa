# ════════════════════════════════════════════════════════════════
#  CORE HELPERS
# ════════════════════════════════════════════════════════════════
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|${port}|" "$DB" 2>/dev/null || { echo "$port"; return 0; }
        port=$((port+1))
    done
    echo ""
}

setup_tracking() {
    local port=$1
    iptables -I INPUT -p udp --dport "$port" -j ACCEPT 2>/dev/null
    iptables -t nat -A PREROUTING -p udp --dport "$port" \
        -j DNAT --to-destination :5667 2>/dev/null
    iptables -N "UDP_IN_${port}"  2>/dev/null
    iptables -N "UDP_OUT_${port}" 2>/dev/null
    iptables -I INPUT  -p udp --dport "$port" -j "UDP_IN_${port}"  2>/dev/null
    iptables -I OUTPUT -p udp --sport "$port" -j "UDP_OUT_${port}" 2>/dev/null
}

remove_tracking() {
    local port=$1
    iptables -D INPUT  -p udp --dport "$port" -j "UDP_IN_${port}"  2>/dev/null
    iptables -D OUTPUT -p udp --sport "$port" -j "UDP_OUT_${port}" 2>/dev/null
    iptables -F "UDP_IN_${port}"  2>/dev/null
    iptables -X "UDP_IN_${port}"  2>/dev/null
    iptables -F "UDP_OUT_${port}" 2>/dev/null
    iptables -X "UDP_OUT_${port}" 2>/dev/null
    iptables -D INPUT -p udp --dport "$port" -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport "$port" \
        -j DNAT --to-destination :5667 2>/dev/null
}

# Safe sed escape helper
esc() { printf '%s\n' "$1" | sed 's/[[\.*^$()+?{|]/\\&/g'; }

# ════════════════════════════════════════════════════════════════
#  USER MANAGEMENT – CORE
# ════════════════════════════════════════════════════════════════
add_user_core() {
    local basepass="$1" days="$2" quota="$3" hwid="$4"
    local finalpass exp port
    finalpass="${basepass}_${hwid}"
    exp=$(date -d "+${days} days" +%Y-%m-%d 2>/dev/null)
    if [ -z "$exp" ]; then echo "ERROR: Invalid days value"; return 1; fi
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports available"; return 1; }

    # Add to config
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" \
        > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"

    # Append to DB
    echo "${finalpass}|${exp}|${quota}|${port}|${hwid}" >> "$DB"
    echo "${finalpass}|0" >> "$USAGE_DB"

    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|${finalpass}|${exp}|${port}|${quota}"
}

remove_user_core() {
    local pass="$1"
    local port
    port=$(grep "^$(esc "$pass")|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
        > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    # Use temp file to avoid sed issues with special chars in password
    grep -v "^$(esc "$pass")|" "$DB"       > /tmp/db_tmp && mv /tmp/db_tmp "$DB"
    grep -v "^$(esc "$pass")|" "$USAGE_DB" > /tmp/ub_tmp && mv /tmp/ub_tmp "$USAGE_DB"
    systemctl restart zivpn 2>/dev/null
}

renew_user_core() {
    local pass="$1" days="$2"
    local oldexp newexp ep
    oldexp=$(grep "^$(esc "$pass")|" "$DB" | cut -d'|' -f2)
    if [ -z "$oldexp" ]; then echo "ERROR: User not found"; return 1; fi
    # If already expired, renew from today
    today=$(date +%Y-%m-%d)
    if [[ "$oldexp" < "$today" ]]; then
        ep="$today"
    else
        ep="$oldexp"
    fi
    newexp=$(date -d "${ep} +${days} days" +%Y-%m-%d 2>/dev/null)
    [ -z "$newexp" ] && { echo "ERROR: Invalid days"; return 1; }
    # Replace expiry field safely
    awk -F'|' -v pass="$pass" -v newexp="$newexp" 'OFS="|" {
        if ($1 == pass) $2 = newexp; print
    }' "$DB" > /tmp/db_tmp && mv /tmp/db_tmp "$DB"
    echo "SUCCESS|$newexp"
}

resetbw_core() {
    local pass="$1"
    local port
    port=$(grep "^$(esc "$pass")|" "$DB" | cut -d'|' -f4)
    [ -n "$port" ] && {
        iptables -Z "UDP_IN_${port}"  2>/dev/null
        iptables -Z "UDP_OUT_${port}" 2>/dev/null
    }
    awk -F'|' -v pass="$pass" 'OFS="|" {
        if ($1 == pass) $2 = 0; print
    }' "$USAGE_DB" > /tmp/ub_tmp && mv /tmp/ub_tmp "$USAGE_DB"
    echo "SUCCESS"
}

get_user_info() {
    local pass="$1"
    local user_data used quota_bytes remain days_left
    user_data=$(grep "^$(esc "$pass")|" "$DB")
    [ -z "$user_data" ] && { echo "ERROR: User not found"; return 1; }
    IFS='|' read -r p expiry quota port hwid <<< "$user_data"
    used=$(grep "^$(esc "$pass")|" "$USAGE_DB" | cut -d'|' -f2)
    used=${used:-0}
    quota_bytes=0
    if echo "$quota" | grep -qi "GB"; then
        num=$(echo "$quota" | grep -oP '[0-9.]+')
        quota_bytes=$(echo "$num * 1073741824" | bc | cut -d'.' -f1)
    elif echo "$quota" | grep -qi "MB"; then
        num=$(echo "$quota" | grep -oP '[0-9.]+')
        quota_bytes=$(echo "$num * 1048576" | bc | cut -d'.' -f1)
    fi
    remain=$((quota_bytes - used))
    [ $remain -lt 0 ] && remain=0
    days_left=$(( ( $(date -d "$expiry" +%s 2>/dev/null || echo 0) - $(date +%s) ) / 86400 ))
    used_hr=$(numfmt --to=iec "$used" 2>/dev/null || echo "${used}B")
    remain_hr=$(numfmt --to=iec "$remain" 2>/dev/null || echo "${remain}B")
    echo "FOUND|${pass}|${expiry}|${days_left}|${quota}|${used_hr}|${remain_hr}|${hwid}|${port}"
}

