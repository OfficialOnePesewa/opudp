# ══════════════════════════════════════════════════════════════════════════════
#  HELPER FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|$port|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port+1))
    done
    echo ""
}

quota_to_bytes() {
    local q=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    if [[ "$q" =~ ^([0-9.]+)gb$ ]]; then echo "${BASH_REMATCH[1]} * 1073741824" | bc | cut -d. -f1
    elif [[ "$q" =~ ^([0-9.]+)mb$ ]]; then echo "${BASH_REMATCH[1]} * 1048576" | bc | cut -d. -f1
    elif [[ "$q" == "0" ]] || [[ "$q" == "unlimited" ]] || [[ -z "$q" ]]; then echo "0"
    else echo "0"; fi
}

format_bytes() {
    local b=$1
    if   [ $b -ge 1073741824 ]; then echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [ $b -ge 1048576    ]; then echo "$(echo "scale=2; $b/1048576"    | bc) MB"
    elif [ $b -ge 1024       ]; then echo "$(echo "scale=2; $b/1024"       | bc) KB"
    else echo "$b B"; fi
}

setup_tracking() {
    local port=$1
    iptables -C INPUT -p udp --dport $port -j ACCEPT 2>/dev/null || iptables -I INPUT -p udp --dport $port -j ACCEPT
    iptables -t nat -C PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null || iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667
    iptables -N UDP_IN_$port  2>/dev/null || true
    iptables -N UDP_OUT_$port 2>/dev/null || true
    iptables -C INPUT  -p udp --dport $port -j UDP_IN_$port  2>/dev/null || iptables -I INPUT  -p udp --dport $port -j UDP_IN_$port
    iptables -C OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null || iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port
}

remove_tracking() {
    local port=$1
    iptables -D INPUT  -p udp --dport $port -j UDP_IN_$port  2>/dev/null || true
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null || true
    iptables -F UDP_IN_$port  2>/dev/null || true
    iptables -X UDP_IN_$port  2>/dev/null || true
    iptables -F UDP_OUT_$port 2>/dev/null || true
    iptables -X UDP_OUT_$port 2>/dev/null || true
    iptables -D INPUT  -p udp --dport $port -j ACCEPT 2>/dev/null || true
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null || true
}

validate_input() {
    local days="$1" quota="$2"
    if ! [[ "$days" =~ ^[0-9]+$ ]] || [ "$days" -lt 1 ]; then
        echo "ERROR: Validity must be a positive integer."
        return 1
    fi
    if ! [[ "$quota" =~ ^([0-9.]+[GgMm][Bb])$ ]] && [ "$quota" != "0" ] && [ "$quota" != "unlimited" ]; then
        echo "ERROR: Quota must be like 10GB, 500MB, 0, or unlimited."
        return 1
    fi
    return 0
}

add_user_core() {
    local basepass="$1" days="$2" quota="$3" hwid="$4"
    if ! validate_input "$days" "$quota"; then
        echo "$(validate_input "$days" "$quota")"
        return 1
    fi
    finalpass="${basepass}_${hwid}"
    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")
    startdate=$(date +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }

    tmp_json=$(mktemp)
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$hwid|$startdate" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null || true
    echo "SUCCESS|$finalpass|$exp|$port|$quota"
}

reset_user_quota_pause() {
    local pass="$1"
    if grep -q "^$pass|.*PAUSED" "$DB"; then
        sed -i "s|^$pass \[PAUSED\]|$pass|" "$DB"
        tmp_json=$(mktemp)
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
        systemctl restart zivpn 2>/dev/null || true
    fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  USAGE TRACKING
# ══════════════════════════════════════════════════════════════════════════════
update_usage_db() {
    local tmp_usage=$(mktemp)
    while IFS='|' read -r pass expiry quota port hwid start; do
        [ -z "$port" ] || [ "$port" = "None" ] && continue
        in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | awk '/^[ ]*[0-9]+/ {print $2}' || echo 0)
        out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | awk '/^[ ]*[0-9]+/ {print $2}' || echo 0)
        total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
        echo "$pass|$total" >> "$tmp_usage"
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ] && ! grep -q "^$pass|.*PAUSED" "$DB"; then
            sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
            tmp_json=$(mktemp)
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
            systemctl restart zivpn 2>/dev/null || true
        fi
    done < "$DB"
    mv "$tmp_usage" "$USAGE_DB"
}

start_usage_daemon() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null || true
    ( while true; do /usr/local/bin/onepesewa --update-usage; sleep 10; done ) &
    echo $! > "$DAEMON_PID_FILE"
}

# ══════════════════════════════════════════════════════════════════════════════
#  BANDWIDTH DETAILS VIEW (new style)
# ══════════════════════════════════════════════════════════════════════════════
show_bandwidth_details() {   # pass password as $1
    local pass="$1"
    local user_data=$(grep "^$pass|" "$DB")
    if [ -z "$user_data" ]; then
        echo -e "${RED}Password not found.${RST}"
        return 1
    fi

    IFS='|' read -r p expiry quota port hwid start <<< "$user_data"
    local used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2)
    used=${used:-0}

    local quota_bytes=$(quota_to_bytes "$quota")
    local limit_str="$quota"

    # Format used and remaining with 3 decimal places in GB
    local used_gb=$(echo "scale=3; $used / 1073741824" | bc)
    local used_mb=$(echo "scale=2; $used / 1048576" | bc)
    local remain_gb=0
    local usage_percent=0
    local bar="[          ]"   # 10 spaces for empty bar

    if [ "$quota_bytes" -gt 0 ]; then
        local remain_bytes=$(( quota_bytes - used ))
        [ $remain_bytes -lt 0 ] && remain_bytes=0
        remain_gb=$(echo "scale=3; $remain_bytes / 1073741824" | bc)
        # Calculate percentage with one decimal
        usage_percent=$(echo "scale=1; ($used * 100) / $quota_bytes" | bc)
        # Build progress bar (10 blocks)
        local filled=$(echo "scale=0; ($used * 10) / $quota_bytes" | bc)
        [ $filled -gt 10 ] && filled=10
        local empty=$(( 10 - filled ))
        bar="["
        for ((i=0; i<filled; i++)); do bar+="█"; done
        for ((i=0; i<empty; i++)); do bar+=" "; done
        bar+="]"
    else
        limit_str="Unlimited"
        remain_gb="Unlimited"
        usage_percent="N/A"
        bar="[██████████] Unlimited"
    fi

    # Display
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│  ${WHT}Bandwidth Details: ${BOLD}$p${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST}  ${YLW}Data Used:${RST}      ${used_gb} GB (${used_mb} MB)"
    echo -e "${CYN}│${RST}  ${YLW}Bandwidth Limit:${RST} ${limit_str}"
    echo -e "${CYN}│${RST}  ${YLW}Remaining:${RST}      ${remain_gb} GB"
    if [ "$quota_bytes" -gt 0 ]; then
        echo -e "${CYN}│${RST}  ${YLW}Usage:${RST}          ${usage_percent}%"
        echo -e "${CYN}│${RST}  ${YLW}Progress:${RST}       ${bar}  ${usage_percent}%"
    else
        echo -e "${CYN}│${RST}  ${YLW}Usage:${RST}          Unlimited"
        echo -e "${CYN}│${RST}  ${YLW}Progress:${RST}       ${bar}"
    fi
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}"
    echo ""
    return 0
}

# Wrapper for interactive use (option 24)
show_user_status() {
    echo -ne "${GRN}Enter full password: ${RST}"
    read pass
    show_bandwidth_details "$pass"
    read -p "Press Enter to return..."
}

# ══════════════════════════════════════════════════════════════════════════════
#  OTHER MENU ACTIONS
# ══════════════════════════════════════════════════════════════════════════════
renew_user_interactive() {
    echo -ne "${GRN}Full password: ${RST}"; read pass
    echo -ne "${GRN}Days to add: ${RST}"; read days
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    if [ -z "$oldexp" ]; then
        echo -e "${RED}User not found.${RST}"; read -p "Press Enter..."; return
    fi
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
    awk -F'|' -v OFS='|' -v p="$pass" -v newexp="$newexp" '$1==p{$2=newexp}1' "$DB" > /tmp/db.tmp && mv /tmp/db.tmp "$DB"
    echo -e "${GRN}Expiry extended to $newexp${RST}"
    read -p "Press Enter..."
}

cleanup_expired() {
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port hwid start; do
        if [[ "$expiry" < "$today" ]]; then
            [ -n "$port" ] && remove_tracking "$port"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
        fi
    done < "$DB"
    systemctl restart zivpn 2>/dev/null || true
    echo -e "${GRN}Expired users cleaned.${RST}"
    read -p "Press Enter..."
}

connection_stats() {
    echo -e "\n${CYN}Current UDP sessions per user:${RST}"
    while IFS='|' read -r pass expiry quota port hwid start; do
        sessions=$(ss -un state established 2>/dev/null | grep -c ":$port " || echo 0)
        echo -e "${WHT}$pass${RST} : ${YLW}$sessions sessions${RST}"
    done < "$DB"
    read -p "Press Enter..."
}

bw_expiry_summary() {
    echo -e "\n${CYN}Password | Used/Quota | Expiry${RST}"
    while IFS='|' read -r pass expiry quota port hwid start; do
        used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2)
        used=${used:-0}
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ]; then
            used_fmt=$(format_bytes $used)
            quota_fmt=$quota
        else
            used_fmt="unlimited"
            quota_fmt="unlimited"
        fi
        echo "$pass | $used_fmt / $quota_fmt | $expiry"
    done < "$DB"
    read -p "Press Enter..."
}

reset_bandwidth_interactive() {
    echo -ne "${GRN}Full password: ${RST}"; read pass
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    [ -n "$port" ] && { iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null; }
    sed -i "/^$pass|/c\\$pass|0" "$USAGE_DB"
    reset_user_quota_pause "$pass"
    echo -e "${GRN}Bandwidth reset.${RST}"
    read -p "Press Enter..."
}

speed_test() {
    if command -v speedtest-cli &>/dev/null; then
        speedtest-cli
    else
        echo -e "${YLW}speedtest-cli not found.${RST}"
    fi
    read -p "Press Enter..."
}

backup_data() {
    local backup_file="/tmp/opudp_backup_$(date +%Y%m%d_%H%M%S).tar.gz"
    tar -czf "$backup_file" /etc/zivpn 2>/dev/null
    echo -e "${GRN}Backup saved to ${WHT}$backup_file${RST}"
    read -p "Press Enter..."
}

restore_backup() {
    echo -ne "${GRN}Path to backup file: ${RST}"; read backup_file
    if [ ! -f "$backup_file" ]; then
        echo -e "${RED}File not found.${RST}"; read -p "Press Enter..."; return
    fi
    systemctl stop zivpn 2>/dev/null
    tar -xzf "$backup_file" -C /
    systemctl start zivpn 2>/dev/null
    echo -e "${GRN}Restored.${RST}"
    read -p "Press Enter..."
}

change_port_range() {
    echo -e "${YLW}Current range: $PORT_START - $PORT_END${RST}"
    echo -ne "${GRN}New start port: ${RST}"; read new_start
    echo -ne "${GRN}New end port: ${RST}"; read new_end
    if ! [[ "$new_start" =~ ^[0-9]+$ ]] || ! [[ "$new_end" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Invalid ports.${RST}"; read -p "Press Enter..."; return
    fi
    sed -i "s/^PORT_START=.*/PORT_START=$new_start/; s/^PORT_END=.*/PORT_END=$new_end/" /usr/local/bin/onepesewa
    echo -e "${GRN}Port range updated. Restart panel to apply.${RST}"
    read -p "Press Enter..."
}

conn_limit_interactive() {
    echo -ne "${GRN}Full password: ${RST}"; read pass
    echo -ne "${GRN}Max connections (0 = unlimited): ${RST}"; read max
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    if [ -z "$port" ]; then echo -e "${RED}User not found.${RST}"; read -p "Press Enter..."; return; fi
    if [ "$max" -eq 0 ]; then
        iptables -D INPUT -p udp --dport $port -m connlimit --connlimit-above 0 -j DROP 2>/dev/null || true
        echo -e "${GRN}Limit removed.${RST}"
    else
        iptables -C INPUT -p udp --dport $port -m connlimit --connlimit-above $max -j DROP 2>/dev/null || \
            iptables -I INPUT -p udp --dport $port -m connlimit --connlimit-above $max -j DROP
        echo -e "${GRN}Limit set to $max.${RST}"
    fi
    read -p "Press Enter..."
}

