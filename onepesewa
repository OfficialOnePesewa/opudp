config_telegram() {
    clear
    echo -e "${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│           🤖 TELEGRAM BOT CONFIGURATION              │${RST}"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
    echo -e "${GRN}1) Set Bot Token${RST}"
    echo -e "${GRN}2) Start Bot${RST}"
    echo -e "${GRN}3) Stop Bot${RST}"
    echo -e "${GRN}4) Bot Status${RST}"
    echo -e "${GRN}5) Add Bot Admin (Sub-admin)${RST}"
    echo -e "${GRN}6) Remove Bot Admin${RST}"
    echo -e "${GRN}7) List Bot Admins${RST}"
    echo -e "${RED}0) Back${RST}"
    echo -ne "${CYN}Choose: ${RST}"
    read opt_bot
    case $opt_bot in
        1)
            echo -ne "${GRN}Enter Bot Token: ${RST}"; read token
            echo "$token" > "$TELEGRAM_TOKEN_FILE"
            echo -e "${GRN}Token saved.${RST}"
            read -p "Press Enter..."
            ;;
        2)
            if [ ! -f "$TELEGRAM_TOKEN_FILE" ]; then
                echo -e "${RED}Token not set.${RST}"; read -p "Press Enter..."; return
            fi
            if ! python3 -c "import telegram" 2>/dev/null; then
                echo -e "${YLW}Installing python-telegram-bot...${RST}"
                pip3 install python-telegram-bot --break-system-packages -q
            fi
            if [ ! -f /usr/local/bin/opudp_bot.py ]; then
                wget -qO /usr/local/bin/opudp_bot.py "https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/opudp_bot.py"
                chmod +x /usr/local/bin/opudp_bot.py
            fi
            cat <<EOF > "$BOT_SERVICE_FILE"
[Unit]
Description=OP UDP Panel Telegram Bot
After=network.target

[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/opudp_bot.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
EOF
            systemctl daemon-reload
            systemctl enable opudp-bot
            systemctl restart opudp-bot
            echo -e "${GRN}Bot started.${RST}"
            read -p "Press Enter..."
            ;;
        3)
            systemctl stop opudp-bot; systemctl disable opudp-bot
            echo -e "${RED}Bot stopped.${RST}"
            read -p "Press Enter..."
            ;;
        4)
            if systemctl is-active --quiet opudp-bot; then
                echo -e "${GRN}Bot is running.${RST}"
            else
                echo -e "${RED}Bot is not running.${RST}"
            fi
            read -p "Press Enter..."
            ;;
        5)
            echo -ne "${GRN}Enter Chat ID: ${RST}"; read chatid
            echo "$chatid" >> "$BOT_ADMINS_FILE"
            echo -e "${GRN}Admin added.${RST}"
            read -p "Press Enter..."
            ;;
        6)
            echo -ne "${GRN}Enter Chat ID: ${RST}"; read chatid
            sed -i "/^$chatid$/d" "$BOT_ADMINS_FILE" 2>/dev/null
            echo -e "${GRN}Removed.${RST}"
            read -p "Press Enter..."
            ;;
        7)
            if [ -f "$BOT_ADMINS_FILE" ]; then
                echo -e "${CYN}Bot Admins:${RST}"; cat "$BOT_ADMINS_FILE"
            else
                echo -e "${YLW}No admins configured.${RST}"
            fi
            read -p "Press Enter..."
            ;;
        0) return ;;
        *) echo -e "${RED}Invalid.${RST}"; read -p "Press Enter..." ;;
    esac
    config_telegram
}

# ══════════════════════════════════════════════════════════════════════════════
#  BOT CLI MODE (updated userstatus)
# ══════════════════════════════════════════════════════════════════════════════
if [[ "${1-}" == "--bot-"* ]]; then
    cmd="${1#--bot-}"; shift
    case "$cmd" in
        status)
            fetch_geo; get_sysinfo
            echo "🖥 <b>Server Status</b>%0A🌐 IP: $IP%0A📍 Location: $LOC_STR%0A🏢 ISP: $ISP%0A💻 OS: $OS_INFO%0A⚡ Service: $(systemctl is-active zivpn)%0A⏱ Uptime: $UPTIME%0A🚀 BBR: $(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo unknown)%0A👥 Users: $USER_COUNT"
            ;;
        adduser)    result=$(add_user_core "$1" "$2" "$3" "$4"); echo "$result" ;;
        removeuser) pass="$1"
            port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
            [ -n "$port" ] && remove_tracking "$port"
            tmp_json=$(mktemp)
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
            systemctl restart zivpn 2>/dev/null || true
            echo "✅ User removed." ;;
        renew)      pass="$1"; days="$2"
            oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
            newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
            awk -F'|' -v OFS='|' -v p="$pass" -v newexp="$newexp" '$1==p{$2=newexp}1' "$DB" > /tmp/db.tmp && mv /tmp/db.tmp "$DB"
            echo "✅ Expiry extended to $newexp" ;;
        resetbw)    pass="$1"
            port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
            [ -n "$port" ] && { iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null; }
            sed -i "/^$pass|/c\\$pass|0" "$USAGE_DB"
            reset_user_quota_pause "$pass"
            echo "✅ Bandwidth reset." ;;
        userinfo)   pass="$1"
            user_data=$(grep "^$pass|" "$DB")
            IFS='|' read -r p expiry quota port hwid start <<< "$user_data"
            used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}
            quota_bytes=$(quota_to_bytes "$quota")
            remain=$((quota_bytes - used))
            days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
            echo "🔍 <b>${p}</b>%0A📅 Expiry: $expiry ($days_left days)%0A📊 Quota: $quota%0A📈 Used: $(format_bytes $used)%0A📉 Remain: $(format_bytes $remain)%0A🔒 HWID: $hwid%0A🔌 Port: $port" ;;
        userstatus) pass="$1"
            # Use the same bandwidth details function, but redirected to stdout
            show_bandwidth_details "$pass" | sed 's/\x1B\[[0-9;]*[a-zA-Z]//g'  # strip colors for bot
            ;;
        list)       column -t -s "|" "$DB" | awk -F'|' '{print $1" | "$2" | "$3" | "$5}' ;;
        cleanup)    today=$(date +%Y-%m-%d)
            while IFS='|' read -r pass expiry quota port hwid start; do
                [[ "$expiry" < "$today" ]] && {
                    [ -n "$port" ] && remove_tracking "$port"
                    tmp_json=$(mktemp)
                    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
                    sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
                }
            done < "$DB"
            systemctl restart zivpn 2>/dev/null || true
            echo "✅ Cleanup done." ;;
        trial)      mins="$1"
            hwid="trial_$(openssl rand -hex 4)"
            basepass="trial"
            finalpass="${basepass}_${hwid}"
            port=$(find_free_port)
            exp=$(date -d "+1 day" +%Y-%m-%d)
            tmp_json=$(mktemp)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > "$tmp_json" && mv "$tmp_json" "$CONFIG"
            echo "$finalpass|$exp|100MB|$port|$hwid|$(date +%Y-%m-%d)" >> "$DB"
            echo "$finalpass|0" >> "$USAGE_DB"
            setup_tracking "$port"
            systemctl restart zivpn 2>/dev/null || true
            echo "Trial created: $finalpass (expires in $mins minutes)"
            ( sleep $((mins*60))
              remove_tracking "$port"
              jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
              sed -i "/^$finalpass|/d" "$DB" "$USAGE_DB"
              systemctl restart zivpn 2>/dev/null
            ) & ;;
        bbr)        bash <(curl -s https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/optimizer.sh --ipv4) ;;
        badvpn)     wget -N https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/Install/udpgw.sh && bash udpgw.sh ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi

