# ════════════════════════════════════════════════════════════════
#  GEO / SYSINFO
# ════════════════════════════════════════════════════════════════
fetch_geo() {
    if [ -f "$CACHE_FILE" ] && \
       [ $(( $(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0) )) -lt $CACHE_TTL ]; then
        # shellcheck disable=SC1090
        source "$CACHE_FILE"; return
    fi
    printf "${DIM}Fetching location...${RST}"
    GEO=""
    for api in "https://ipapi.co/json/" "https://ipinfo.io/json" "https://ifconfig.co/json"; do
        GEO=$(curl -4 -s --max-time 5 "$api" 2>/dev/null)
        echo "$GEO" | grep -q '"ip"' && break
        GEO=""
    done
    if [ -z "$GEO" ]; then
        IP="N/A"; CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"
        ZIP=""; COUNTRY_CODE=""
    else
        IP=$(echo "$GEO"           | grep -oP '"ip"\s*:\s*"\K[^"]+')
        CITY=$(echo "$GEO"         | grep -oP '"city"\s*:\s*"\K[^"]+')
        COUNTRY=$(echo "$GEO"      | grep -oP '"country_name"\s*:\s*"\K[^"]+')
        [ -z "$COUNTRY" ] && \
        COUNTRY=$(echo "$GEO"      | grep -oP '"country"\s*:\s*"\K[^"]+' | head -1)
        COUNTRY_CODE=$(echo "$GEO" | grep -oP '"country"\s*:\s*"\K[^"]+' \
                       | head -1 | tr '[:upper:]' '[:lower:]')
        ZIP=$(echo "$GEO"          | grep -oP '"postal"\s*:\s*"\K[^"]+')
        ISP=$(echo "$GEO"          | grep -oP '"org"\s*:\s*"\K[^"]+')
        [ -z "$IP"      ] && IP="N/A"
        [ -z "$CITY"    ] && CITY="Unknown"
        [ -z "$COUNTRY" ] && COUNTRY="Unknown"
        [ -z "$ISP"     ] && ISP="Unknown"
    fi
    printf "IP=\"%s\"; CITY=\"%s\"; COUNTRY=\"%s\"; COUNTRY_CODE=\"%s\"; ZIP=\"%s\"; ISP=\"%s\"\n" \
        "$IP" "$CITY" "$COUNTRY" "$COUNTRY_CODE" "$ZIP" "$ISP" > "$CACHE_FILE"
    printf "\r\033[K"
}

flag() {
    case $1 in
        us) echo "🇺🇸";; gb) echo "🇬🇧";; ca) echo "🇨🇦";; au) echo "🇦🇺";;
        de) echo "🇩🇪";; fr) echo "🇫🇷";; nl) echo "🇳🇱";; in) echo "🇮🇳";;
        jp) echo "🇯🇵";; br) echo "🇧🇷";; za) echo "🇿🇦";; sg) echo "🇸🇬";;
        gh) echo "🇬🇭";; ng) echo "🇳🇬";; ke) echo "🇰🇪";; il) echo "🇮🇱";;
        *) echo "🌍";;
    esac
}

get_sysinfo() {
    OS_INFO=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2)
    UPTIME=$(uptime -p 2>/dev/null | sed \
        's/up //;s/ days\?/d/;s/ hours\?/h/;s/ minutes\?/m/')
    [ -z "$UPTIME" ] && UPTIME="N/A"
    if systemctl is-active --quiet zivpn 2>/dev/null; then
        STATUS="${GRN}🟢 Active${RST}"
    else
        STATUS="${RED}🔴 Inactive${RST}"
    fi
    USER_COUNT=$(jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0")
    DATE_TIME=$(date +"%a %d %b %Y  %I:%M:%S %p %Z")
    FLAG=$(flag "$COUNTRY_CODE")
    LOC_STR="${FLAG}  ${CITY}, ${COUNTRY}"
}

