# ── Free NAT port finder ──────────────────────────────────────────────────────
find_free_port() {
    local p=$ZIVPN_NAT_START
    while [ $p -le $ZIVPN_NAT_END ]; do
        grep -q "|$p|" "$ZIVPN_DB" 2>/dev/null || { echo $p; return; }
        p=$(( p + 1 ))
    done
    echo "$ZIVPN_NAT_END"
}

# ── Service control ───────────────────────────────────────────────────────────
service_control() {
    local action=$1
    echo -e "${YLW}Select service:${RST}"
    echo "  1) ZIVPN only"
    echo "  2) UDP Custom only"
    echo "  3) Both"
    read -p "Choice: " svc
    case $svc in
        1) systemctl "$action" zivpn ;;
        2) systemctl "$action" udp-custom ;;
        3) systemctl "$action" zivpn; systemctl "$action" udp-custom ;;
        *) echo -e "${RED}Invalid choice.${RST}"; return ;;
    esac
    sleep 2
    echo ""
    echo -e "ZIVPN:      $(systemctl is-active zivpn 2>/dev/null)"
    echo -e "UDP Custom: $(systemctl is-active udp-custom 2>/dev/null)"
}

# ── UDP Custom user management ────────────────────────────────────────────────
udpc_add_user() {
    local username=$1 password=$2 days=$3
    local exp_date; exp_date=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || date -v "+${days}d" +%Y-%m-%d)
    local tmp; tmp=$(mktemp)
    jq --arg u "$username" --arg p "$password" --arg e "$exp_date" \
        '. + {($u): {"password": $p, "expiry": $e}}' "$UDPC_USERFILE" > "$tmp" 2>/dev/null \
        && mv "$tmp" "$UDPC_USERFILE" || rm -f "$tmp"
    sync_udpc_config
    systemctl restart udp-custom 2>/dev/null || true
    echo "$exp_date"
}

udpc_remove_user() {
    local username=$1
    local tmp; tmp=$(mktemp)
    jq --arg u "$username" 'del(.[$u])' "$UDPC_USERFILE" > "$tmp" 2>/dev/null \
        && mv "$tmp" "$UDPC_USERFILE" || rm -f "$tmp"
    sync_udpc_config
    systemctl restart udp-custom 2>/dev/null || true
}

udpc_list_users() {
    echo -e "\n${CYN}UDP Custom Users:${RST}"
    if [ -f "$UDPC_USERFILE" ] && [ "$(jq 'length' "$UDPC_USERFILE" 2>/dev/null)" -gt 0 ]; then
        printf "%-20s %-20s %-12s\n" "Username" "Password" "Expiry"
        echo "───────────────────────────────────────────────────────"
        jq -r 'to_entries[] | "\(.key)|\(.value.password)|\(.value.expiry)"' \
            "$UDPC_USERFILE" 2>/dev/null | \
        while IFS='|' read -r u p e; do
            printf "%-20s %-20s %-12s\n" "$u" "$p" "$e"
        done
    else
        echo -e "  ${DIM}No UDP Custom users.${RST}"
    fi
}

# ── Add user ──────────────────────────────────────────────────────────────────
add_user() {
    echo -e "\n${YLW}Select Protocol:${RST}"
    echo "  1) ZIVPN"
    echo "  2) UDP Custom"
    read -p "Choice [1-2]: " proto
    case $proto in
        1)
            read -p "Base Password       : " basepass
            read -p "Validity (Days)     : " days
            read -p "Quota (e.g. 10GB)   : " quota
            read -p "Device ID (optional): " devid
            [ -n "$devid" ] && finalpass="${basepass}_${devid}" || finalpass="$basepass"
            local exp; exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "N/A")
            local port; port=$(find_free_port)
            local tmp; tmp=$(mktemp)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$ZIVPN_CFG" > "$tmp" 2>/dev/null \
                && mv "$tmp" "$ZIVPN_CFG" || rm -f "$tmp"
            echo "$finalpass|$exp|$quota|$port|${devid:-None}|$(date +%Y-%m-%d)" >> "$ZIVPN_DB"
            echo "$finalpass|0" >> "$ZIVPN_USAGE"
            systemctl restart zivpn 2>/dev/null || true
            fetch_geo
            echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
            echo -e "${CYN}│  ${GRN}🎉 ZIVPN USER CREATED${RST}${CYN}                                │${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Server IP  :${RST} ${WHT}$IP${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Port       :${RST} ${WHT}5667${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Password   :${RST} ${WHT}$finalpass${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Expiry     :${RST} ${WHT}$exp ($days days)${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Quota      :${RST} ${WHT}$quota${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Device ID  :${RST} ${WHT}${devid:-None}${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Location   :${RST} ${WHT}$CITY, $COUNTRY${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Admin TG   :${RST} ${WHT}$ADMIN_TELEGRAM${RST}"
            echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}"
            ;;
        2)
            read -p "Username (blank=auto): " username
            read -p "Password (blank=auto): " password
            read -p "Validity (Days)      : " days
            [ -z "$username" ] && username="user_$(openssl rand -hex 3)"
            [ -z "$password" ] && password=$(openssl rand -hex 6)
            local expiry; expiry=$(udpc_add_user "$username" "$password" "$days")
            fetch_geo
            echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
            echo -e "${CYN}│  ${GRN}🎉 UDP CUSTOM USER CREATED${RST}${CYN}                            │${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Server IP  :${RST} ${WHT}$IP${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Port       :${RST} ${WHT}$UDPC_PORT${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Username   :${RST} ${WHT}$username${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Password   :${RST} ${WHT}$password${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Expiry     :${RST} ${WHT}$expiry ($days days)${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Connection :${RST} ${WHT}$IP:$UDPC_PORT@$username:$password${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Location   :${RST} ${WHT}$CITY, $COUNTRY${RST}"
            echo -e "${CYN}│${RST}  ${YLW}Admin TG   :${RST} ${WHT}$ADMIN_TELEGRAM${RST}"
            echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}"
            ;;
        *) echo -e "${RED}Invalid.${RST}" ;;
    esac
    read -p "Press Enter to continue..."
}

# ── Remove user ───────────────────────────────────────────────────────────────
remove_user() {
    echo -e "\n${YLW}Select Protocol:${RST}"
    echo "  1) ZIVPN"
    echo "  2) UDP Custom"
    read -p "Choice [1-2]: " proto
    case $proto in
        1)
            read -p "ZIVPN Password: " pass
            local tmp; tmp=$(mktemp)
            jq --arg p "$pass" '.auth.config -= [$p]' "$ZIVPN_CFG" > "$tmp" 2>/dev/null \
                && mv "$tmp" "$ZIVPN_CFG" || rm -f "$tmp"
            sed -i "/^$pass|/d" "$ZIVPN_DB" "$ZIVPN_USAGE" 2>/dev/null || true
            systemctl restart zivpn 2>/dev/null || true
            echo -e "${GRN}ZIVPN user removed.${RST}"
            ;;
        2)
            read -p "UDP Custom Username: " username
            udpc_remove_user "$username"
            echo -e "${GRN}UDP Custom user removed.${RST}"
            ;;
        *) echo -e "${RED}Invalid.${RST}" ;;
    esac
    read -p "Press Enter to continue..."
}

# ── Renew ─────────────────────────────────────────────────────────────────────
renew_user() {
    read -p "ZIVPN Password : " pass
    read -p "Extend by Days : " days
    local line; line=$(grep "^$pass|" "$ZIVPN_DB" 2>/dev/null | head -1)
    if [ -z "$line" ]; then
        echo -e "${RED}User not found.${RST}"; read -p "Press Enter..."; return
    fi
    local oldexp; oldexp=$(echo "$line" | cut -d'|' -f2)
    local newexp; newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d 2>/dev/null || echo "N/A")
    sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$ZIVPN_DB"
    echo -e "${GRN}Expiry extended to $newexp${RST}"
    read -p "Press Enter..."
}

# ── Cleanup expired ───────────────────────────────────────────────────────────
cleanup_expired() {
    local today; today=$(date +%Y-%m-%d)
    local count=0
    while IFS='|' read -r p exp rest; do
        [[ "$exp" < "$today" ]] || continue
        local tmp; tmp=$(mktemp)
        jq --arg p "$p" '.auth.config -= [$p]' "$ZIVPN_CFG" > "$tmp" 2>/dev/null \
            && mv "$tmp" "$ZIVPN_CFG" || rm -f "$tmp"
        sed -i "/^$p|/d" "$ZIVPN_DB" "$ZIVPN_USAGE" 2>/dev/null || true
        count=$(( count + 1 ))
    done < "$ZIVPN_DB"
    systemctl restart zivpn 2>/dev/null || true
    echo -e "${GRN}Cleanup done. Removed $count expired ZIVPN user(s).${RST}"
    read -p "Press Enter..."
}

