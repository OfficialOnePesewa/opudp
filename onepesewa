# ------------------ Helper Functions ------------------
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|$port|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port+1))
    done
    echo ""
}

setup_tracking() {
    local port=$1
    iptables -I INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
    iptables -N UDP_IN_$port 2>/dev/null; iptables -N UDP_OUT_$port 2>/dev/null
    iptables -I INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
}

remove_tracking() {
    local port=$1
    iptables -D INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
    iptables -F UDP_IN_$port 2>/dev/null; iptables -X UDP_IN_$port 2>/dev/null
    iptables -F UDP_OUT_$port 2>/dev/null; iptables -X UDP_OUT_$port 2>/dev/null
    iptables -D INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
}

add_user_core() {
    local basepass="$1" days="$2" quota="$3" hwid="$4"
    finalpass="${basepass}_${hwid}"
    exp=$(date -d "+$days days" +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$hwid" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|$finalpass|$exp|$port|$quota"
}

# Show user status (for panel option 24)
show_user_status() {
    echo -ne "${GRN}Enter full password: ${RST}"
    read pass
    user_data=$(grep "^$pass|" "$DB")
    if [ -z "$user_data" ]; then
        echo -e "${RED}Password not found.${RST}"
        read -p "Press Enter..."
        return
    fi
    IFS='|' read -r p expiry quota port hwid <<< "$user_data"
    used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2)
    used=${used:-0}
    quota_bytes=$(echo "$quota" | awk '/GB/ {print $1*1073741824} /MB/ {print $1*1048576} !/GB|MB/ {print 0}')
    remain=$((quota_bytes - used))
    [ $remain -lt 0 ] && remain=0
    days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
    sessions=$(ss -un state established 2>/dev/null | grep -c ":$port" || echo 0)
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│           📊 ACCOUNT STATUS 📊                         │${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST} ${YLW}🔑 Password  :${RST} $p"
    echo -e "${CYN}│${RST} ${YLW}📅 Expiry    :${RST} $expiry (${days_left} days left)"
    echo -e "${CYN}│${RST} ${YLW}📊 Quota     :${RST} $quota"
    echo -e "${CYN}│${RST} ${YLW}📈 Used      :${RST} $(numfmt --to=iec $used 2>/dev/null || echo "$used B")"
    echo -e "${CYN}│${RST} ${YLW}📉 Remaining :${RST} $(numfmt --to=iec $remain 2>/dev/null || echo "$remain B")"
    echo -e "${CYN}│${RST} ${YLW}🔒 HWID      :${RST} $hwid"
    echo -e "${CYN}│${RST} ${YLW}👥 Sessions  :${RST} $sessions"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}"
    read -p "Press Enter..."
}

