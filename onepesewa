            echo "🖥 <b>Server Status</b>%0A🌐 IP: $IP%0A📍 Location: $LOC_STR%0A🏢 ISP: $ISP%0A💻 OS: $OS_INFO%0A⚡ Service: $(systemctl is-active zivpn)%0A⏱ Uptime: $UPTIME%0A👥 Users: $USER_COUNT"
            ;;
        adduser)
            result=$(add_user_core "$1" "$2" "$3" "$4")
            echo "$result"
            ;;
        removeuser)
            pass="$1"
            port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
            [ -n "$port" ] && remove_tracking "$port"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
            systemctl restart zivpn 2>/dev/null
            echo "✅ User removed."
            ;;
        renew)
            pass="$1"; days="$2"
            oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
            newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
            sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
            echo "✅ Expiry extended to $newexp"
            ;;
        resetbw)
            pass="$1"
            port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
            iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null
            sed -i "s|^$pass|.*|$pass|0|" "$USAGE_DB"
            echo "✅ Bandwidth reset."
            ;;
        userinfo)
            pass="$1"
            user_data=$(grep "^$pass|" "$DB")
            IFS='|' read -r p expiry quota port hwid <<< "$user_data"
            used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2)
            used=${used:-0}
            quota_bytes=$(echo "$quota" | awk '/GB/ {print $1*1073741824} /MB/ {print $1*1048576} !/GB|MB/ {print 0}')
            remain=$((quota_bytes - used))
            days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
            echo "🔍 <b>${p}</b>%0A📅 Expiry: $expiry ($days_left days)%0A📊 Quota: $quota%0A📈 Used: $(numfmt --to=iec $used)%0A📉 Remain: $(numfmt --to=iec $remain)%0A🔒 HWID: $hwid%0A🔌 Port: $port"
            ;;
        userstatus)
            pass="$1"
            user_data=$(grep "^$pass|" "$DB")
            if [ -z "$user_data" ]; then
                echo "❌ Password not found."
                exit 1
            fi
            IFS='|' read -r p expiry quota port hwid <<< "$user_data"
            used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2)
            used=${used:-0}
            quota_bytes=$(echo "$quota" | awk '/GB/ {print $1*1073741824} /MB/ {print $1*1048576} !/GB|MB/ {print 0}')
            remain=$((quota_bytes - used))
            if [ $remain -lt 0 ]; then remain=0; fi
            days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
            sessions=$(ss -un state established 2>/dev/null | grep -c ":$port" || echo 0)
            echo "🔑 *Password:* $p"
            echo "📅 *Expiry:* $expiry ($days_left days left)"
            echo "📊 *Quota:* $quota"
            echo "📈 *Used:* $(numfmt --to=iec $used 2>/dev/null || echo "$used B")"
            echo "📉 *Remaining:* $(numfmt --to=iec $remain 2>/dev/null || echo "$remain B")"
            echo "🔒 *HWID:* $hwid"
            echo "👥 *Active sessions:* $sessions"
            ;;
        list)
            column -t -s "|" "$DB" | awk -F'|' '{print $1" | "$2" | "$3" | "$5}'
            ;;
        cleanup)
            today=$(date +%Y-%m-%d)
            while IFS='|' read -r pass expiry quota port hwid; do
                [[ "$expiry" < "$today" ]] && {
                    [ -n "$port" ] && remove_tracking "$port"
                    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
                    sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
                }
            done < "$DB"
            systemctl restart zivpn 2>/dev/null
            echo "✅ Cleanup done."
            ;;
        trial)
            mins="$1"
            hwid="trial_$(openssl rand -hex 4)"
            basepass="trial"
            finalpass="${basepass}_${hwid}"
            port=$(find_free_port)
            exp=$(date -d "+1 day" +%Y-%m-%d)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            echo "$finalpass|$exp|100MB|$port|$hwid" >> "$DB"
            echo "$finalpass|0" >> "$USAGE_DB"
            setup_tracking "$port"
            systemctl restart zivpn 2>/dev/null
            echo "Trial created: $finalpass (expires in $mins minutes)"
            ( sleep $((mins*60))
              remove_tracking "$port"
              jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
              sed -i "/^$finalpass|/d" "$DB" "$USAGE_DB"
              systemctl restart zivpn 2>/dev/null
            ) &
            ;;
        bbr)
            apt install curl -y
            bash <(curl -s https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/optimizer.sh --ipv4)
            echo "BBR optimization installed."
            ;;
        badvpn)
            wget -N https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/Install/udpgw.sh && bash udpgw.sh
            echo "BadVPN installed."
            ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi

# ------------------ Main Loop ------------------
fetch_geo
while true; do
    banner
    show_menu
    echo -ne "${CYN}Choose [0-99]: ${RST}"; read opt
    case $opt in
        1) systemctl start zivpn && echo -e "${GRN}Started.${RST}" || echo -e "${RED}Failed.${RST}"; read -p "Press Enter..." ;;
        2) systemctl stop zivpn && echo -e "${RED}Stopped.${RST}" || echo -e "${RED}Failed.${RST}"; read -p "Press Enter..." ;;
        3) systemctl restart zivpn && echo -e "${GRN}Restarted.${RST}" || echo -e "${RED}Failed.${RST}"; read -p "Press Enter..." ;;
        4) systemctl status zivpn; read -p "Press Enter..." ;;
        5) [ -f "$DB" ] && { echo -e "\n${CYN}Password | Expiry | Quota | HWID${RST}"; column -t -s "|" "$DB" | awk -F'|' '{print $1" | "$2" | "$3" | "$5}'; } || echo -e "${RED}No users.${RST}"; read -p "Press Enter..." ;;
        6) add_user_interactive ;;
        7) remove_user_interactive ;;
        8|9|10|11|12|13|15|16|17|19) echo "Coming soon."; read -p "Press Enter..." ;;
        14) journalctl -u zivpn -f ;;
        18) echo -e "\n${YLW}Updating panel...${RST}"
            wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa
            chmod +x /usr/local/bin/onepesewa
            echo -e "${GRN}Update complete! Restarting...${RST}"; sleep 2; exec onepesewa ;;
        20) trial_user_interactive ;;
        21) install_bbr ;;
        22) install_badvpn ;;
        23) config_telegram ;;
        24) show_user_status ;;
        99) systemctl stop zivpn 2>/dev/null; rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa; echo -e "${RED}Uninstalled.${RST}"; exit ;;
        0) goodbye; exit ;;
        *) echo -e "${RED}Invalid.${RST}"; read -p "Press Enter..." ;;
    esac
done
