# --- Add User (with card) - FIXED PROMPTS ---
add_user() {
    echo -e "\n${YLW}═══════════════ CREATE NEW USER ═══════════════${RST}"
    echo -ne "${GRN}User Password: ${RST}"
    read pass
    echo -ne "${GRN}Validity (Days): ${RST}"
    read days
    echo -ne "${GRN}Quota (GB/MB): ${RST}"
    read quota
    echo -ne "${GRN}Device ID (Optional): ${RST}"
    read devid

    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")

    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi

    echo "$pass|$exp|$quota|${devid:-None}" >> "$DB"
    systemctl restart zivpn 2>/dev/null

    echo -e "\n${CYN}╔══════════════════════════════════════════════════════╗${RST}"
    echo -e "${CYN}║  ${GRN}${BOLD}🎉 NEW USER CREATED SUCCESSFULLY 🎉${RST}${CYN}                 ║${RST}"
    echo -e "${CYN}╠══════════════════════════════════════════════════════╣${RST}"
    echo -e "${CYN}║${RST} ${YLW}👤 Password   :${RST} ${WHT}$pass${RST}"
    echo -e "${CYN}║${RST} ${YLW}⏳ Expiry     :${RST} ${WHT}$exp ($days Days)${RST}"
    echo -e "${CYN}║${RST} ${YLW}📊 Quota      :${RST} ${WHT}$quota${RST}"
    echo -e "${CYN}║${RST} ${YLW}📱 Device ID  :${RST} ${WHT}${devid:-None}${RST}"
    echo -e "${CYN}╠══════════════════════════════════════════════════════╣${RST}"
    echo -e "${CYN}║${RST} ${MAG}🌍 Server IP  :${RST} ${WHT}$IP${RST}"
    echo -e "${CYN}║${RST} ${MAG}📍 Location   :${RST} ${WHT}$CITY, $COUNTRY${RST}"
    echo -e "${CYN}║${RST} ${MAG}🏢 ISP        :${RST} ${WHT}$ISP${RST}"
    echo -e "${CYN}╚══════════════════════════════════════════════════════╝${RST}"
    echo ""
    read -p "Press Enter to continue..."
}

# --- Trial User ---
trial_user() {
    echo -ne "${GRN}Minutes (1-60): ${RST}"
    read mins
    pass="trial_$(openssl rand -hex 2)"
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi
    echo -e "${GRN}Trial Created: ${YLW}$pass${GRN} (Expires in $mins mins)${RST}"
    (
        sleep $((mins * 60))
        if [ -f "$CONFIG" ]; then
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
        fi
    ) &
    read -p "Press Enter to continue..."
}

# --- Menu ---
show_menu() {
    echo -e "${WHT}┌─────────────────────────────────────────────────────────────────────────────┐${RST}"
    echo -e "${WHT}│  ${GRN} 1)${RST} Start ZIVPN      ${GRN} 6)${RST} Add User          ${GRN}11)${RST} Bandwidth+Expiry  ${GRN}16)${RST} Restore Backup   ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN} 2)${RST} Stop ZIVPN       ${GRN} 7)${RST} Remove User       ${GRN}12)${RST} Reset Bandwidth   ${GRN}17)${RST} Change Port Range${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN} 3)${RST} Restart ZIVPN    ${GRN} 8)${RST} Renew/Extend      ${GRN}13)${RST} Speed Test        ${GRN}18)${RST} ${YLW}Auto-Update Panel${RST} ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN} 4)${RST} Status           ${GRN} 9)${RST} Cleanup Expired   ${GRN}14)${RST} Live Logs         ${GRN}19)${RST} Set Conn Limit    ${WHT}│${RST}"
    echo -e "${WHT}│  ${GRN} 5)${RST} List Users       ${GRN}10)${RST} Connection Stats  ${GRN}15)${RST} Backup Data       ${GRN}20)${RST} Trial User (1-60m)${WHT}│${RST}"
    echo -e "${WHT}├─────────────────────────────────────────────────────────────────────────────┤${RST}"
    echo -e "${WHT}│  ${RED}99) UNINSTALL${RST}                                                      ${GRN} 0) Exit${RST}  ${WHT}│${RST}"
    echo -e "${WHT}└─────────────────────────────────────────────────────────────────────────────┘${RST}"
    echo ""
}

# --- Main Loop ---
while true; do
    banner
    show_menu
    echo -ne "${CYN}Choose [0-99]: ${RST}"
    read opt

    case $opt in
        1) systemctl start zivpn && echo -e "${GRN}Started.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        2) systemctl stop zivpn && echo -e "${RED}Stopped.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        3) systemctl restart zivpn && echo -e "${GRN}Restarted.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        4) systemctl status zivpn ;;
        5)
           if [ -f "$DB" ]; then
               echo -e "\n${CYN}Pass | Expiry | Quota | DeviceID${RST}"
               echo "---------------------------------"
               column -t -s "|" "$DB"
           else
               echo -e "${RED}No user database.${RST}"
           fi
           read -p "Press Enter to continue..."
           ;;
        6) add_user ;;
        7)
           echo -ne "${GRN}Password to remove: ${RST}"
           read pass
           if [ -f "$CONFIG" ]; then
               jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
           fi
           [ -f "$DB" ] && sed -i "/^$pass|/d" "$DB"
           systemctl restart zivpn 2>/dev/null
           echo -e "${GRN}User removed.${RST}"
           read -p "Press Enter to continue..."
           ;;
        8|9|10|11|12|13|15|16|17|19)
           echo "Function not implemented yet."
           read -p "Press Enter..."
           ;;
        14) journalctl -u zivpn -f ;;
        18)
           echo -e "\n${YLW}Fetching latest panel from GitHub...${RST}"
           wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa
           chmod +x /usr/local/bin/onepesewa
           echo -e "${GRN}Update complete! Restarting...${RST}"
           sleep 2
           exec onepesewa
           ;;
        20) trial_user ;;
        99)
           systemctl stop zivpn 2>/dev/null
           rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa
           echo -e "${RED}Uninstalled.${RST}"
           exit
           ;;
        0) goodbye; exit ;;
        *) echo -e "${RED}Invalid option.${RST}"; read -p "Press Enter..." ;;
    esac
done
