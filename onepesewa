# ══════════════════════════════════════════════════════════════
#  CONNECTION LIMIT ENFORCEMENT (cron, every minute)
# ══════════════════════════════════════════════════════════════
ENFORCE_SCRIPT="/usr/local/bin/opudp_enforce_limits.sh"
ENFORCE_CRON="/etc/cron.d/opudp_connlimit"

write_enforce_script() {
    cat > "$ENFORCE_SCRIPT" <<'ENFEOF'
#!/bin/bash
DB="/etc/zivpn/users.db"
CONN_LIMIT_FILE="/etc/zivpn/conn_limits.db"
LOG_FILE="/var/log/opudp_enforce.log"
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"; }
[ ! -f "$DB" ] && exit 0
while IFS='|' read -r pass expiry quota port hwid used; do
    [ -z "$port" ] && continue
    limit=$(grep "^${pass}|" "$CONN_LIMIT_FILE" 2>/dev/null | cut -d'|' -f2)
    [ -z "$limit" ] || [ "$limit" -eq 0 ] && continue
    sessions=$(ss -un state established 2>/dev/null | grep -c ":${port} " || echo 0)
    if [ "$sessions" -gt "$limit" ]; then
        log "User $pass (port $port) has $sessions sessions, limit $limit – killing excess connections"
        conntrack -D -p udp --dport "$port" 2>/dev/null
    fi
done < "$DB"
ENFEOF
    chmod +x "$ENFORCE_SCRIPT"
}

enable_enforcement() {
    write_enforce_script
    echo "* * * * * root $ENFORCE_SCRIPT" > "$ENFORCE_CRON"
    if ! command -v conntrack &>/dev/null; then
        apt-get install -y conntrack -qq 2>/dev/null
    fi
    systemctl restart cron 2>/dev/null || systemctl restart crond 2>/dev/null
    echo -e "\n  ${GRN}✔ Connection limit enforcement enabled (cron every minute).${RST}"
}

disable_enforcement() {
    rm -f "$ENFORCE_SCRIPT" "$ENFORCE_CRON"
    systemctl restart cron 2>/dev/null || systemctl restart crond 2>/dev/null
    echo -e "\n  ${YLW}⚠ Connection enforcement disabled.${RST}"
}

enforcement_status() {
    if [ -f "$ENFORCE_CRON" ]; then
        echo -e "  ${GRN}● Enabled${RST} (cron job every minute)"
    else
        echo -e "  ${RED}● Disabled${RST}"
    fi
}

