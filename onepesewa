# --- Helper functions ---
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        if ! grep -q "|$port|" "$DB" 2>/dev/null; then
            echo $port; return
        fi
        port=$((port+1))
    done
    echo ""
}

quota_to_bytes() {
    local q=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    if [[ "$q" =~ ^([0-9.]+)gb$ ]]; then echo "${BASH_REMATCH[1]} * 1073741824" | bc | cut -d. -f1
    elif [[ "$q" =~ ^([0-9.]+)mb$ ]]; then echo "${BASH_REMATCH[1]} * 1048576" | bc | cut -d. -f1
    else echo "0"; fi
}

format_bytes() {
    local b=$1
    if [ $b -ge 1073741824 ]; then echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [ $b -ge 1048576 ]; then echo "$(echo "scale=2; $b/1048576" | bc) MB"
    elif [ $b -ge 1024 ]; then echo "$(echo "scale=2; $b/1024" | bc) KB"
    else echo "$b B"; fi
}

setup_tracking() {
    local port=$1
    iptables -I INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
    iptables -N UDP_IN_$port 2>/dev/null; iptables -N UDP_OUT_$port 2>/dev/null
    iptables -I INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
}

remove_tracking() {
    local port=$1
    iptables -D INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
    iptables -F UDP_IN_$port 2>/dev/null; iptables -X UDP_IN_$port 2>/dev/null
    iptables -F UDP_OUT_$port 2>/dev/null; iptables -X UDP_OUT_$port 2>/dev/null
    iptables -D INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
}

update_usage_db() {
    while IFS='|' read -r pass expiry quota port deviceid startdate; do
        if [ -n "$port" ] && [ "$port" != "None" ]; then
            in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
            out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
            total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
            grep -v "^$pass|" "$USAGE_DB" 2>/dev/null > /tmp/usage_tmp
            echo "$pass|$total" >> /tmp/usage_tmp
            mv /tmp/usage_tmp "$USAGE_DB"
            quota_bytes=$(quota_to_bytes "$quota")
            if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ]; then
                if grep -q "^$pass|" "$DB" && ! grep -q "^$pass|.*|PAUSED" "$DB"; then
                    sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
                    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
                    systemctl restart zivpn 2>/dev/null
                    echo "$(date): User $pass paused - quota exceeded" >> /var/log/opudp.log
                fi
            fi
        fi
    done < "$DB"
}

get_usage() {
    grep "^$1|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2 | head -1
}

install_cron() {
    if [ ! -f /etc/cron.d/opudp_bandwidth ]; then
        echo '* * * * * root /usr/local/bin/onepesewa --update-usage >/dev/null 2>&1' > /etc/cron.d/opudp_bandwidth
        chmod 644 /etc/cron.d/opudp_bandwidth
        systemctl restart cron 2>/dev/null
    fi
}

# --- Features ---
add_user() {
    echo -e "\n${YLW}╭────────────────── CREATE NEW USER ──────────────────╮${RST}"
    read -p "$(echo -e "${GRN}Base Password  : ${RST}")" basepass
    read -p "$(echo -e "${GRN}Validity (Days): ${RST}")" days
    read -p "$(echo -e "${GRN}Quota (GB/MB)  : ${RST}")" quota
    read -p "$(echo -e "${GRN}Device ID      : ${RST}")" devid
    echo -e "${YLW}╰──────────────────────────────────────────────────────╯${RST}"
    if [ -n "$devid" ]; then finalpass="${basepass}_${devid}"; else finalpass="$basepass"; devid="None"; fi
    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")
    startdate=$(date +%Y-%m-%d)
    port=$(find_free_port)
    if [ -z "$port" ]; then echo -e "${RED}No free ports!${RST}"; read -p "Press Enter..."; return; fi
    if [ -f "$CONFIG" ]; then jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; fi
    echo "$finalpass|$exp|$quota|$port|$devid|$startdate" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    get_sysinfo
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│  ${GRN}${BOLD}🎉 NEW USER CREATED SUCCESSFULLY 🎉${RST}${CYN}                 │${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST} ${YLW}🔑 UDP Password :${RST} ${WHT}$finalpass${RST}"
    echo -e "${CYN}│${RST} ${YLW}📡 Assigned Port:${RST} ${WHT}$port${RST}"
    echo -e "${CYN}│${RST} ${YLW}⏳ Expiry       :${RST} ${WHT}$exp ($days Days)${RST}"
    echo -e "${CYN}│${RST} ${YLW}📊 Quota        :${RST} ${WHT}$quota${RST}"
    echo -e "${CYN}│${RST} ${YLW}📱 Device ID    :${RST} ${WHT}$devid${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST} ${MAG}🌍 Server IP    :${RST} ${WHT}$IP${RST}"
    echo -e "${CYN}│${RST} ${MAG}📍 Location     :${RST} ${WHT}$CITY, $COUNTRY${RST}"
    echo -e "${CYN}│${RST} ${MAG}🏢 ISP          :${RST} ${WHT}$ISP${RST}"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
    read -p "Press Enter to continue..."
}

remove_user() {
    read -p "$(echo -e "${GRN}Password to remove: ${RST}")" pass
    port=$(grep "^$pass|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^$pass|/d" "$DB" 2>/dev/null; sed -i "/^$pass|/d" "$USAGE_DB" 2>/dev/null
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}User removed.${RST}"; read -p "Press Enter..."
}

renew_user() {
    read -p "$(echo -e "${GRN}Password to renew: ${RST}")" pass
    if ! grep -q "^$pass|" "$DB"; then echo -e "${RED}User not found.${RST}"; read -p "Press Enter..."; return; fi
    read -p "$(echo -e "${GRN}Extend by days: ${RST}")" days
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d 2>/dev/null || echo "$oldexp")
    sed -i "s|^$pass|$pass|$newexp|" "$DB"
    echo -e "${GRN}Expiry extended to $newexp.${RST}"; read -p "Press Enter..."
}

cleanup_expired() {
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port deviceid startdate; do
        if [[ "$expiry" < "$today" ]]; then
            [ -n "$port" ] && remove_tracking "$port"
            [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB"; sed -i "/^$pass|/d" "$USAGE_DB"
            echo "Removed expired user: $pass"
        fi
    done < "$DB"
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}Cleanup completed.${RST}"; read -p "Press Enter..."
}

show_usage_stats() {
    update_usage_db
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│${RST} ${BOLD}Password                          | Used / Quota       | Port  | Expiry${RST}     ${CYN}│${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────────────────────────┤${RST}"
    while IFS='|' read -r pass expiry quota port deviceid startdate; do
        if [ -n "$pass" ]; then
            used_bytes=$(get_usage "$pass"); quota_bytes=$(quota_to_bytes "$quota")
            used_fmt=$(format_bytes ${used_bytes:-0})
            if [ $quota_bytes -gt 0 ] && [ ${used_bytes:-0} -ge $quota_bytes ]; then status="${RED}PAUSED${RST}"; else status="${GRN}ACTIVE${RST}"; fi
            printf "${CYN}│${RST} %-33s | %-18s | %-5s | %-10s %s ${CYN}│${RST}\n" "${pass:0:33}" "$used_fmt / $quota" "$port" "$expiry" "$status"
        fi
    done < "$DB"
    echo -e "${CYN}╰──────────────────────────────────────────────────────────────────────────╯${RST}\n"
    read -p "Press Enter to continue..."
}

user_info() {
    read -p "$(echo -e "${GRN}Enter user password: ${RST}")" pass
    user_data=$(grep "^$pass|" "$DB" 2>/dev/null)
    if [ -z "$user_data" ]; then
        echo -e "${RED}User not found.${RST}"
        read -p "Press Enter..."
        return
    fi
    IFS='|' read -r p expiry quota port deviceid startdate <<< "$user_data"
    used_bytes=$(get_usage "$pass")
    used_fmt=$(format_bytes ${used_bytes:-0})
    
    exp_sec=$(date -d "$expiry" +%s 2>/dev/null)
    now_sec=$(date +%s)
    if [ -n "$exp_sec" ]; then
        days_left=$(( (exp_sec - now_sec) / 86400 ))
        [ $days_left -lt 0 ] && days_left=0
    else
        days_left="unknown"
    fi
    
    clear
    echo ""
    echo -e "${WHT}Dear user ${YLW}${p}${WHT}, Your subscription will end in ${GRN}${days_left}${WHT} days. Your subscription details -${RST}"
    echo ""
    echo -e "${WHT}Configuration Date${RST}"
    echo -e "${WHT}------------------${RST}"
    echo -e "${WHT}Start Date : ${startdate:-N/A}${RST}"
    echo -e "${WHT}Expiry Date: ${expiry}${RST}"
    echo ""
    echo -e "${WHT}Configuration Quota${RST}"
    echo -e "${WHT}-------------------${RST}"
    echo -e "${WHT}Purchased Traffic : ${quota}${RST}"
    echo -e "${WHT}Consumed Traffic  : ${used_fmt}${RST}"
    echo ""
    read -p "Press Enter to continue..."
}

reset_bandwidth() {
    read -p "$(echo -e "${GRN}Password to reset bandwidth: ${RST}")" pass
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    if [ -n "$port" ]; then
        iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null
        sed -i "s|^$pass|.*|$pass|0|" "$USAGE_DB"
        echo -e "${GRN}Bandwidth reset.${RST}"
    else echo -e "${RED}User not found.${RST}"; fi
    read -p "Press Enter..."
}

speed_test() {
    echo -e "${YLW}Running speed test...${RST}"
    speedtest-cli --simple
    read -p "Press Enter..."
}

backup_data() {
    mkdir -p /root/opudp_backup
    tar -czf /root/opudp_backup/opudp_$(date +%Y%m%d_%H%M%S).tar.gz /etc/zivpn/
    echo -e "${GRN}Backup saved to /root/opudp_backup/${RST}"
    read -p "Press Enter..."
}

restore_backup() {
    echo -e "${YLW}Available backups:${RST}"
    ls -1 /root/opudp_backup/*.tar.gz 2>/dev/null || { echo -e "${RED}No backups found.${RST}"; read -p "Press Enter..."; return; }
    read -p "Enter filename to restore: " file
    if [ -f "$file" ]; then
        systemctl stop zivpn
        tar -xzf "$file" -C /
        systemctl start zivpn
        echo -e "${GRN}Restored.${RST}"
    else echo -e "${RED}File not found.${RST}"; fi
    read -p "Press Enter..."
}

change_port_range() {
    read -p "New start port (current $PORT_START): " new_start
    read -p "New end port (current $PORT_END): " new_end
    if [[ "$new_start" =~ ^[0-9]+$ ]] && [[ "$new_end" =~ ^[0-9]+$ ]]; then
        PORT_START=$new_start; PORT_END=$new_end
        echo -e "${GRN}Port range updated. Restart panel to apply.${RST}"
    else echo -e "${RED}Invalid input.${RST}"; fi
    read -p "Press Enter..."
}

set_conn_limit() {
    read -p "Max connections per user: " limit
    echo "$limit" > /etc/zivpn/conn_limit
    echo -e "${GRN}Connection limit set to $limit (requires iptables connlimit module).${RST}"
    read -p "Press Enter..."
}

trial_user() {
    read -p "$(echo -e "${GRN}Minutes (1-60): ${RST}")" mins
    pass="trial_$(openssl rand -hex 2)"
    port=$(find_free_port)
    if [ -z "$port" ]; then echo -e "${RED}No free ports!${RST}"; read -p "Press Enter..."; return; fi
    if [ -f "$CONFIG" ]; then jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; fi
    exp=$(date -d "+1 days" +%Y-%m-%d)
    startdate=$(date +%Y-%m-%d)
    echo "$pass|$exp|100MB|$port|trial|$startdate" >> "$DB"
    echo "$pass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}Trial Created: ${YLW}$pass${GRN} (Port $port, Expires in $mins mins)${RST}"
    ( sleep $((mins*60))
      remove_tracking "$port"
      [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
      sed -i "/^$pass|/d" "$DB"; sed -i "/^$pass|/d" "$USAGE_DB"
      systemctl restart zivpn 2>/dev/null
    ) &
    read -p "Press Enter..."
}

