# ══════════════════════════════════════════════════════════════
#  BOT CLI MODE  –  called by opudp_bot.py
# ══════════════════════════════════════════════════════════════
if [[ "$1" == "--bot-"* ]]; then
    cmd="${1#--bot-}"; shift
    fetch_geo
    case "$cmd" in
        status)
            get_sysinfo
            echo "🖥 <b>Server Status</b>"
            echo "🌐 IP: $IP"
            echo "📍 Location: $LOC_STR"
            echo "🏢 ISP: $ISP"
            echo "💻 OS: $OS_INFO"
            echo "⚡ Service: $(systemctl is-active zivpn 2>/dev/null)"
            echo "⏱ Uptime: $UPTIME"
            echo "👥 Users: $USER_COUNT"
            echo "👤 Admin: $ADMIN_HANDLE"
            ;;
        adduser)
            result=$(add_user_core "$1" "$2" "$3" "$4")
            echo "$result"
            ;;
        removeuser)
            pass="$1"
            port=$(grep "^${pass}|" "$DB" 2>/dev/null | cut -d'|' -f4)
            [ -n "$port" ] && remove_tracking "$port"
            [ -f "$CONFIG" ] && \
                jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
                > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^${pass}|/d" "$DB" "$USAGE_DB" 2>/dev/null
            systemctl restart zivpn 2>/dev/null
            echo "✅ User removed."
            ;;
        renew)
            pass="$1"; days="$2"
            oldexp=$(grep "^${pass}|" "$DB" | cut -d'|' -f2)
            newexp=$(date -d "${oldexp} +${days} days" +%Y-%m-%d 2>/dev/null)
            awk -F'|' -v p="$pass" -v ne="$newexp" \
                'BEGIN{OFS="|"} $1==p{$2=ne} {print}' "$DB" \
                > /tmp/db_tmp && mv /tmp/db_tmp "$DB"
            echo "✅ Expiry → $newexp"
            ;;
        resetbw)
            pass="$1"
            port=$(grep "^${pass}|" "$DB" | cut -d'|' -f4)
            iptables -Z "UDP_IN_${port}"  2>/dev/null
            iptables -Z "UDP_OUT_${port}" 2>/dev/null
            awk -F'|' -v p="$pass" 'BEGIN{OFS="|"} $1==p{$2=0} {print}' \
                "$USAGE_DB" > /tmp/u_tmp && mv /tmp/u_tmp "$USAGE_DB"
            echo "✅ BW reset."
            ;;
        userinfo)
            pass="$1"
            IFS='|' read -r p expiry quota port hwid used \
                <<< "$(grep "^${pass}|" "$DB")"
            used=${used:-0}
            quota_b=$(quota_to_bytes "$quota")
            remain=$(( quota_b > used ? quota_b - used : 0 ))
            days_left=$(( ( $(date -d "$expiry" +%s 2>/dev/null || echo 0) \
                            - $(date +%s) ) / 86400 ))
            echo "🔍 <b>${pass:0:20}</b>"
            echo "📅 Expiry: $expiry ($days_left days)"
            echo "📊 Quota: $quota"
            echo "📈 Used: $(bytes_human $used)"
            echo "📉 Remain: $(bytes_human $remain)"
            echo "🔒 HWID: $hwid"
            echo "🔌 Port: $port"
            ;;
        userstatus)
            pass="$1"
            line=$(grep "^${pass}|" "$DB")
            [ -z "$line" ] && { echo "❌ Not found."; exit 1; }
            IFS='|' read -r p expiry quota port hwid used <<< "$line"
            used=${used:-0}
            quota_b=$(quota_to_bytes "$quota")
            remain=$(( quota_b > used ? quota_b - used : 0 ))
            days_left=$(( ( $(date -d "$expiry" +%s 2>/dev/null || echo 0) \
                            - $(date +%s) ) / 86400 ))
            sessions=$(ss -un state established 2>/dev/null \
                       | grep -c ":${port} " || echo 0)
            echo "🔑 Password: $p"
            echo "📅 Expiry: $expiry ($days_left days)"
            echo "📊 Quota: $quota"
            echo "📈 Used: $(bytes_human $used)"
            echo "📉 Remain: $(bytes_human $remain)"
            echo "🔒 HWID: $hwid"
            echo "🔌 Port: $port"
            echo "👥 Sessions: $sessions"
            echo "👤 Admin: $ADMIN_HANDLE"
            ;;
        list)
            [ -f "$DB" ] && column -t -s "|" "$DB"
            ;;
        cleanup)
            today=$(date +%Y-%m-%d)
            [ -f "$DB" ] && while IFS='|' read -r pass expiry quota port hwid used; do
                [[ "$expiry" < "$today" ]] && {
                    [ -n "$port" ] && remove_tracking "$port"
                    [ -f "$CONFIG" ] && \
                        jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
                        > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
                    sed -i "/^${pass}|/d" "$DB" "$USAGE_DB" 2>/dev/null
                }
            done < <(cat "$DB")
            systemctl restart zivpn 2>/dev/null
            echo "✅ Cleanup done."
            ;;
        trial)
            mins="${1:-10}"
            hwid="trial_$(openssl rand -hex 4)"
            finalpass="trial_${hwid}"
            port=$(find_free_port)
            exp=$(date -d "+1 day" +%Y-%m-%d 2>/dev/null || date -v +1d +%Y-%m-%d)
            mkdir -p "$(dirname "$CONFIG")"
            [ -f "$CONFIG" ] || echo '{"auth":{"config":[]}}' > "$CONFIG"
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" \
                > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            echo "${finalpass}|${exp}|100MB|${port}|${hwid}|0" >> "$DB"
            echo "${finalpass}|0" >> "$USAGE_DB"
            setup_tracking "$port"
            systemctl restart zivpn 2>/dev/null
            echo "✅ Trial: $finalpass (${mins}m) | Server: $IP | $ADMIN_HANDLE"
            ( sleep $(( mins * 60 ))
              remove_tracking "$port"
              [ -f "$CONFIG" ] && \
                  jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" \
                  > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
              sed -i "/^${finalpass}|/d" "$DB" "$USAGE_DB" 2>/dev/null
              systemctl restart zivpn 2>/dev/null
            ) &
            ;;
        bbr)
            apt-get install -y curl -qq 2>/dev/null
            bash <(curl -4 -s \
                "https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/optimizer.sh" \
                --ipv4)
            echo "✅ BBR installed."
            ;;
        badvpn)
            wget -qN \
                "https://raw.githubusercontent.com/opiran-club/VPS-Optimizer/main/Install/udpgw.sh" \
                && bash udpgw.sh
            echo "✅ BadVPN installed."
            ;;
        *) echo "Unknown: $cmd"; exit 1 ;;
    esac
    exit 0
fi

