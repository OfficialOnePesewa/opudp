udpc_add_user() {
    local username=$1 password=$2 days=$3
    local exp_date=$(date -d "+$days days" +%Y-%m-%d)
    local tmp=$(mktemp)
    jq --arg user "$username" --arg pass "$password" --arg exp "$exp_date" \
        '. + {($user): {"password": $pass, "expiry": $exp}}' "$UDPC_USERS" > "$tmp" 2>/dev/null
    mv "$tmp" "$UDPC_USERS"
    systemctl restart udp-custom --no-block 2>/dev/null &
    echo "$exp_date"
}

udpc_remove_user() {
    local username=$1
    jq "del(.\"$username\")" "$UDPC_USERS" > /tmp/udpc_tmp.json && mv /tmp/udpc_tmp.json "$UDPC_USERS"
    systemctl restart udp-custom --no-block 2>/dev/null &
}

udpc_list_users() {
    if [ -f "$UDPC_USERS" ]; then
        echo -e "\n${CYN}UDP Custom Users:${RST}"
        echo "Username | Password | Expiry"
        echo "--------------------------------"
        jq -r 'to_entries[] | "\(.key) | \(.value.password) | \(.value.expiry)"' "$UDPC_USERS" 2>/dev/null
    else
        echo -e "${RED}No UDP Custom users found.${RST}"
    fi
}

find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|$port|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port+1))
    done
    echo ""
}

service_control() {
    action=$1
    echo -e "${YLW}Select service:${RST}"
    echo "  1) ZIVPN only"
    echo "  2) UDP Custom only"
    echo "  3) Both"
    read -p "Choice: " svc
    case $svc in
        1) systemctl $action zivpn --no-block & ;;
        2) systemctl $action udp-custom --no-block & ;;
        3) systemctl $action zivpn --no-block & systemctl $action udp-custom --no-block & ;;
        *) echo "Invalid";;
    esac
    echo -e "${GRN}Command sent. Check status with option 4.${RST}"
}

