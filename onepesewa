# ── Detect UDP Custom port ───────────────────────────────────────────────────
if [ -f "$UDPC_PORT_FILE" ]; then
    UDPC_PORT=$(cat "$UDPC_PORT_FILE" | tr -d '[:space:]')
else
    UDPC_PORT=$(grep -oP '"listen":\s*":\K\d+' "$UDPC_CFG" 2>/dev/null | head -1)
    [ -z "$UDPC_PORT" ] && UDPC_PORT="36712"
fi

