press_enter() { echo ""; read -rp "  Press [Enter] to continue..." _x; }

find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|${port}|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port + 1))
    done
    echo ""
}

setup_tracking() {
    local port=$1
    iptables -I INPUT  -p udp --dport "$port" -j ACCEPT 2>/dev/null
    iptables -t nat -A PREROUTING -p udp --dport "$port" -j DNAT --to-destination :5667 2>/dev/null
    iptables -N "UDP_IN_${port}"  2>/dev/null
    iptables -N "UDP_OUT_${port}" 2>/dev/null
    iptables -I INPUT  -p udp --dport "$port" -j "UDP_IN_${port}"  2>/dev/null
    iptables -I OUTPUT -p udp --sport "$port" -j "UDP_OUT_${port}" 2>/dev/null
}

remove_tracking() {
    local port=$1
    iptables -D INPUT  -p udp --dport "$port" -j "UDP_IN_${port}"  2>/dev/null
    iptables -D OUTPUT -p udp --sport "$port" -j "UDP_OUT_${port}" 2>/dev/null
    iptables -F "UDP_IN_${port}"  2>/dev/null
    iptables -X "UDP_IN_${port}"  2>/dev/null
    iptables -F "UDP_OUT_${port}" 2>/dev/null
    iptables -X "UDP_OUT_${port}" 2>/dev/null
    iptables -D INPUT -p udp --dport "$port" -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport "$port" -j DNAT --to-destination :5667 2>/dev/null
}

bytes_human() {
    local b=${1:-0}
    if   [ "$b" -ge 1073741824 ]; then printf "%.2f GB" "$(echo "scale=2; $b/1073741824" | bc)"
    elif [ "$b" -ge 1048576 ];    then printf "%.2f MB" "$(echo "scale=2; $b/1048576"    | bc)"
    elif [ "$b" -ge 1024 ];       then printf "%.0f KB" "$(echo "scale=0; $b/1024"       | bc)"
    else printf "%d B" "$b"; fi
}

quota_to_bytes() {
    local q; q=$(echo "$1" | tr '[:lower:]' '[:upper:]')
    if   [[ "$q" =~ ^([0-9]+(\.[0-9]+)?)GB$ ]]; then
         echo $(echo "scale=0; ${BASH_REMATCH[1]}*1073741824/1" | bc)
    elif [[ "$q" =~ ^([0-9]+(\.[0-9]+)?)MB$ ]]; then
         echo $(echo "scale=0; ${BASH_REMATCH[1]}*1048576/1"    | bc)
    elif [[ "$q" =~ ^([0-9]+(\.[0-9]+)?)KB$ ]]; then
         echo $(echo "scale=0; ${BASH_REMATCH[1]}*1024/1"       | bc)
    else echo "0"; fi
}

# ══════════════════════════════════════════════════════════════
#  ADD USER (with optional password, ip & conn limits)
# ══════════════════════════════════════════════════════════════
add_user_core() {
    local basepass="$1" days="$2" quota="$3" hwid="$4" ip_limit="$5" conn_limit="$6" userpass="$7"
    local finalpass
    if [ -n "$userpass" ]; then
        finalpass="$userpass"
        if grep -q "^${finalpass}|" "$DB" 2>/dev/null; then
            echo "ERROR: Password already exists."; return 1
        fi
    else
        finalpass=$(openssl rand -base64 32 | tr -d '/=+' | head -c32)
    fi
    local exp port
    exp=$(date -d "+${days} days" +%Y-%m-%d 2>/dev/null || date -v "+${days}d" +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }
    mkdir -p "$(dirname "$CONFIG")"
    [ -f "$CONFIG" ] || echo '{"auth":{"config":[]}}' > "$CONFIG"
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json \
        && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "${finalpass}|${exp}|${quota}|${port}|${hwid}|0" >> "$DB"
    echo "${finalpass}|0" >> "$USAGE_DB"
    if [ -n "$ip_limit" ] && [ "$ip_limit" -gt 0 ]; then
        echo "${finalpass}|${ip_limit}" >> "$IP_LIMIT_FILE"
    fi
    if [ -n "$conn_limit" ] && [ "$conn_limit" -gt 0 ]; then
        echo "${finalpass}|${conn_limit}" >> "$CONN_LIMIT_FILE"
    fi
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|${finalpass}|${exp}|${port}|${quota}"
}

# ══════════════════════════════════════════════════════════════
#  PAUSE / RESUME MECHANISM
# ══════════════════════════════════════════════════════════════
PAUSEMON_SERVICE="/etc/systemd/system/opudp-pausemon.service"
PAUSEMON_DAEMON="/usr/local/bin/opudp_pausemon.sh"

write_pause_monitor() {
    cat > "$PAUSEMON_DAEMON" <<'DEOF'
#!/bin/bash
PAUSE_DB="/etc/zivpn/paused.db"
DB="/etc/zivpn/users.db"
LOG="/var/log/opudp_pause.log"
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG"; }
while true; do
    if [ -f "$PAUSE_DB" ] && [ -s "$PAUSE_DB" ]; then
        while IFS='|' read -r pass resume_ts; do
            if [ "$(date +%s)" -ge "$resume_ts" ]; then
                port=$(grep "^${pass}|" "$DB" 2>/dev/null | cut -d'|' -f4)
                if [ -n "$port" ]; then
                    iptables -D INPUT -p udp --dport "$port" -j DROP 2>/dev/null
                    log "Auto-resumed user $pass (port $port)"
                fi
                sed -i "/^${pass}|/d" "$PAUSE_DB" 2>/dev/null
            fi
        done < "$PAUSE_DB"
    fi
    sleep 10
done
DEOF
    chmod +x "$PAUSEMON_DAEMON"
}

enable_pause_monitor() {
    write_pause_monitor
    cat > "$PAUSEMON_SERVICE" <<EOF
[Unit]
Description=OP UDP Panel Pause Monitor
After=network.target
[Service]
Type=simple
User=root
ExecStart=$PAUSEMON_DAEMON
Restart=always
RestartSec=10
[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable opudp-pausemon 2>/dev/null
    systemctl restart opudp-pausemon 2>/dev/null
    echo -e "\n  ${GRN}✔ Pause monitor enabled (auto-resume).${RST}"
}

disable_pause_monitor() {
    systemctl stop opudp-pausemon 2>/dev/null
    systemctl disable opudp-pausemon 2>/dev/null
    rm -f "$PAUSEMON_SERVICE" "$PAUSEMON_DAEMON"
    systemctl daemon-reload
    echo -e "\n  ${YLW}⚠ Pause monitor disabled.${RST}"
}

pause_monitor_status() {
    if systemctl is-active --quiet opudp-pausemon 2>/dev/null; then
        echo -e "  ${GRN}● Enabled${RST}"
    else
        echo -e "  ${RED}● Disabled${RST}"
    fi
}

pause_user() {
    local pass="$1" duration="$2"
    if [[ ! "$duration" =~ ^[0-9]+[mhd]$ ]]; then
        echo "ERROR: Invalid duration format (e.g. 30m, 2h, 1d)."
        return 1
    fi
    local unit=${duration: -1} value=${duration%?}
    local seconds=0
    case $unit in
        m) seconds=$(( value * 60 ));;
        h) seconds=$(( value * 3600 ));;
        d) seconds=$(( value * 86400 ));;
    esac
    local port=$(grep "^${pass}|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -z "$port" ] && { echo "ERROR: User not found."; return 1; }
    iptables -I INPUT -p udp --dport "$port" -j DROP 2>/dev/null
    local resume_ts=$(( $(date +%s) + seconds ))
    mkdir -p "$(dirname "$PAUSE_DB")"
    sed -i "/^${pass}|/d" "$PAUSE_DB" 2>/dev/null
    echo "${pass}|${resume_ts}" >> "$PAUSE_DB"
    echo "SUCCESS|${pass}|${port}|${duration}|${resume_ts}"
}

resume_user() {
    local pass="$1"
    local port=$(grep "^${pass}|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -z "$port" ] && { echo "ERROR: User not found."; return 1; }
    iptables -D INPUT -p udp --dport "$port" -j DROP 2>/dev/null
    sed -i "/^${pass}|/d" "$PAUSE_DB" 2>/dev/null
    echo "SUCCESS|${pass}|resumed"
}

get_pause_remaining() {
    local pass="$1"
    local resume_ts=$(grep "^${pass}|" "$PAUSE_DB" 2>/dev/null | cut -d'|' -f2)
    if [ -n "$resume_ts" ]; then
        local now=$(date +%s)
        if [ "$now" -lt "$resume_ts" ]; then
            echo $(( resume_ts - now ))
            return
        fi
    fi
    echo ""
}

pause_remaining_human() {
    local sec=$1
    if [ $sec -ge 86400 ]; then echo "$(( sec / 86400 ))d $(( (sec % 86400) / 3600 ))h"
    elif [ $sec -ge 3600 ]; then echo "$(( sec / 3600 ))h $(( (sec % 3600) / 60 ))m"
    else echo "$(( sec / 60 ))m $(( sec % 60 ))s"
    fi
}

# ══════════════════════════════════════════════════════════════
#  BANDWIDTH MONITORING (systemd service, every 30 seconds)
# ══════════════════════════════════════════════════════════════
BWMON_SERVICE_FILE="/etc/systemd/system/opudp-bwmon.service"
BWMON_DAEMON="/usr/local/bin/opudp_bwmon.sh"

write_bw_monitor() {
    cat > "$BWMON_DAEMON" <<'BWMONEOF'
#!/bin/bash
DB="/etc/zivpn/users.db"
USAGE_DB="/etc/zivpn/usage.db"
COUNTER_CACHE="/etc/zivpn/.bw_cache"
LOG_FILE="/var/log/opudp_bwmon.log"
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"; }
[ ! -f "$DB" ] && exit 0
mkdir -p "$(dirname "$COUNTER_CACHE")"
touch "$COUNTER_CACHE"
update_usage() {
    local pass="$1"
    local in_bytes="$2"
    local out_bytes="$3"
    local current_used=$(grep "^${pass}|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2)
    [ -z "$current_used" ] && current_used=0
    local new_used=$(( current_used + in_bytes + out_bytes ))
    sed -i "/^${pass}|/d" "$USAGE_DB" 2>/dev/null
    echo "${pass}|${new_used}" >> "$USAGE_DB"
}
while true; do
    while IFS='|' read -r pass expiry quota port hwid used; do
        [ -z "$port" ] && continue
        in_bytes=$(iptables -L "UDP_IN_${port}" -v -n -x 2>/dev/null | awk '/Chain/{p=1;next} p && $1~/[0-9]+/{print $2; exit}')
        out_bytes=$(iptables -L "UDP_OUT_${port}" -v -n -x 2>/dev/null | awk '/Chain/{p=1;next} p && $1~/[0-9]+/{print $2; exit}')
        [ -z "$in_bytes" ] && in_bytes=0
        [ -z "$out_bytes" ] && out_bytes=0
        prev_in=$(grep "^${pass}:in:" "$COUNTER_CACHE" 2>/dev/null | cut -d: -f3)
        prev_out=$(grep "^${pass}:out:" "$COUNTER_CACHE" 2>/dev/null | cut -d: -f3)
        [ -z "$prev_in" ] && prev_in=0
        [ -z "$prev_out" ] && prev_out=0
        diff_in=$(( in_bytes - prev_in ))
        diff_out=$(( out_bytes - prev_out ))
        [ $diff_in -lt 0 ] && diff_in=0
        [ $diff_out -lt 0 ] && diff_out=0
        if [ $diff_in -gt 0 ] || [ $diff_out -gt 0 ]; then
            update_usage "$pass" "$diff_in" "$diff_out"
            log "Updated $pass: +${diff_in}in +${diff_out}out"
        fi
        sed -i "/^${pass}:in:/d" "$COUNTER_CACHE" 2>/dev/null
        sed -i "/^${pass}:out:/d" "$COUNTER_CACHE" 2>/dev/null
        echo "${pass}:in:${in_bytes}" >> "$COUNTER_CACHE"
        echo "${pass}:out:${out_bytes}" >> "$COUNTER_CACHE"
        iptables -Z "UDP_IN_${port}" 2>/dev/null
        iptables -Z "UDP_OUT_${port}" 2>/dev/null
    done < "$DB"
    sleep 30
done
BWMONEOF
    chmod +x "$BWMON_DAEMON"
}

enable_bw_monitor() {
    write_bw_monitor
    cat > "$BWMON_SERVICE_FILE" <<SERVEOF
[Unit]
Description=OP UDP Panel Bandwidth Monitor
After=network.target
[Service]
Type=simple
User=root
ExecStart=$BWMON_DAEMON
Restart=always
RestartSec=10
[Install]
WantedBy=multi-user.target
SERVEOF
    systemctl daemon-reload
    systemctl enable opudp-bwmon 2>/dev/null
    systemctl restart opudp-bwmon 2>/dev/null
    echo -e "\n  ${GRN}✔ Bandwidth monitoring enabled (systemd service, updates every 30 sec).${RST}"
}

disable_bw_monitor() {
    systemctl stop opudp-bwmon 2>/dev/null
    systemctl disable opudp-bwmon 2>/dev/null
    rm -f "$BWMON_SERVICE_FILE" "$BWMON_DAEMON"
    systemctl daemon-reload
    echo -e "\n  ${YLW}⚠ Bandwidth monitoring disabled.${RST}"
}

bw_monitor_status() {
    if systemctl is-active --quiet opudp-bwmon 2>/dev/null; then
        echo -e "  ${GRN}● Enabled${RST} (updates every 30 sec)"
    else
        echo -e "  ${RED}● Disabled${RST}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  IP LIMIT ENFORCEMENT (systemd service, every 5 seconds)
# ══════════════════════════════════════════════════════════════
IPMON_SERVICE_FILE="/etc/systemd/system/opudp-ipmon.service"
IPMON_DAEMON="/usr/local/bin/opudp_ip_monitor_daemon.sh"

write_ip_monitor_daemon() {
    cat > "$IPMON_DAEMON" <<'DAEMONEOF'
#!/bin/bash
DB="/etc/zivpn/users.db"
IP_LIMIT_FILE="/etc/zivpn/ip_limits.db"
LOG_FILE="/var/log/opudp_ipmon.log"
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"; }
kill_ip_on_port() {
    local ip="$1" port="$2"
    conntrack -D -p udp --orig-dst "$port" --orig-src "$ip" 2>/dev/null
    conntrack -D -p udp --reply-src "$ip" --reply-dst "$port" 2>/dev/null
    conntrack -D -p udp --dport "$port" --src "$ip" 2>/dev/null
}
while true; do
    [ ! -f "$DB" ] && sleep 5 && continue
    while IFS='|' read -r pass expiry quota port hwid used; do
        [ -z "$port" ] && continue
        ip_limit=$(grep "^${pass}|" "$IP_LIMIT_FILE" 2>/dev/null | cut -d'|' -f2)
        [ -z "$ip_limit" ] || [ "$ip_limit" -eq 0 ] && continue
        ip_file="/etc/zivpn/iplist_${pass}.db"
        [ ! -f "$ip_file" ] && touch "$ip_file"
        temp_file="${ip_file}.tmp"
        while IFS='|' read -r ip ts; do
            if [ $(( $(date +%s) - ts )) -lt 7200 ]; then
                echo "$ip|$ts" >> "$temp_file"
            fi
        done < "$ip_file"
        mv "$temp_file" "$ip_file" 2>/dev/null
        ss -un state established 2>/dev/null | grep ":${port} " | awk '{print $5}' | cut -d: -f1 | sort -u | while read remote_ip; do
            [[ "$remote_ip" =~ ^(127\.|10\.|172\.1[6-9]|172\.2[0-9]|172\.3[0-1]|192\.168\.) ]] && continue
            if ! grep -q "^${remote_ip}|" "$ip_file" 2>/dev/null; then
                current_count=$(wc -l < "$ip_file")
                if [ "$current_count" -lt "$ip_limit" ]; then
                    echo "${remote_ip}|$(date +%s)" >> "$ip_file"
                    log "ALLOWED new IP $remote_ip for $pass (now $((current_count+1))/$ip_limit)"
                else
                    log "KILL second device: $remote_ip for $pass (limit $ip_limit)"
                    kill_ip_on_port "$remote_ip" "$port"
                    iptables -I INPUT -p udp --dport "$port" -s "$remote_ip" -j DROP 2>/dev/null
                    echo "$(date) - KILLED IP: $remote_ip for user $pass (limit $ip_limit)" >> /var/log/opudp_ip_kill.log
                fi
            else
                iptables -D INPUT -p udp --dport "$port" -s "$remote_ip" -j DROP 2>/dev/null
            fi
        done
    done < "$DB"
    sleep 5
done
DAEMONEOF
    chmod +x "$IPMON_DAEMON"
}

enable_ip_monitor() {
    write_ip_monitor_daemon
    cat > "$IPMON_SERVICE_FILE" <<SERVEOF
[Unit]
Description=OP UDP Panel Instant IP Limit Monitor
After=network.target
[Service]
Type=simple
User=root
ExecStart=$IPMON_DAEMON
Restart=always
RestartSec=5
[Install]
WantedBy=multi-user.target
SERVEOF
    systemctl daemon-reload
    systemctl enable opudp-ipmon 2>/dev/null
    systemctl restart opudp-ipmon 2>/dev/null
    echo -e "\n  ${GRN}✔ Instant IP limit monitoring enabled (systemd service, checks every 5 seconds).${RST}"
}

disable_ip_monitor() {
    systemctl stop opudp-ipmon 2>/dev/null
    systemctl disable opudp-ipmon 2>/dev/null
    rm -f "$IPMON_SERVICE_FILE" "$IPMON_DAEMON"
    rm -f /etc/cron.d/opudp_ip_monitor 2>/dev/null
    systemctl daemon-reload
    echo -e "\n  ${YLW}⚠ Instant IP monitoring disabled.${RST}"
}

ip_monitor_status() {
    if systemctl is-active --quiet opudp-ipmon 2>/dev/null; then
        echo -e "  ${GRN}● Enabled${RST} (systemd service, runs every 5 sec)"
    else
        echo -e "  ${RED}● Disabled${RST}"
    fi
}

reset_user_ips() {
    local pass="$1"
    local port=$(grep "^${pass}|" "$DB" 2>/dev/null | cut -d'|' -f4)
    if [ -n "$port" ]; then
