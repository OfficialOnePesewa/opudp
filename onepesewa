# Handle cron mode
if [ "$1" = "--update-usage" ]; then
    update_usage_db
    exit 0
fi

# Initialize
touch "$DB" "$USAGE_DB" 2>/dev/null
fetch_geo

# Main loop
while true; do
    install_cron
    banner
    show_menu
    read -p "$(echo -e "${CYN}Choose [0-99]: ${RST}")" opt
    case $opt in
        1) systemctl start zivpn && echo -e "${GRN}Started.${RST}" || echo -e "${RED}Failed.${RST}"; read -p "Press Enter..." ;;
        2) systemctl stop zivpn && echo -e "${RED}Stopped.${RST}" || echo -e "${RED}Failed.${RST}"; read -p "Press Enter..." ;;
        3) systemctl restart zivpn && echo -e "${GRN}Restarted.${RST}" || echo -e "${RED}Failed.${RST}"; read -p "Press Enter..." ;;
        4) systemctl status zivpn; read -p "Press Enter..." ;;
        5) [ -f "$DB" ] && { echo -e "\n${CYN}Password | Expiry | Quota | Port | DeviceID${RST}"; column -t -s "|" "$DB"; } || echo -e "${RED}No users.${RST}"; read -p "Press Enter..." ;;
        6) add_user ;;
        7) remove_user ;;
        8) renew_user ;;
        9) cleanup_expired ;;
        10) show_usage_stats ;;
        11) show_usage_stats ;;
        12) reset_bandwidth ;;
        13) speed_test ;;
        14) journalctl -u zivpn -f ;;
        15) backup_data ;;
        16) restore_backup ;;
        17) change_port_range ;;
        18) echo -e "\n${YLW}Updating panel...${RST}"
             wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa
             chmod +x /usr/local/bin/onepesewa
             echo -e "${GRN}Update complete! Restarting...${RST}"; sleep 2; exec onepesewa ;;
        19) set_conn_limit ;;
        20) trial_user ;;
        21) user_info ;;
        99) systemctl stop zivpn 2>/dev/null
            rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa /etc/cron.d/opudp_bandwidth
            echo -e "${RED}Uninstalled.${RST}"; exit ;;
        0) goodbye; exit ;;
        *) echo -e "${RED}Invalid.${RST}"; read -p "Press Enter..." ;;
    esac
done
