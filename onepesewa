do_list() {
    echo -e "\n  ${CYN}${BOLD}◈  Registered Users${RST}\n"
    if [ ! -f "$DB" ] || [ ! -s "$DB" ]; then
        echo -e "  ${YLW}⚠  No users found.${RST}"
        press_enter; return
    fi
    local today; today=$(date +%Y-%m-%d)
    echo -e "  ${WHT}╔══════════════════════════════════════════════════════════════════╗${RST}"
    printf  "  ${WHT}║${RST}  ${BOLD}%-28s %-12s %-8s %-6s %-8s${RST}  ${WHT}║${RST}\n" \
            "PASSWORD" "EXPIRY" "QUOTA" "PORT" "STATUS"
    echo -e "  ${WHT}╠══════════════════════════════════════════════════════════════════╣${RST}"
    while IFS='|' read -r pass exp quota port hwid used; do
        local color status
        if [[ "$exp" < "$today" ]]; then color="$RED"; status="Expired"
        else color="$GRN"; status="Active"; fi
        printf  "  ${WHT}║${RST}  %-28s %-12s %-8s %-6s ${color}%-8s${RST}  ${WHT}║${RST}\n" \
                "${pass:0:28}" "$exp" "$quota" "$port" "$status"
    done < "$DB"
    echo -e "  ${WHT}╚══════════════════════════════════════════════════════════════════╝${RST}"
    echo ""
    press_enter
}

