    printf  "  ${WHT}в•‘${RST}  ${BOLD}%-24s %-12s %-8s %-10s %-10s %-7s${RST}  ${WHT}в•‘${RST}\n" \
            "USER" "EXPIRY" "QUOTA" "USED" "REMAIN" "STATUS"
    echo -e "  ${WHT}в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј${RST}"
    while IFS='|' read -r pass exp quota port hwid used; do
        local used_b="${used:-0}"
        local quota_b; quota_b=$(quota_to_bytes "$quota")
        local remain_b=$(( quota_b > used_b ? quota_b - used_b : 0 ))
        local used_h;   used_h=$(bytes_human "$used_b")
        local remain_h; remain_h=$(bytes_human "$remain_b")
        local status color
        if [[ "$exp" < "$today" ]]; then
            status="Expired"; color="$RED"
        elif [ "$quota_b" -gt 0 ] && [ "$used_b" -ge "$quota_b" ]; then
            status="Quota!";  color="$RED"
        else
            status="OK";      color="$GRN"
        fi
        printf  "  ${WHT}в•‘${RST}  %-24s %-12s %-8s %-10s %-10s ${color}%-7s${RST}  ${WHT}в•‘${RST}\n" \
                "${pass:0:24}" "$exp" "$quota" "$used_h" "$remain_h" "$status"
    done < "$DB"
    echo -e "  ${WHT}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${RST}"
    echo ""
    press_enter
}

# [12] RESET BANDWIDTH
do_reset_bw() {
    echo -e "\n  ${YLW}${BOLD}в—Ҳ  Reset Bandwidth${RST}\n"
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && {
        echo -e "  ${YLW}No users.${RST}"; press_enter; return
    }
    echo -ne "  ${GRN}Password (or ALL to reset all): ${RST}"; read -r target
    [ -z "$target" ] && { echo -e "  ${RED}вңҳ  Aborted.${RST}"; press_enter; return; }
    if [ "$target" = "ALL" ]; then
        while IFS='|' read -r pass exp quota port hwid used; do
            iptables -Z "UDP_IN_${port}"  2>/dev/null
            iptables -Z "UDP_OUT_${port}" 2>/dev/null
        done < "$DB"
        awk -F'|' 'BEGIN{OFS="|"} {$2=0; print}' "$USAGE_DB" \
            > /tmp/u_tmp && mv /tmp/u_tmp "$USAGE_DB"
        echo -e "\n  ${GRN}вң”  All bandwidth counters reset.${RST}"
    else
        grep -q "^${target}|" "$DB" 2>/dev/null || {
            echo -e "  ${RED}вңҳ  Not found.${RST}"; press_enter; return
        }
        local port; port=$(grep "^${target}|" "$DB" | cut -d'|' -f4)
        iptables -Z "UDP_IN_${port}"  2>/dev/null
        iptables -Z "UDP_OUT_${port}" 2>/dev/null
        awk -F'|' -v p="$target" 'BEGIN{OFS="|"} $1==p{$2=0} {print}' \
            "$USAGE_DB" > /tmp/u_tmp && mv /tmp/u_tmp "$USAGE_DB"
        echo -e "\n  ${GRN}вң”  Reset for ${YLW}${target}${RST}"
    fi
    press_enter
}

