        printf "${CYN}│${RST}  ${BOLD}%-30s %-12s %-8s %s${RST}\n" "Password" "Expiry" "Quota" "HWID"
        echo -e "${CYN}│${RST}  ──────────────────────────────────────────────────────────────"
        while IFS='|' read -r pass expiry quota port hwid; do
            printf "${CYN}│${RST}  %-30s %-12s %-8s %s\n" \
                "${pass:0:28}" "$expiry" "$quota" "${hwid:0:20}"
        done < "$DB"
    fi
    echo -e "${CYN}╰──────────────────────────────────────────────────────────────────╯${RST}"
    read -rp "Press Enter..."
}

cleanup_interactive() {
    echo -e "\n${YLW}Running cleanup of expired users...${RST}"
    local today count=0
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port hwid; do
        [ -z "$pass" ] && continue
        if [[ "$expiry" < "$today" ]]; then
            remove_user_core "$pass"
            echo -e "  ${RED}✗${RST} Removed: $pass (expired $expiry)"
            count=$((count+1))
        fi
    done < <(cat "$DB")
    systemctl restart zivpn 2>/dev/null
    echo -e "\n${GRN}✅ Cleanup complete. $count user(s) removed.${RST}"
    read -rp "Press Enter..."
}

trial_user_interactive() {
    echo -ne "${GRN}Trial minutes (1-60): ${RST}"; read -r mins
    if ! [[ "$mins" =~ ^[0-9]+$ ]] || [ "$mins" -lt 1 ] || [ "$mins" -gt 60 ]; then
        echo -e "${RED}❌ Invalid value.${RST}"; read -rp "Press Enter..."; return
    fi
    local hwid basepass finalpass port exp
    hwid="trial_$(openssl rand -hex 4)"
    basepass="trial"
    finalpass="${basepass}_${hwid}"
    port=$(find_free_port)
    if [ -z "$port" ]; then
        echo -e "${RED}❌ No free port.${RST}"; read -rp "Press Enter..."; return
    fi
    exp=$(date -d "+1 day" +%Y-%m-%d)
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" \
        > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "${finalpass}|${exp}|100MB|${port}|${hwid}" >> "$DB"
    echo "${finalpass}|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    get_sysinfo
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│  🧪 ${BOLD}TRIAL USER CREATED${RST}${CYN}                                 │${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST} ${YLW}🔑 Password :${RST} ${WHT}${BOLD}$finalpass${RST}"
    echo -e "${CYN}│${RST} ${YLW}🌍 Server   :${RST} ${WHT}$IP${RST}"
    echo -e "${CYN}│${RST} ${YLW}⏳ Duration :${RST} ${WHT}$mins minute(s)${RST}"
    echo -e "${CYN}│${RST} ${YLW}📊 Quota    :${RST} ${WHT}100MB${RST}"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}"
    # Auto-remove in background
    ( sleep $((mins*60))
      remove_tracking "$port"
      jq --arg p "$finalpass" '.auth.config -= [$p]' "$CONFIG" \
          > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
      grep -v "^$(esc "$finalpass")|" "$DB"       > /tmp/db_tmp && mv /tmp/db_tmp "$DB"
      grep -v "^$(esc "$finalpass")|" "$USAGE_DB" > /tmp/ub_tmp && mv /tmp/ub_tmp "$USAGE_DB"
      systemctl restart zivpn 2>/dev/null
    ) &
    read -rp "Press Enter..."
}

