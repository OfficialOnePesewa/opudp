# --- Helper functions ---
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        if ! grep -q "|$port|" "$DB" 2>/dev/null; then
            echo $port; return
        fi
        port=$((port+1))
    done
    echo ""
}

quota_to_bytes() {
    local q=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    if [[ "$q" =~ ^([0-9.]+)gb$ ]]; then echo "${BASH_REMATCH[1]} * 1073741824" | bc | cut -d. -f1
    elif [[ "$q" =~ ^([0-9.]+)mb$ ]]; then echo "${BASH_REMATCH[1]} * 1048576" | bc | cut -d. -f1
    else echo "0"; fi
}

format_bytes() {
    local b=$1
    if [ $b -ge 1073741824 ]; then echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [ $b -ge 1048576 ]; then echo "$(echo "scale=2; $b/1048576" | bc) MB"
    elif [ $b -ge 1024 ]; then echo "$(echo "scale=2; $b/1024" | bc) KB"
    else echo "$b B"; fi
}

setup_tracking() {
    local port=$1
    iptables -I INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
    iptables -N UDP_IN_$port 2>/dev/null; iptables -N UDP_OUT_$port 2>/dev/null
    iptables -I INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
}

remove_tracking() {
    local port=$1
    iptables -D INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
    iptables -F UDP_IN_$port 2>/dev/null; iptables -X UDP_IN_$port 2>/dev/null
    iptables -F UDP_OUT_$port 2>/dev/null; iptables -X UDP_OUT_$port 2>/dev/null
    iptables -D INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
}

# --- Telegram functions ---
send_telegram_message() {
    local chat_id="$1"
    local message="$2"
    local token=$(cat /etc/zivpn/telegram_token 2>/dev/null)
    if [ -z "$token" ]; then return; fi
    curl -s -X POST "https://api.telegram.org/bot$token/sendMessage" \
        -d "chat_id=$chat_id" \
        -d "text=$message" \
        -d "parse_mode=HTML" >/dev/null
}

is_admin() {
    local tg_id="$1"
    grep -q "^$tg_id|" "$ADMINS_DB" 2>/dev/null
}

is_owner() {
    local tg_id="$1"
    grep -q "^$tg_id|owner|" "$ADMINS_DB" 2>/dev/null
}

telegram_setup() {
    echo -e "\n${YLW}╭────────────────── TELEGRAM BOT SETUP ──────────────────╮${RST}"
    echo -e "${WHT}1. Create a bot with @BotFather and get the token.${RST}"
    echo -e "${WHT}2. Paste the token below.${RST}"
    read -p "$(echo -e "${GRN}Bot Token: ${RST}")" token
    echo "$token" > /etc/zivpn/telegram_token
    chmod 600 /etc/zivpn/telegram_token
    echo -e "${GRN}Token saved!${RST}"
    echo -e "${WHT}Now add yourself as the owner (Option 23).${RST}"
    read -p "Press Enter to continue..."
}

add_admin() {
    read -p "$(echo -e "${GRN}Telegram Chat ID: ${RST}")" tg_id
    if [ ! -s "$ADMINS_DB" ]; then
        # First admin is owner
        read -p "$(echo -e "${GRN}Name: ${RST}")" name
        echo "$tg_id|owner|$name" > "$ADMINS_DB"
        echo -e "${GRN}Owner added!${RST}"
    else
        if is_owner "$(whoami 2>/dev/null)" 2>/dev/null || [ "$1" = "owner_override" ]; then
            read -p "$(echo -e "${GRN}Name: ${RST}")" name
            echo "$tg_id|admin|$name" >> "$ADMINS_DB"
            echo -e "${GRN}Sub-admin added!${RST}"
        else
            echo -e "${RED}Only owner can add admins via panel.${RST}"
        fi
    fi
    read -p "Press Enter to continue..."
}

list_admins() {
    echo -e "\n${CYN}Telegram Admins:${RST}"
    echo "ID | Role | Name"
    cat "$ADMINS_DB" 2>/dev/null || echo "No admins."
    read -p "Press Enter to continue..."
}

# --- Core user management (used by both menu and bot) ---
add_user_core() {
    local basepass="$1" days="$2" quota="$3" devid="$4"
    if [ -n "$devid" ]; then finalpass="${basepass}_${devid}"; else finalpass="$basepass"; devid="None"; fi
    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")
    startdate=$(date +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }
    [ -f "$CONFIG" ] && jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$devid|$startdate" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|$finalpass|$exp|$port|$quota"
}

remove_user_core() {
    local pass="$1"
    port=$(grep "^$pass|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^$pass|/d" "$DB" 2>/dev/null; sed -i "/^$pass|/d" "$USAGE_DB" 2>/dev/null
    sed -i "/^$pass|/d" "$TELEGRAM_DB" 2>/dev/null; sed -i "/^$pass|/d" "$LAST_SENT_DB" 2>/dev/null
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|User removed"
}

renew_user_core() {
    local pass="$1" days="$2"
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    [ -z "$oldexp" ] && { echo "ERROR|User not found"; return 1; }
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d 2>/dev/null || echo "$oldexp")
    sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
    echo "SUCCESS|Expiry extended to $newexp"
}

reset_bw_core() {
    local pass="$1"
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    [ -z "$port" ] && { echo "ERROR|User not found"; return 1; }
    iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null
    sed -i "s|^$pass|.*|$pass|0|" "$USAGE_DB"
    echo "SUCCESS|Bandwidth reset"
}

get_user_info() {
    local pass="$1"
    user_data=$(grep "^$pass|" "$DB" 2>/dev/null)
    [ -z "$user_data" ] && { echo "ERROR|User not found"; return 1; }
    IFS='|' read -r p expiry quota port deviceid startdate <<< "$user_data"
    used_bytes=$(grep "^$pass|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2)
    used_bytes=${used_bytes:-0}
    quota_bytes=$(quota_to_bytes "$quota")
    remaining=$((quota_bytes - used_bytes))
    [ $remaining -lt 0 ] && remaining=0
    used_fmt=$(format_bytes $used_bytes)
    remaining_fmt=$(format_bytes $remaining)
    days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
    echo "SUCCESS|$pass|$expiry|$quota|$used_fmt|$remaining_fmt|$days_left|$deviceid|$port|$startdate"
}

# --- Bot command processor ---
process_bot_command() {
    local chat_id="$1" text="$2"
    local cmd=$(echo "$text" | awk '{print $1}')
    local args=($(echo "$text" | cut -d' ' -f2-))

    # /start for regular users
    if [[ "$text" =~ ^/start[[:space:]]+(.+)$ ]]; then
        pass="${BASH_REMATCH[1]}"
        if grep -q "^$pass|" "$DB"; then
            grep -v "^$pass|" "$TELEGRAM_DB" 2>/dev/null > /tmp/tg_tmp
            echo "$pass|$chat_id" >> /tmp/tg_tmp
            mv /tmp/tg_tmp "$TELEGRAM_DB"
            send_telegram_message "$chat_id" "✅ Your VPN account has been linked! You'll receive usage updates here."
        else
            send_telegram_message "$chat_id" "❌ Invalid password."
        fi
        return
    fi

    # Admin commands require authorization
    if ! is_admin "$chat_id"; then
        # Not an admin, maybe show help?
        if [[ "$cmd" == "/help" ]]; then
            send_telegram_message "$chat_id" "Commands for users: /start <password> - link your account"
        else
            send_telegram_message "$chat_id" "⛔ You are not authorized to use admin commands."
        fi
        return
    fi

    case "$cmd" in
        /help)
            local help_msg="🔧 <b>Admin Commands</b>%0A"
            help_msg+="/status - Server status%0A"
            help_msg+="/listusers - List all users%0A"
            help_msg+="/userinfo &lt;pass&gt; - User details%0A"
            help_msg+="/adduser &lt;basepass&gt; &lt;days&gt; &lt;quota&gt; [deviceid]%0A"
            help_msg+="/removeuser &lt;pass&gt;%0A"
            help_msg+="/renew &lt;pass&gt; &lt;days&gt;%0A"
            help_msg+="/resetbw &lt;pass&gt;%0A"
            help_msg+="/cleanup - Remove expired%0A"
            if is_owner "$chat_id"; then
                help_msg+="%0A👑 <b>Owner Commands</b>%0A"
                help_msg+="/addadmin &lt;tgid&gt; &lt;name&gt;%0A"
                help_msg+="/removeadmin &lt;tgid&gt;%0A"
                help_msg+="/listadmins%0A"
            fi
            send_telegram_message "$chat_id" "$help_msg"
            ;;
        /status)
            local msg="🖥 <b>Server Status</b>%0A"
            msg+="🌐 IP: $IP%0A"
            msg+="📍 Location: $CITY, $COUNTRY%0A"
            msg+="🏢 ISP: $ISP%0A"
            msg+="⚡ Service: $(systemctl is-active zivpn)%0A"
            msg+="⏱ Uptime: $UPTIME%0A"
            msg+="👥 Active users: $USER_COUNT"
            send_telegram_message "$chat_id" "$msg"
            ;;
        /listusers)
            local list=""
            while IFS='|' read -r pass expiry quota port dev start; do
                list+="$pass | $expiry | $quota%0A"
            done < "$DB"
            [ -z "$list" ] && list="No users found."
            send_telegram_message "$chat_id" "👥 <b>Users:</b>%0A$list"
            ;;
        /userinfo)
            local pass="${args[0]}"
            result=$(get_user_info "$pass")
            if [[ "$result" == ERROR* ]]; then
                send_telegram_message "$chat_id" "❌ User not found."
            else
                IFS='|' read -r status p expiry quota used remain days dev port start <<< "$result"
                local msg="🔍 <b>User: ${p:0:20}</b>%0A"
                msg+="📅 Expiry: $expiry ($days days left)%0A"
                msg+="📊 Quota: $quota%0A"
                msg+="📈 Used: $used%0A"
                msg+="📉 Remaining: $remain%0A"
                msg+="📱 Device: $dev%0A"
                msg+="🔌 Port: $port%0A"
                msg+="📆 Start: $start"
                send_telegram_message "$chat_id" "$msg"
            fi
            ;;
        /adduser)
            if [ ${#args[@]} -lt 3 ]; then
                send_telegram_message "$chat_id" "Usage: /adduser &lt;basepass&gt; &lt;days&gt; &lt;quota&gt; [deviceid]"
                return
            fi
            basepass="${args[0]}"; days="${args[1]}"; quota="${args[2]}"; devid="${args[3]}"
            result=$(add_user_core "$basepass" "$days" "$quota" "$devid")
            if [[ "$result" == SUCCESS* ]]; then
                IFS='|' read -r status finalpass exp port quota <<< "$result"
                send_telegram_message "$chat_id" "✅ User created:%0A🔑 Password: <code>$finalpass</code>%0A📡 Port: $port%0A📅 Expiry: $exp%0A📊 Quota: $quota"
            else
                send_telegram_message "$chat_id" "❌ Failed: $result"
            fi
            ;;
        /removeuser)
            pass="${args[0]}"
            result=$(remove_user_core "$pass")
            send_telegram_message "$chat_id" "$result"
            ;;
        /renew)
            pass="${args[0]}"; days="${args[1]}"
            result=$(renew_user_core "$pass" "$days")
            send_telegram_message "$chat_id" "$result"
            ;;
        /resetbw)
            pass="${args[0]}"
            result=$(reset_bw_core "$pass")
            send_telegram_message "$chat_id" "$result"
            ;;
        /cleanup)
            cleanup_expired > /dev/null
            send_telegram_message "$chat_id" "✅ Expired users cleaned."
            ;;
        /addadmin)
            if ! is_owner "$chat_id"; then
                send_telegram_message "$chat_id" "⛔ Owner only."
                return
            fi
            tg_id="${args[0]}"; name="${args[1]}"
            grep -v "^$tg_id|" "$ADMINS_DB" > /tmp/adm_tmp
            echo "$tg_id|admin|$name" >> /tmp/adm_tmp
            mv /tmp/adm_tmp "$ADMINS_DB"
            send_telegram_message "$chat_id" "✅ Admin $name added."
            ;;
        /removeadmin)
            if ! is_owner "$chat_id"; then
                send_telegram_message "$chat_id" "⛔ Owner only."
                return
            fi
            tg_id="${args[0]}"
            sed -i "/^$tg_id|/d" "$ADMINS_DB"
            send_telegram_message "$chat_id" "✅ Admin removed."
            ;;
        /listadmins)
            if ! is_owner "$chat_id"; then return; fi
            list=$(cat "$ADMINS_DB" 2>/dev/null | sed 's/|/ - /g')
            send_telegram_message "$chat_id" "👑 Admins:%0A$list"
            ;;
    esac
}

# --- Bot listener ---
start_telegram_listener() {
    local token=$(cat /etc/zivpn/telegram_token 2>/dev/null)
    if [ -z "$token" ]; then return; fi
    (
        local offset=0
        while true; do
            updates=$(curl -s "https://api.telegram.org/bot$token/getUpdates?offset=$offset&timeout=30")
            if echo "$updates" | grep -q '"ok":true'; then
                echo "$updates" | jq -c '.result[]' 2>/dev/null | while read update; do
                    update_id=$(echo "$update" | jq -r '.update_id')
                    offset=$((update_id + 1))
                    message=$(echo "$update" | jq -r '.message')
                    if [ "$message" != "null" ]; then
                        text=$(echo "$message" | jq -r '.text')
                        chat_id=$(echo "$message" | jq -r '.chat.id')
                        process_bot_command "$chat_id" "$text"
                    fi
                done
            fi
            sleep 2
        done
    ) &
    echo $! > /var/run/opudp_tg_listener.pid
}

# --- Update usage daemon (includes quota enforcement) ---
update_usage_db() {
    while IFS='|' read -r pass expiry quota port deviceid startdate; do
        if [ -n "$port" ] && [ "$port" != "None" ]; then
            in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
            out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
            total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
            prev=$(grep "^$pass|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2)
            prev=${prev:-0}
            grep -v "^$pass|" "$USAGE_DB" 2>/dev/null > /tmp/usage_tmp
            echo "$pass|$total" >> /tmp/usage_tmp
            mv /tmp/usage_tmp "$USAGE_DB"
            # Notification on first activity
            last_sent=$(grep "^$pass|" "$LAST_SENT_DB" 2>/dev/null | cut -d'|' -f2)
            current_time=$(date +%s)
            if [ $total -gt $prev ] && [ $((total - prev)) -gt 1024 ]; then
                if [ -z "$last_sent" ] || [ $((current_time - last_sent)) -gt 3600 ]; then
                    chat_id=$(grep "^$pass|" "$TELEGRAM_DB" 2>/dev/null | cut -d'|' -f2)
                    if [ -n "$chat_id" ]; then
                        used_fmt=$(format_bytes $total)
                        quota_bytes=$(quota_to_bytes "$quota")
                        remaining=$((quota_bytes - total))
                        [ $remaining -lt 0 ] && remaining=0
                        remaining_fmt=$(format_bytes $remaining)
                        days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
                        message="🔔 <b>VPN Session Started</b>%0A%0A"
                        message+="👤 <b>User:</b> ${pass:0:15}...%0A"
                        message+="📅 <b>Expiry:</b> $expiry ($days_left days)%0A"
                        message+="📊 <b>Quota:</b> $quota%0A"
                        message+="📈 <b>Used:</b> $used_fmt%0A"
                        message+="📉 <b>Remaining:</b> $remaining_fmt%0A"
                        message+="🌐 <b>Server:</b> $IP%0A"
                        message+="📍 <b>Location:</b> $CITY, $COUNTRY"
                        send_telegram_message "$chat_id" "$message"
                        grep -v "^$pass|" "$LAST_SENT_DB" 2>/dev/null > /tmp/last_tmp
                        echo "$pass|$current_time" >> /tmp/last_tmp
                        mv /tmp/last_tmp "$LAST_SENT_DB"
                    fi
                fi
            fi
            # Quota enforcement
            quota_bytes=$(quota_to_bytes "$quota")
            if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ]; then
                if grep -q "^$pass|" "$DB" && ! grep -q "^$pass|.*|PAUSED" "$DB"; then
                    sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
                    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
                    systemctl restart zivpn 2>/dev/null
                    echo "$(date): User $pass paused - quota exceeded" >> /var/log/opudp.log
                    chat_id=$(grep "^$pass|" "$TELEGRAM_DB" 2>/dev/null | cut -d'|' -f2)
                    [ -n "$chat_id" ] && send_telegram_message "$chat_id" "⛔ Your VPN quota has been exhausted. Service paused."
                fi
            fi
        fi
    done < "$DB"
}

start_usage_daemon() {
    if [ -f "$DAEMON_PID_FILE" ]; then
        old_pid=$(cat "$DAEMON_PID_FILE")
        kill $old_pid 2>/dev/null
        rm -f "$DAEMON_PID_FILE"
    fi
    (
        while true; do
            /usr/local/bin/onepesewa --update-usage
            sleep 10
        done
    ) &
    echo $! > "$DAEMON_PID_FILE"
}

stop_usage_daemon() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null && rm -f "$DAEMON_PID_FILE"
    [ -f /var/run/opudp_tg_listener.pid ] && kill $(cat /var/run/opudp_tg_listener.pid) 2>/dev/null && rm -f /var/run/opudp_tg_listener.pid
}

# Handle daemon mode
if [ "$1" = "--update-usage" ]; then
