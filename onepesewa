                journalctl -u opudp-bot -n 20 --no-pager 2>/dev/null
                press_enter
                ;;
            5)
                echo -ne "\n  ${GRN}Chat ID to add: ${RST}"; read -r chatid
                [[ ! "$chatid" =~ ^-?[0-9]+$ ]] && {
                    echo -e "  ${RED}✘  Invalid.${RST}"; press_enter; continue
                }
