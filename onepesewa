            tmp=$(mktemp)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$ZIVPN_CFG" > "$tmp" && mv "$tmp" "$ZIVPN_CFG"
            echo "$finalpass|$exp|$quota|$port|${devid:-None}|$(date +%Y-%m-%d)" >> "$ZIVPN_DB"
            echo "$finalpass|0" >> "$ZIVPN_USAGE"
            systemctl restart zivpn 2>/dev/null || true
            echo "SUCCESS|$finalpass|$exp|$port|$quota"
            ;;
        removeuser)
            pass="$1"
            tmp=$(mktemp)
            jq --arg p "$pass" '.auth.config -= [$p]' "$ZIVPN_CFG" > "$tmp" && mv "$tmp" "$ZIVPN_CFG"
            sed -i "/^$pass|/d" "$ZIVPN_DB" "$ZIVPN_USAGE" 2>/dev/null || true
            systemctl restart zivpn 2>/dev/null || true
            echo "✅ User $pass removed."
            ;;
        renew)
            pass="$1"; days="$2"
            oldexp=$(grep "^$pass|" "$ZIVPN_DB" | head -1 | cut -d'|' -f2)
            newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d 2>/dev/null || echo "N/A")
            sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$ZIVPN_DB"
            echo "✅ Expiry extended to $newexp"
            ;;
        cleanup)
            today=$(date +%Y-%m-%d); count=0
            while IFS='|' read -r p exp rest; do
                [[ "$exp" < "$today" ]] || continue
                tmp=$(mktemp)
                jq --arg p "$p" '.auth.config -= [$p]' "$ZIVPN_CFG" > "$tmp" && mv "$tmp" "$ZIVPN_CFG"
                sed -i "/^$p|/d" "$ZIVPN_DB" "$ZIVPN_USAGE" 2>/dev/null || true
                count=$(( count + 1 ))
            done < "$ZIVPN_DB"
            systemctl restart zivpn 2>/dev/null || true
            echo "✅ Cleanup done. Removed $count expired user(s)."
            ;;
        *) echo "Unknown bot command: $cmd"; exit 1 ;;
    esac
    exit 0
fi

