    local backup_file="/tmp/opudp_backup_$(date +%Y%m%d_%H%M%S).tar.gz"
    tar -czf "$backup_file" /etc/zivpn 2>/dev/null
    echo -e "${GRN}Backup saved to ${WHT}$backup_file${RST}"
    read -p "Press Enter..."
