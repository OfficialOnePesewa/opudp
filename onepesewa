MAG='\e[1;35m' CYN='\e[1;36m' WHT='\e[1;37m' RST='\e[0m' DIM='\e[2m'

command -v jq &>/dev/null || apt-get install -y jq -qq 2>/dev/null

# ── Geo lookup ───────────────────────────────────────────────────────────────
fetch_geo() {
    if [ -f "$CACHE_FILE" ] && \
       [ $(( $(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0) )) -lt $CACHE_TTL ]; then
        source "$CACHE_FILE"; return
    fi
    printf "${DIM}Fetching location...${RST}"
    GEO=""
    for api in "https://ipapi.co/json/" "https://ipinfo.io/json" "https://ifconfig.co/json"; do
        GEO=$(curl -4 -s --max-time 5 "$api" 2>/dev/null)
        echo "$GEO" | grep -q '"ip"' && break
    done
    if [ -z "$GEO" ]; then
        IP=$(curl -4 -s --max-time 5 ifconfig.me 2>/dev/null || echo "N/A")
        CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"
        COUNTRY_CODE=""; ZIP=""
    else
        IP=$(echo "$GEO"           | grep -oP '"ip":\s*"\K[^"]+' | head -1)
        CITY=$(echo "$GEO"         | grep -oP '"city":\s*"\K[^"]+' | head -1)
        COUNTRY=$(echo "$GEO"      | grep -oP '"country_name":\s*"\K[^"]+' | head -1)
        [ -z "$COUNTRY" ] && COUNTRY=$(echo "$GEO" | grep -oP '"country":\s*"\K[^"]+' | head -1)
        COUNTRY_CODE=$(echo "$GEO" | grep -oP '"country_code":\s*"\K[^"]+' | head -1 | tr '[:upper:]' '[:lower:]')
        ZIP=$(echo "$GEO"          | grep -oP '"postal":\s*"\K[^"]+' | head -1)
        ISP=$(echo "$GEO"          | grep -oP '"org":\s*"\K[^"]+' | head -1)
    fi
    [ -z "$IP" ]      && IP="N/A"
    [ -z "$CITY" ]    && CITY="Unknown"
    [ -z "$COUNTRY" ] && COUNTRY="Unknown"
    [ -z "$ISP" ]     && ISP="Unknown"
    printf "\r\033[K"
    cat > "$CACHE_FILE" <<EOF
IP="$IP"; CITY="$CITY"; COUNTRY="$COUNTRY"
COUNTRY_CODE="$COUNTRY_CODE"; ZIP="$ZIP"; ISP="$ISP"
EOF
}

flag() {
    case $1 in
        us) echo "🇺🇸" ;; gb) echo "🇬🇧" ;; ca) echo "🇨🇦" ;; au) echo "🇦🇺" ;;
        de) echo "🇩🇪" ;; fr) echo "🇫🇷" ;; nl) echo "🇳🇱" ;; in) echo "🇮🇳" ;;
        jp) echo "🇯🇵" ;; br) echo "🇧🇷" ;; za) echo "🇿🇦" ;; sg) echo "🇸🇬" ;;
        gh) echo "🇬🇭" ;; ng) echo "🇳🇬" ;; ke) echo "🇰🇪" ;; il) echo "🇮🇱" ;;
        *) echo "🌍" ;;
    esac
}

# ── Sync users.json → config.json auth.config ────────────────────────────────
sync_udpc_config() {
    [ ! -f "$UDPC_USERFILE" ] && return
    [ ! -f "$UDPC_CFG" ]      && return
    local auth_array
    auth_array=$(jq -r 'to_entries[] | "\(.key):\(.value.password)"' "$UDPC_USERFILE" 2>/dev/null \
        | jq -R '.' | jq -s '.' 2>/dev/null || echo '[]')
    local tmp; tmp=$(mktemp)
    jq --argjson arr "$auth_array" '.auth.config = $arr' "$UDPC_CFG" > "$tmp" 2>/dev/null \
        && mv "$tmp" "$UDPC_CFG" || rm -f "$tmp"
}

# ── System + service info ─────────────────────────────────────────────────────
get_sysinfo() {
    OS_INFO=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
    ARCH=$(uname -m)
    OS_FULL="$OS_INFO $ARCH"
    UPTIME=$(uptime -p 2>/dev/null | sed 's/up //;s/ days\?/d/;s/ hours\?/h/;s/ minutes\?/m/' || echo "N/A")

    if systemctl is-active --quiet zivpn 2>/dev/null; then
        ZIVPN_STATUS="${GRN}🟢 active${RST}"
        ZIVPN_USER_COUNT=$(jq '.auth.config | length' "$ZIVPN_CFG" 2>/dev/null || echo "0")
    else
        ZIVPN_STATUS="${RED}🔴 inactive${RST}"
        ZIVPN_USER_COUNT=0
    fi

    if systemctl is-active --quiet udp-custom 2>/dev/null; then
        UDPC_STATUS="${GRN}🟢 active${RST}"
        UDPC_USER_COUNT=$(jq 'length' "$UDPC_USERFILE" 2>/dev/null || echo "0")
    else
        UDPC_STATUS="${RED}🔴 inactive${RST}"
        UDPC_USER_COUNT=0
    fi

    DATE_TIME=$(TZ="Africa/Accra" date +"%A, %d %B %Y  %I:%M:%S %p %Z" 2>/dev/null || date)
    FLAG=$(flag "$COUNTRY_CODE")
    [ -n "$FLAG" ] && LOC_STR="${FLAG}  $CITY, $COUNTRY" || LOC_STR="$CITY, $COUNTRY"
}

