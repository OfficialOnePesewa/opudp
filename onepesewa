    [ -z "$UPTIME" ] && UPTIME="N/A"
    if systemctl is-active --quiet zivpn; then
        STATUS="${GRN}🟢 active${RST}"
    else
        STATUS="${RED}🔴 inactive${RST}"
    fi
    USER_COUNT=$(jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0")
    DATE_TIME=$(date +"%a %d %b %Y  %I:%M:%S %p %Z")
